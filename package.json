{
  "name": "worker-cms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "node scripts/install.mjs",
    "dev": "npm run build:css && wrangler dev --local",
    "build:css": "tailwindcss -i styles/admin.css -o views/assets/admin.css --minify",
    "deploy": "npm run build:css && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply cms --local && wrangler d1 migrations apply cms-published --local",
    "db:migrate:admin": "wrangler d1 migrations apply cms --local",
    "db:migrate:published": "wrangler d1 migrations apply cms-published --local",
    "type-check": "tsc --noEmit",
    "pretest": "npm run build:css",
    "test": "vitest run"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260630.1",
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
