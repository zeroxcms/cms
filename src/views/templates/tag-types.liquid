<div class="px-8 py-8">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold text-gray-900">Tag Types</h2>
    <a href="/admin/tag-types/new" class="px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg">New Tag Type</a>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <table class="w-full text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Slug</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasTagTypes %}
          {% for tagType in tagTypes %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">{{ tagType.name | escape }}</td>
              <td class="px-6 py-3 text-sm font-mono text-gray-500">{{ tagType.slug | escape }}</td>
              <td class="px-6 py-3 text-right">
                <a href="{{ tagType.editHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">Edit</a>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="3" class="px-6 py-10 text-center text-gray-400">No tag types yet.</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
