{%- comment -%}
  Generic file pagefield: stores a /media/... URL for any type the upload
  allowlist accepts (pdf, csv, txt, zip, media…), not just images. Reuses the
  picture field's data-attribute contract so the core views/assets/
  picture-field.js wiring uploads it to /admin/upload; `data-upload-dir` sends
  it to the files/ prefix instead of pictures/. Without JS the URL input is
  still editable by hand, so the field degrades cleanly.
{%- endcomment -%}
<div class="min-w-0" data-picture-field data-upload-dir="files">
  <label for="{{ field.id }}" class="block text-sm font-medium text-gray-700 mb-1">{% if field.labelKey != blank %}{{ field.labelKey | t }}{% else %}{{ field.label }}{% endif %}{% if field.required %} *{% endif %}</label>
  <div class="min-w-0 flex-1 space-y-2">
    <input id="{{ field.id }}" data-picture-url type="text" name="{{ field.inputName }}"
           value="{{ field.value }}"
           placeholder="{{ field.placeholder | default: '/media/files/...' }}"
           class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
           {% if field.required %}required{% endif %}>
    <div class="flex min-w-0 flex-wrap items-center gap-2">
      <label for="{{ field.id }}_file"
             class="cursor-pointer rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
        {{ "view_strings.snippets_pagefield_picture_basic.upload" | t }}
      </label>
      <input id="{{ field.id }}_file" data-picture-file type="file" {% if field.accept != blank %}accept="{{ field.accept }}"{% endif %} class="hidden">
      {% if field.value != blank %}<a href="{{ field.value }}" target="_blank" rel="noopener" class="min-w-0 truncate text-xs font-medium text-indigo-600 hover:text-indigo-800">{{ field.value }}</a>{% endif %}
      <span data-picture-status class="min-w-0 text-xs text-gray-500"></span>
    </div>
  </div>
</div>
