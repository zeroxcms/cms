<label for="{{ field.id | escape }}" class="min-w-0 block">
  <span class="block text-sm font-medium text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</span>
  <textarea id="{{ field.id | escape }}" name="{{ field.inputName | escape }}" rows="4"
            placeholder="{{ field.placeholder | escape }}"
            class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-y"
            {% if field.required %}required{% endif %}>{{ field.value | escape }}</textarea>
</label>
