<div class="min-w-0" data-picture-field>
  <label for="{{ field.id | escape }}" class="block text-sm font-medium text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</label>
  <div class="flex min-w-0 items-center gap-3">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-gray-200 bg-gray-50 text-gray-400">
      {% if field.value != blank %}
        <img data-picture-preview src="{{ field.value | escape }}" alt="" class="h-full w-full object-cover">
      {% else %}
        <img data-picture-preview src="" alt="" class="hidden h-full w-full object-cover">
        <span data-picture-empty class="text-xs">Image</span>
      {% endif %}
    </div>
    <div class="min-w-0 flex-1 space-y-2">
      <input id="{{ field.id | escape }}" data-picture-url type="text" name="{{ field.inputName | escape }}"
             value="{{ field.value | escape }}"
             placeholder="/media/upload/..."
             class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
             {% if field.required %}required{% endif %}>
      <div class="flex min-w-0 flex-wrap items-center gap-2">
        <label for="{{ field.id | escape }}_file"
               class="cursor-pointer rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-xs font-semibold text-gray-700 hover:bg-gray-50">
          Upload
        </label>
        <input id="{{ field.id | escape }}_file" data-picture-file type="file" accept="image/*" class="hidden">
        <span data-picture-status class="min-w-0 text-xs text-gray-500"></span>
      </div>
    </div>
  </div>
</div>

