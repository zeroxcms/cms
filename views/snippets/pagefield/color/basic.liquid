<label for="{{ field.id | escape }}" class="min-w-0 block">
  <span class="block text-sm font-medium text-gray-700 mb-1">{{ field.label | escape }}{% if field.required %} *{% endif %}</span>
  <input id="{{ field.id | escape }}" type="color" name="{{ field.inputName | escape }}"
         value="{{ field.value | escape }}"
         class="block h-10 min-w-0 w-full max-w-full rounded-lg border border-gray-300"
         {% if field.required %}required{% endif %}>
</label>
