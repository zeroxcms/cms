<fieldset class="min-w-0 sm:col-span-2">
  <legend class="block text-sm font-medium text-gray-700 mb-1">{{ field.label }}</legend>
  <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-3">
    <label for="{{ field.id }}_from" class="min-w-0 block">
      <span class="block text-xs font-medium text-gray-500 mb-1">From</span>
      <input id="{{ field.id }}_from" type="datetime-local" name="{{ names.value }}"
             value="{{ values.value }}"
             class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
    </label>
    <label for="{{ field.id }}_to" class="min-w-0 block">
      <span class="block text-xs font-medium text-gray-500 mb-1">To</span>
      <input id="{{ field.id }}_to" type="datetime-local" name="{{ names.end }}"
             value="{{ values.end }}"
             class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
    </label>
    <label for="{{ field.id }}_timezone" class="min-w-0 block">
      <span class="block text-xs font-medium text-gray-500 mb-1">Timezone</span>
      <input id="{{ field.id }}_timezone" type="text" name="{{ names.timezone }}"
             value="{{ values.timezone }}"
             placeholder="Asia/Hong_Kong"
             class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
    </label>
  </div>
</fieldset>
