<fieldset class="min-w-0 sm:col-span-2">
  <legend class="block text-sm font-medium text-gray-700 mb-1">{{ field.label | escape }}</legend>
  <div class="grid min-w-0 grid-cols-1 gap-3 sm:grid-cols-2">
    <label for="{{ field.id | escape }}_label" class="min-w-0 block">
      <span class="sr-only">{{ field.label | escape }} label</span>
      <input id="{{ field.id | escape }}_label" type="text" name="{{ names.label | escape }}"
             value="{{ values.label | escape }}"
             placeholder="Label"
             class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
    </label>
    <label for="{{ field.id | escape }}_url" class="min-w-0 block">
      <span class="sr-only">{{ field.label | escape }} URL</span>
      <input id="{{ field.id | escape }}_url" type="text" name="{{ names.url | escape }}"
             value="{{ values.url | escape }}"
             placeholder="/path-or-url"
             class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
    </label>
  </div>
</fieldset>
