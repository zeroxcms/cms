{%- comment -%}
  Page-reference field. The pointer's name is the referenced page type (e.g.
  `*event` references `event` pages), so the combobox searches that type via
  /admin/api/pages/<type>?q=… and writes the chosen page id into the hidden input
  that posts under the pointer name. A raw numeric id can still be typed.

  Behaviour lives in the core admin asset /assets/page-ref.js (loaded by the
  layout), which binds every [data-page-ref] — inline scripts don't survive
  client rendering / plugin-view sanitizing.
{%- endcomment -%}
<label for="{{ field.id }}" class="min-w-0 block">
  <span class="block text-sm font-medium text-gray-700 mb-1">{{ field.label }}</span>
  <div id="{{ field.id }}__ref" class="relative min-w-0"
       data-page-ref data-page-ref-type="{{ field.name }}">
    <input type="hidden" name="{{ field.inputName }}" value="{{ field.value }}" data-page-ref-id>
    <div class="relative min-w-0">
      <input id="{{ field.id }}" type="text" autocomplete="off"
             role="combobox" aria-expanded="false" aria-controls="{{ field.id }}__results"
             value="{% if field.value != blank %}#{{ field.value }}{% endif %}"
             placeholder="Search {{ field.name }} pages…"
             class="block min-w-0 w-full max-w-full px-3 py-2 pr-8 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
             data-page-ref-search>
      <button type="button" data-page-ref-clear
              class="absolute hidden items-center justify-center w-5 h-5 text-gray-400 hover:text-gray-600 cursor-pointer bg-transparent border-0 p-0.5 text-xs"
              style="right:6px;top:50%;transform:translateY(-50%)"
              title="Clear reference">&times;</button>
      <div id="{{ field.id }}__results"
           class="absolute left-0 right-0 top-full z-20 mt-1 hidden max-h-64 overflow-auto rounded-lg border border-gray-200 bg-white py-1 shadow-lg"
           data-page-ref-results></div>
    </div>
  </div>
</label>
