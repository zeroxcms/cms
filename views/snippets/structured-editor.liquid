<div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-5">
  <div class="flex items-center justify-between gap-4">
    <p class="text-sm font-semibold text-gray-700">Structured Content</p>
    <label class="flex items-center gap-2 text-xs text-gray-500">
      Language
      <select
        name="_language"
        class="px-2 py-1 border border-gray-300 rounded-lg text-xs"
        onchange="switchEditorLanguage(this.value)"
      >
        {% for option in languageOptions %}
          <option value="{{ option.value | escape }}" {% if option.selected %}selected{% endif %}>{{ option.value | escape }}</option>
        {% endfor %}
      </select>
    </label>
  </div>
  {{ fieldsHtml }}
  <div class="border-t border-gray-100 pt-5 space-y-4">
    <div class="flex items-center justify-between gap-4">
      <p class="text-sm font-semibold text-gray-700">Blocks</p>
      {% if hasBlockOptions %}
        <div class="flex items-center gap-2">
          <select name="block-select" class="px-2 py-1 border border-gray-300 rounded-lg text-xs">
            {% for option in blockOptions %}
              <option value="{{ option.value | escape }}">{{ option.value | escape }}</option>
            {% endfor %}
          </select>
          <button type="submit" name="action" value="block-add"
                  class="px-3 py-1.5 rounded-lg bg-gray-900 text-white text-xs font-semibold">Add Block</button>
        </div>
      {% endif %}
    </div>
    {% if hasBlocks %}
      {% for block in blocks %}
        <div class="rounded-lg border border-gray-200 p-4 space-y-4">
          <div class="flex items-center justify-between gap-3">
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">{{ block.type | escape }}</p>
            <button type="submit" name="action" value="{{ block.deleteAction | escape }}"
                    class="text-xs font-semibold text-red-600 hover:text-red-700">Delete Block</button>
          </div>
          <input type="hidden" name="#{{ block.index }}@_type" value="{{ block.type | escape }}">
          <input type="hidden" name="#{{ block.index }}@_id" value="{{ block.id | escape }}">
          {{ block.fieldsHtml }}
        </div>
      {% endfor %}
    {% else %}
      <p class="text-sm text-gray-400">No blocks yet.</p>
    {% endif %}
  </div>
</div>
