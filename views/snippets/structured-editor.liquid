{% if hasSettings %}
  <section class="min-w-0 space-y-3">
    <p class="text-sm font-semibold text-gray-700">Settings</p>
    {{ settingsHtml }}
  </section>
{% endif %}

<div class="min-w-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm space-y-5 sm:p-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm font-semibold text-gray-700">Content</p>
    {% if hasLanguageContent %}
      <label for="structured_language" class="flex min-w-0 w-full items-center gap-2 text-xs text-gray-500 sm:w-auto">
        Language
        <select
          id="structured_language"
          name="_language"
          class="min-w-0 flex-1 px-2 py-1 border border-gray-300 rounded-lg text-xs sm:flex-none"
        >
          {% for option in languageOptions %}
            <option value="{{ option.value | escape }}" {% if option.selected %}selected{% endif %}>{{ option.value | escape }}</option>
          {% endfor %}
        </select>
      </label>
    {% endif %}
  </div>
  {{ contentHtml }}
  <div class="border-t border-gray-100 pt-5 space-y-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm font-semibold text-gray-700">Blocks</p>
      {% if hasBlockOptions %}
        <div class="flex min-w-0 w-full flex-col gap-2 sm:w-auto sm:flex-row sm:flex-wrap sm:items-center">
          <label for="block_select" class="sr-only">Block type</label>
          <select id="block_select" name="block-select" class="min-w-0 w-full px-2 py-1 border border-gray-300 rounded-lg text-xs sm:w-auto">
            {% for option in blockOptions %}
              <option value="{{ option.value | escape }}">{{ option.value | escape }}</option>
            {% endfor %}
          </select>
          <button type="submit" name="action" value="block-add"
                  class="w-full shrink-0 px-3 py-1.5 rounded-lg bg-gray-900 text-white text-xs font-semibold sm:w-auto">Add Block</button>
        </div>
      {% endif %}
    </div>
    {% if hasBlocks %}
      {% assign sortedBlocks = blocks | sort: 'weight' %}
      {% for block in sortedBlocks %}
        <div class="min-w-0 rounded-lg border border-gray-200 p-4 space-y-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <p class="min-w-0 break-words text-xs font-semibold uppercase tracking-wide text-gray-500">{{ block.name | escape }}</p>
            <div class="flex shrink-0 items-center gap-3">
              <div class="flex items-center gap-1 text-sm text-gray-500">
                <span aria-hidden="true">#</span>
                <label for="{{ block.weightInputId | escape }}" class="sr-only">Weight for {{ block.name | escape }}</label>
                <input type="number" id="{{ block.weightInputId | escape }}" name="{{ block.weightInputName | escape }}"
                       value="{{ block.weight }}"
                       class="w-12 border-b border-transparent bg-transparent p-0 text-right text-lg font-bold focus:border-indigo-500 focus:outline-none">
              </div>
              <button type="submit" name="action" value="{{ block.deleteAction | escape }}"
                      class="text-xs font-semibold text-red-600 hover:text-red-700">Delete Block</button>
            </div>
          </div>
          <input type="hidden" name="#{{ block.index }}@_type" value="{{ block.type | escape }}">
          <input type="hidden" name="#{{ block.index }}@_id" value="{{ block.id | escape }}">
          {% if block.hasSettings %}
            <div class="space-y-3">
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Settings</p>
              {{ block.settingsHtml }}
            </div>
          {% endif %}
          {{ block.contentHtml }}
        </div>
      {% endfor %}
    {% else %}
      <p class="text-sm text-gray-400">No blocks yet.</p>
    {% endif %}
  </div>
</div>
