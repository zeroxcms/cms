<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-3 mb-6 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">{{ "view_strings.sections_trash.trash" | t }}</h2>
      <p class="text-sm text-gray-500 mt-1">{{ total }} {% if filterType != '' %}{{ filterType }} {% endif %}{% if singularCount %}{{ "trash.page_in_trash" | t }}{% else %}{{ "trash.pages_in_trash" | t }}{% endif %}</p>
    </div>
    <div class="flex flex-col gap-2 items-start sm:items-end">
      {% if anyTrash %}
        {% if hasTypeFilter %}
          <select id="trash-type-filter" aria-label="{{ "view_strings.sections_trash.show_only_this_type" | t }}" class="rounded-md border border-gray-300 bg-white px-2 py-1.5 text-sm">
            <option value=""{% unless filterType %} selected{% endunless %}>{{ "trash.all_types" | t }} ({{ grandTotal }})</option>
            {% for t in typeCounts %}
              <option value="{{ t.pageType }}"{% if t.pageType == filterType %} selected{% endif %}>{{ t.pageType }} ({{ t.count }})</option>
            {% endfor %}
          </select>
        {% endif %}
        {% if hasPages %}
          <form id="restore-trash-form" method="POST" action="{{ restoreAllAction }}" class="flex flex-wrap items-center gap-2">
            <input type="hidden" name="type" value="{{ filterType }}">
            <button type="submit" name="action" value="now" class="inline-flex h-9 items-center rounded-lg border border-transparent bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">{{ "view_strings.sections_trash.restore_all" | t }}</button>
            {% if hasRecent %}
              <button type="submit" name="action" value="1h" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">{{ "trash.restore_last_hour" | t }} ({{ recentCount }})</button>
            {% endif %}
          </form>
          {% if canPurgeTrash %}
            <form id="empty-trash-form" method="POST" action="{{ emptyTrashAction }}" class="flex flex-wrap items-center gap-2">
              <input type="hidden" name="type" value="{{ filterType }}">
              <button type="submit" name="action" value="now" class="inline-flex h-9 items-center rounded-lg border border-transparent bg-red-600 px-4 text-sm font-semibold text-white hover:bg-red-700">{{ "view_strings.sections_trash.empty_all" | t }}</button>
              {% if hasRecent %}
                <button type="submit" name="action" value="1h" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">{{ "trash.last_hour" | t }} ({{ recentCount }})</button>
              {% endif %}
            </form>
          {% endif %}
        {% endif %}
      {% endif %}
      <a href="/admin" class="text-sm text-indigo-600 hover:underline">{{ "view_strings.sections_trash.back_to_pages" | t }}</a>
    </div>
  </div>

  {% if hasFlash %}
    <div id="flash" class="mb-4 rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-700">{{ flash | t }}</div>
  {% endif %}

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_trash.page" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_trash.deleted" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_trash.actions" | t }}</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasPages %}
          {% for page in pages %}
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <div class="font-medium text-gray-900">{{ page.name }}</div>
                <div class="text-xs text-gray-500 font-mono">/{{ page.slug }}</div>
                {% if showTypeBadge and page.hasPageType %}
                  <div class="mt-1.5">
                    {% if page.pageTypeHref %}
                      <a href="{{ page.pageTypeHref }}" class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-700 transition-colors hover:bg-indigo-200 hover:text-gray-900">{{ page.pageType }}</a>
                    {% else %}
                      <span class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-700">{{ page.pageType }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              </td>
              <td class="px-6 py-4 text-sm text-gray-400">{{ page.updatedAt | l10n_date }}</td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap items-center gap-2">
                  <form method="POST" action="{{ page.restoreAction }}" class="inline">
                    <button type="submit"
                            class="text-indigo-600 hover:text-indigo-800 text-sm font-medium">{{ "view_strings.sections_trash.restore" | t }}</button>
                  </form>
                  {% if canPurgeTrash %}
                    <form method="POST" action="{{ page.deleteAction }}" class="inline"
                          data-confirm="{{ "view_strings.sections_trash.permanently_delete_this_page_this_cannot_be_undone" | t }}">
                      <button type="submit"
                              class="text-red-500 hover:text-red-700 text-sm font-medium">{{ "view_strings.sections_trash.delete_forever" | t }}</button>
                    </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="3" class="px-6 py-12 text-center text-gray-400">{{ "view_strings.sections_trash.trash_is_empty" | t }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>

  {% if showPagination %}
    <div class="mt-4 flex flex-col gap-3 text-sm sm:flex-row sm:items-center sm:justify-between">
      <div class="text-gray-500">Page {{ currentPage }} of {{ totalPages }}</div>
      <div class="flex flex-wrap gap-2">
        {% if hasFirstPage %}<a href="{{ firstHref }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_trash.first" | t }}</a>{% endif %}
        {% if hasPreviousPage %}<a href="{{ previousHref }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_trash.previous" | t }}</a>{% endif %}
        {% if hasNextPage %}<a href="{{ nextHref }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_trash.next" | t }}</a>{% endif %}
        {% if hasLastPage %}<a href="{{ lastHref }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_trash.last" | t }}</a>{% endif %}
      </div>
    </div>
  {% endif %}
</div>

<script nonce="{{ nonce }}">
  const flash = document.getElementById('flash');
  if (flash) setTimeout(() => flash.remove(), 4000);

  // Type filter: reload showing only the chosen type. Server-side so it stays
  // correct across pagination (not just the rows on the current page).
  const typeFilter = document.getElementById('trash-type-filter');
  if (typeFilter) {
    typeFilter.addEventListener('change', () => {
      const v = typeFilter.value;
      window.location.href = v ? '/admin/trash?type=' + encodeURIComponent(v) : '/admin/trash';
    });
  }

  // The active type's name for confirm copy — read from the select (its value
  // is a real page type, never raw URL input) so nothing user-controlled is
  // interpolated into this script.
  const scope = typeFilter && typeFilter.value ? typeFilter.value + ' ' : '';
  const recentCount = (s) => s.textContent.match(/\d+/)?.[0] ?? '?';

  const restoreTrashForm = document.getElementById('restore-trash-form');
  if (restoreTrashForm) {
    restoreTrashForm.addEventListener('submit', (e) => {
      const submitter = e.submitter;
      if (submitter && submitter.value === '1h') {
        const n = recentCount(submitter);
        if (!confirm('Restore ' + n + ' ' + scope + 'page' + (n === '1' ? '' : 's') + ' trashed in the last hour to drafts?')) {
          e.preventDefault();
        }
        return;
      }
      if (!confirm('Restore all {{ total }} ' + scope + 'page{% if total != 1 %}s{% endif %} from trash to drafts?')) {
        e.preventDefault();
      }
    });
  }

  const emptyTrashForm = document.getElementById('empty-trash-form');
  if (emptyTrashForm) {
    emptyTrashForm.addEventListener('submit', (e) => {
      const submitter = e.submitter;
      if (submitter && submitter.value === '1h') {
        const n = recentCount(submitter);
        if (!confirm('Permanently delete ' + n + ' ' + scope + 'page' + (n === '1' ? '' : 's') + ' trashed in the last hour?\n\nThis cannot be undone.')) {
          e.preventDefault();
        }
        return;
      }
      if (!confirm('Empty {{ total }} ' + scope + 'page{% if total != 1 %}s{% endif %} from trash permanently?\n\nThis cannot be undone.')) {
        e.preventDefault();
      }
    });
  }
</script>
