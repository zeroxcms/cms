<div class="max-w-xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-6">{{ heading | escape }}</h2>
  <form method="POST" action="{{ action | escape }}" class="space-y-4">
    <label class="block">
      <span class="block text-sm font-medium text-gray-700 mb-1">Name</span>
      <input name="name" required value="{{ name | escape }}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
    </label>
    <label class="block">
      <span class="block text-sm font-medium text-gray-700 mb-1">Slug</span>
      <input name="slug" value="{{ slug | escape }}" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
    </label>
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <button type="submit" class="w-full px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg sm:w-auto">Save</button>
      <a href="/admin/tag-types" class="w-full px-4 py-2 text-center bg-white border border-gray-300 rounded-lg text-sm font-semibold sm:w-auto">Cancel</a>
    </div>
  </form>
  {% if isEdit %}
    <form method="POST" action="{{ deleteAction | escape }}">
      <button type="submit" class="px-4 py-2 text-sm font-semibold text-red-600">Delete</button>
    </form>
  {% endif %}
</div>
