<div class="min-w-0 max-w-xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-1">{{ name | escape }}</h2>
  <p class="text-sm text-gray-500 mb-6">{{ email | escape }}</p>
  {% if hasError %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">{{ error | escape }}</div>
  {% endif %}
  <form method="POST" action="{{ action | escape }}" class="min-w-0 space-y-4">
    <fieldset class="min-w-0">
      <legend class="block text-sm font-medium text-gray-700 mb-1">Roles</legend>
      <div class="flex flex-wrap gap-2 rounded-lg border border-gray-200 bg-gray-50 p-3">
        {% for option in roleOptions %}
          <label class="inline-flex items-center gap-2 rounded-md bg-white border border-gray-200 px-3 py-1.5 text-sm">
            <input type="checkbox" name="roles" value="{{ option.value | escape }}"{% if option.checked %} checked{% endif %} class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            <span>{{ option.label | escape }}</span>
          </label>
        {% endfor %}
      </div>
      <span class="block text-xs text-gray-500 mt-1">A user with no roles selected becomes a viewer (no admin access).</span>
    </fieldset>
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="w-full shrink-0 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg sm:w-auto">Save</button>
      <a href="/admin/users" class="w-full shrink-0 px-4 py-2 text-center bg-white border border-gray-300 rounded-lg text-sm font-semibold sm:w-auto">Cancel</a>
    </div>
  </form>
</div>
