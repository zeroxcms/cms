<div class="min-w-0 max-w-xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-1">{{ name | escape }}</h2>
  <p class="text-sm text-gray-500 mb-6">{{ email | escape }}</p>
  {% if hasError %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">{{ error | escape }}</div>
  {% endif %}
  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flash | escape }}</div>
  {% endif %}
  <form method="POST" action="{{ action | escape }}" class="min-w-0 space-y-4">
    <fieldset class="min-w-0">
      <legend class="block text-sm font-medium text-gray-700 mb-1">Roles</legend>
      <div class="flex flex-wrap gap-2 rounded-lg border border-gray-200 bg-gray-50 p-3">
        {% for option in roleOptions %}
          <label class="inline-flex items-center gap-2 rounded-md bg-white border border-gray-200 px-3 py-1.5 text-sm">
            <input type="checkbox" name="roles" value="{{ option.value | escape }}"{% if option.checked %} checked{% endif %} class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            <span>{{ option.label | escape }}</span>
          </label>
        {% endfor %}
      </div>
      <span class="block text-xs text-gray-500 mt-1">A user with no roles selected becomes a viewer (no admin access).</span>
    </fieldset>
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">Save</button>
      <a href="/admin/users" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">Cancel</a>
    </div>
  </form>

  <section class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">Credits</h3>
    <p class="mt-2 text-2xl font-bold text-gray-900">{{ creditBalance }}</p>
    <form method="POST" action="{{ creditAdjustAction | escape }}" class="mt-4 space-y-3">
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">Adjustment</span>
        <input name="amount" type="number" step="1" required placeholder="e.g. 500 or -100"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        <span class="block text-xs text-gray-500 mt-1">Positive grants credits, negative deducts. The balance can never go below zero.</span>
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">Note</span>
        <input name="note" type="text" required maxlength="300" placeholder="Why this adjustment is made"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Apply adjustment</button>
    </form>

    {% if canShareCredits %}
      <form method="POST" action="{{ sharedGrantAction | escape }}"
            data-confirm="Grant shared-pool credits to this user?"
            class="mt-5 space-y-3 border-t border-gray-100 pt-5">
        <h4 class="text-sm font-semibold text-gray-900">Grant from shared pool</h4>
        <p class="text-xs text-gray-500">
          Shared pool balance: <span class="font-semibold text-gray-900">{{ sharedCreditBalance }}</span>.
          Move credits from the site-wide pool into this user's balance.
        </p>
        <label class="block">
          <span class="block text-sm font-medium text-gray-700 mb-1">Amount</span>
          <input name="amount" type="number" step="1" min="1" required placeholder="e.g. 100"
                 class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </label>
        <label class="block">
          <span class="block text-sm font-medium text-gray-700 mb-1">Note <span class="text-gray-400">(optional)</span></span>
          <input name="note" type="text" maxlength="300" placeholder="What this grant is for"
                 class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </label>
        <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Grant credits</button>
      </form>
    {% endif %}

    {% if hasCreditLedger %}
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">When</th>
              <th class="px-4 py-2">Action</th>
              <th class="px-4 py-2">Change</th>
              <th class="px-4 py-2">Balance</th>
              <th class="px-4 py-2">By</th>
            </tr>
          </thead>
          <tbody>
            {% for entry in creditLedger %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3 text-xs text-gray-500">{{ entry.createdAt | escape }}</td>
                <td class="px-4 py-3">
                  <span class="font-mono text-xs">{{ entry.action | escape }}</span>
                  {% if entry.note != '' %}<div class="text-xs text-gray-500 mt-0.5">{{ entry.note | escape }}</div>{% endif %}
                </td>
                <td class="px-4 py-3 text-sm {% if entry.isSpend %}text-red-700{% else %}text-green-700{% endif %}">{{ entry.delta | escape }}</td>
                <td class="px-4 py-3 text-sm text-gray-700">{{ entry.balanceAfter }}</td>
                <td class="px-4 py-3 text-xs text-gray-500">{{ entry.createdBy | escape }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% endif %}
  </section>
</div>
