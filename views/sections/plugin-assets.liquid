<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← Plugins</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel | escape }} · Assets</h2>
      <p class="mt-1 text-sm text-gray-500">JS/CSS files this plugin wants to run inside CMS chrome. Approving a file pins its content hash — if the plugin's file ever changes, it stops running until re-approved.</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessage | escape }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      This plugin is not reachable right now, so its declared assets can't be listed.
    </div>
  {% else %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
      <table class="w-full min-w-[560px] text-left text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2">Asset</th>
            <th class="px-4 py-2">Status</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody>
          {% if hasAssets %}
            {% for asset in assets %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900">{{ asset.label | escape }}</div>
                  <div class="text-xs text-gray-500 font-mono">{{ asset.path | escape }}</div>
                  {% if asset.approved %}
                    <div class="text-xs text-gray-400 mt-0.5">Approved by {{ asset.approvedBy | escape }}</div>
                    <div class="text-xs text-gray-400 mt-0.5 font-mono break-all">{{ asset.integrity | escape }}</div>
                  {% endif %}
                </td>
                <td class="px-4 py-3">
                  <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ asset.statusClass | escape }}">{{ asset.statusLabel | escape }}</span>
                  {% if asset.fetchError %}<div class="text-xs text-red-600 mt-1">Could not fetch current file from plugin</div>{% endif %}
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  {% if asset.approved %}
                    <form method="post" action="{{ asset.revokeAction | escape }}" class="inline" data-confirm="Revoke approval for {{ asset.path | escape }}? It will stop running in CMS chrome.">
                      <input type="hidden" name="path" value="{{ asset.path | escape }}">
                      <button type="submit" class="px-3 py-1 rounded-lg border border-red-300 text-xs font-semibold text-red-700">Revoke</button>
                    </form>
                    {% if asset.drifted %}
                      <form method="post" action="{{ asset.approveAction | escape }}" class="inline">
                        <input type="hidden" name="path" value="{{ asset.path | escape }}">
                        <button type="submit" class="ml-1 px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Re-approve</button>
                      </form>
                    {% endif %}
                  {% else %}
                    <form method="post" action="{{ asset.approveAction | escape }}" class="inline">
                      <input type="hidden" name="path" value="{{ asset.path | escape }}">
                      <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Approve</button>
                    </form>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="3" class="px-4 py-8 text-center text-sm text-gray-500">This plugin declares no assets.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
