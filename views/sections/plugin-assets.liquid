<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "view_strings.sections_plugin_assets.plugins" | t }}</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel }} · {{ "view_strings.sections_plugin_assets.assets" | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugin_assets.js_css_files_this_plugin_wants_to_run_inside_cms_chrome_approving_a_file" | t }}</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessageKey | t }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      {{ "view_strings.sections_plugin_assets.this_plugin_is_not_reachable_right_now_so_its_declared_assets_can_t_be_l" | t }}
    </div>
  {% else %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
      <table class="w-full min-w-[560px] text-left text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2">{{ "view_strings.sections_plugin_assets.asset" | t }}</th>
            <th class="px-4 py-2">{{ "view_strings.sections_plugin_assets.status" | t }}</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody>
          {% if hasAssets %}
            {% for asset in assets %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900">{{ asset.label }}</div>
                  <div class="text-xs text-gray-500 font-mono">{{ asset.path }}</div>
                  {% if asset.approved %}
                    <div class="text-xs text-gray-400 mt-0.5">{{ "view_strings.sections_plugin_assets.approved_by" | t }} {{ asset.approvedBy }}</div>
                    <div class="text-xs text-gray-400 mt-0.5 font-mono break-all">{{ asset.integrity }}</div>
                  {% endif %}
                </td>
                <td class="px-4 py-3">
                  <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ asset.statusClass }}">{{ asset.statusKey | t }}</span>
                  {% if asset.fetchError %}<div class="text-xs text-red-600 mt-1">{{ "view_strings.sections_plugin_assets.could_not_fetch_current_file_from_plugin" | t }}</div>{% endif %}
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  {% if asset.approved %}
                    <form method="post" action="{{ asset.revokeAction }}" class="inline" data-confirm="{{ "view_strings.sections_plugin_assets.revoke_confirmation" | t }}">
                      <input type="hidden" name="path" value="{{ asset.path }}">
                      <button type="submit" class="px-3 py-1 rounded-lg border border-red-300 text-xs font-semibold text-red-700">{{ "view_strings.sections_plugin_assets.revoke" | t }}</button>
                    </form>
                    {% if asset.drifted %}
                      <form method="post" action="{{ asset.approveAction }}" class="inline">
                        <input type="hidden" name="path" value="{{ asset.path }}">
                        <button type="submit" class="ml-1 px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">{{ "view_strings.sections_plugin_assets.re_approve" | t }}</button>
                      </form>
                    {% endif %}
                  {% else %}
                    <form method="post" action="{{ asset.approveAction }}" class="inline">
                      <input type="hidden" name="path" value="{{ asset.path }}">
                      <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">{{ "view_strings.sections_plugin_assets.approve" | t }}</button>
                    </form>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="3" class="px-4 py-8 text-center text-sm text-gray-500">{{ "view_strings.sections_plugin_assets.this_plugin_declares_no_assets" | t }}</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
