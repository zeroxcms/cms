<div class="min-w-0 max-w-2xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-6">{{ heading | escape }}</h2>
  {% if readOnly %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-600">This page type is defined in the config file and cannot be edited here.</div>
  {% endif %}
  {% if hasError %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-sm text-red-700">{{ error | escape }}</div>
  {% endif %}
  <form method="POST" action="{{ action | escape }}" class="min-w-0 space-y-4">
    <label for="page_type_name" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Name</span>
      <input id="page_type_name" name="name" required value="{{ name | escape }}"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm{% if readOnly %} bg-gray-50 text-gray-600{% endif %}">
    </label>
    <label for="page_type_slug" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Slug</span>
      <input id="page_type_slug" name="slug" value="{{ slug | escape }}"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono{% if readOnly %} bg-gray-50 text-gray-600{% endif %}">
      {% unless readOnly %}<span class="block text-xs text-gray-500 mt-1">The page-type key used on pages (e.g. <code>event</code>). Cannot collide with a config or existing type.</span>{% endunless %}
    </label>
    <label for="page_type_weight" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Weight</span>
      <input id="page_type_weight" name="weight" type="number" value="{{ weight | escape }}"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-32 max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm{% if readOnly %} bg-gray-50 text-gray-600{% endif %}">
    </label>
    <label for="page_type_blueprint" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Blueprint (JSON array)</span>
      <textarea id="page_type_blueprint" name="blueprint" rows="8"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono{% if readOnly %} bg-gray-50 text-gray-600{% endif %}" spellcheck="false">{{ blueprint | escape }}</textarea>
      {% unless readOnly %}<span class="block text-xs text-gray-500 mt-1">Field definitions, e.g. <code>["@date", "name", "body:text", {"items": ["name"]}]</code></span>{% endunless %}
    </label>

    <fieldset class="min-w-0">
      <legend class="block text-sm font-medium text-gray-700 mb-1">Blocks</legend>
      {% if hasBlockOptions %}
        <div class="flex flex-wrap gap-2 rounded-lg border border-gray-200 bg-gray-50 p-3">
          {% for option in blockOptions %}
            <label class="inline-flex items-center gap-2 rounded-md bg-white border border-gray-200 px-3 py-1.5 text-sm{% if readOnly %} text-gray-500{% endif %}">
              <input type="checkbox" name="block_lists" value="{{ option.value | escape }}"{% if option.checked %} checked{% endif %}{% if readOnly %} disabled{% endif %} class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              <span class="font-mono">{{ option.label | escape }}</span>
            </label>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-gray-400">No block types defined yet. Add some under <a href="/admin/block_types" class="text-indigo-600 hover:text-indigo-800">Block Types</a>.</p>
      {% endif %}
      {% unless readOnly %}<span class="block text-xs text-gray-500 mt-1">Blocks available to pages of this type.</span>{% endunless %}
    </fieldset>

    <fieldset class="min-w-0">
      <legend class="block text-sm font-medium text-gray-700 mb-1">Taxonomies</legend>
      {% if hasTaxonomyOptions %}
        <div class="flex flex-wrap gap-2 rounded-lg border border-gray-200 bg-gray-50 p-3">
          {% for option in taxonomyOptions %}
            <label class="inline-flex items-center gap-2 rounded-md bg-white border border-gray-200 px-3 py-1.5 text-sm{% if readOnly %} text-gray-500{% endif %}">
              <input type="checkbox" name="taxonomy_lists" value="{{ option.value | escape }}"{% if option.checked %} checked{% endif %}{% if readOnly %} disabled{% endif %} class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              <span>{{ option.label | escape }}</span>
            </label>
          {% endfor %}
        </div>
      {% else %}
        <p class="text-sm text-gray-400">No taxonomies defined yet. Add some under <a href="/admin/taxonomies" class="text-indigo-600 hover:text-indigo-800">Taxonomies</a>.</p>
      {% endif %}
      {% unless readOnly %}<span class="block text-xs text-gray-500 mt-1">Taxonomies shown when editing pages of this type.</span>{% endunless %}
    </fieldset>

    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      {% unless readOnly %}<button type="submit" class="w-full shrink-0 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg sm:w-auto">Save</button>{% endunless %}
      <a href="/admin/page_types" class="w-full shrink-0 px-4 py-2 text-center bg-white border border-gray-300 rounded-lg text-sm font-semibold sm:w-auto">{% if readOnly %}Back{% else %}Cancel{% endif %}</a>
    </div>
  </form>
  {% if isEdit %}
    <form method="POST" action="{{ deleteAction | escape }}" data-confirm="Delete this page type? Existing pages keep their type string.">
      <button type="submit" class="mt-4 w-full px-4 py-2 text-sm font-semibold text-red-600 sm:w-auto">Delete</button>
    </form>
  {% endif %}
</div>
