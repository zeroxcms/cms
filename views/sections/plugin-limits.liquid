<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "view_strings.sections_plugin_limits.plugins" | t }}</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel }} · {{ "view_strings.sections_plugin_limits.limits" | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugin_limits.quotas_and_operational_limits_this_plugin_declares_page_quotas_are_enfor" | t }}</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessageKey | t }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      {{ "view_strings.sections_plugin_limits.this_plugin_is_not_reachable_right_now_so_its_declared_limits_can_t_be_l" | t }}
    </div>
  {% else %}
    <form method="post" action="{{ saveAction }}">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
        <table class="w-full min-w-[680px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_limits.limit" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_limits.scope" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_limits.usage" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_limits.effective" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_limits.configure" | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% if hasLimits %}
              {% for limit in limits %}
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900">{{ limit.label }}</div>
                    <div class="text-xs text-gray-400 mt-0.5 font-mono">{{ limit.key }} · {% if limit.pageTypeKey != '' %}{{ limit.pageTypeKey | t }}{% else %}{{ limit.pageType }}{% endif %}</div>
                    {% if limit.description != '' %}<div class="text-xs text-gray-500 mt-0.5">{{ limit.description }}</div>{% endif %}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">{{ limit.scopeKey | t }}{% if limit.scopeDetail != '' %} {{ limit.scopeDetail }}{% endif %}</td>
                  <td class="px-4 py-3 text-sm text-gray-700">{% if limit.usageKey != '' %}{{ limit.usageKey | t }}{% else %}{{ limit.usageLabel }}{% endif %}</td>
                  <td class="px-4 py-3">
                    <div class="text-sm text-gray-700">{% if limit.effectiveKey != '' %}{{ limit.effectiveKey | t }}{% else %}{{ limit.effectiveLabel }}{% endif %}{% if limit.usesDefault %} ({{ "view_strings.sections_plugin_limits.default" | t }}){% endif %}</div>
                    <div class="text-xs text-gray-400 mt-0.5">{{ "view_strings.sections_plugin_limits.default" | t }}: {% if limit.defaultKey != '' %}{{ limit.defaultKey | t }}{% else %}{{ limit.defaultLabel }}{% endif %}</div>
                  </td>
                  <td class="px-4 py-3">
                    <input name="value_{{ limit.key }}" type="number" min="0" step="1" value="{{ limit.value }}" placeholder="{{ "view_strings.sections_plugin_limits.default" | t }}"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    <label class="flex items-center gap-2 text-sm text-gray-700 mt-2">
                      <input name="unlimited_{{ limit.key }}" type="checkbox" value="1"{% if limit.unlimited %} checked{% endif %}> {{ "view_strings.sections_plugin_limits.unlimited" | t }}
                    </label>
                  </td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="5" class="px-4 py-8 text-center text-sm text-gray-500">{{ "view_strings.sections_plugin_limits.this_plugin_declares_no_configurable_limits" | t }}</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
      {% if hasLimits %}
        <div class="mt-4">
          <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">{{ "view_strings.sections_plugin_limits.save_limits" | t }}</button>
        </div>
      {% endif %}
    </form>
  {% endif %}
</div>
