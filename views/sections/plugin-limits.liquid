<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← Plugins</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel | escape }} · Limits</h2>
      <p class="mt-1 text-sm text-gray-500">Quotas and operational limits this plugin declares. Page quotas are enforced by the CMS; operational limits are enforced by the plugin. Leave a value blank to use the plugin default; tick Unlimited to lift a default.</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessage | escape }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      This plugin is not reachable right now, so its declared limits can't be listed.
    </div>
  {% else %}
    <form method="post" action="{{ saveAction | escape }}">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
        <table class="w-full min-w-[680px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">Limit</th>
              <th class="px-4 py-2">Scope</th>
              <th class="px-4 py-2">Usage</th>
              <th class="px-4 py-2">Effective</th>
              <th class="px-4 py-2">Configure</th>
            </tr>
          </thead>
          <tbody>
            {% if hasLimits %}
              {% for limit in limits %}
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900">{{ limit.label | escape }}</div>
                    <div class="text-xs text-gray-400 mt-0.5 font-mono">{{ limit.key | escape }} · {{ limit.pageType | escape }}</div>
                    {% if limit.description != '' %}<div class="text-xs text-gray-500 mt-0.5">{{ limit.description | escape }}</div>{% endif %}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">{{ limit.scopeLabel | escape }}</td>
                  <td class="px-4 py-3 text-sm text-gray-700">{{ limit.usageLabel | escape }}</td>
                  <td class="px-4 py-3">
                    <div class="text-sm text-gray-700">{{ limit.effectiveLabel | escape }}</div>
                    <div class="text-xs text-gray-400 mt-0.5">Default: {{ limit.defaultLabel | escape }}</div>
                  </td>
                  <td class="px-4 py-3">
                    <input name="value_{{ limit.key }}" type="number" min="0" step="1" value="{{ limit.value | escape }}" placeholder="Default"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                    <label class="flex items-center gap-2 text-sm text-gray-700 mt-2">
                      <input name="unlimited_{{ limit.key }}" type="checkbox" value="1"{% if limit.unlimited %} checked{% endif %}> Unlimited
                    </label>
                  </td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="5" class="px-4 py-8 text-center text-sm text-gray-500">This plugin declares no configurable limits.</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
      {% if hasLimits %}
        <div class="mt-4">
          <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Save limits</button>
        </div>
      {% endif %}
    </form>
  {% endif %}
</div>
