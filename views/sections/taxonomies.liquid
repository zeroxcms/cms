<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <h2 class="text-2xl font-bold text-gray-900">Taxonomies</h2>
    {% if canWrite %}
      <a href="/admin/taxonomies/new"
         title="New Taxonomy"
         aria-label="New Taxonomy"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
        <span class="hidden lg:inline">New Taxonomy</span>
      </a>
    {% endif %}
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Slug</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasTaxonomies %}
          {% for taxonomy in taxonomies %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">{{ taxonomy.name | escape }}</td>
              <td class="px-6 py-3 text-sm font-mono text-gray-500">{{ taxonomy.slug | escape }}</td>
              <td class="px-6 py-3 text-right">
                <a href="{{ taxonomy.editHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{% if canWrite %}Edit{% else %}View{% endif %}</a>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="3" class="px-6 py-10 text-center text-gray-400">No taxonomies yet.</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
