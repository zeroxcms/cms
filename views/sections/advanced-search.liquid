<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6 flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">{{ pageTitle | escape }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ resultCountLabel | escape }}</p>
    </div>
    <div class="flex flex-col gap-2 sm:flex-row">
      {% if hasExportHref %}
        <a href="{{ exportHref | escape }}"
           title="Export"
           aria-label="Export"
           class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#download"></use></svg>
          <span class="hidden lg:inline">Export</span>
        </a>
      {% endif %}
      <a href="{{ listHref | escape }}"
         title="List"
         aria-label="List"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#list"></use></svg>
        <span class="hidden lg:inline">List</span>
      </a>
    </div>
  </div>

  <form method="GET" action="{{ searchAction | escape }}" class="mb-6 rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
    <div class="grid gap-3 md:grid-cols-[minmax(10rem,1fr)_minmax(0,1fr)_9rem_8rem_8rem] md:items-end">
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Type</span>
        {% if canSelectPageType %}
          <select id="advanced_search_page_type" name="page_type" class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="all" {% if pageType == 'all' %}selected{% endif %}>All Types</option>
            {% for option in pageTypes %}
              <option value="{{ option.value | escape }}" {% if option.selected %}selected{% endif %}>{{ option.label | escape }}</option>
            {% endfor %}
          </select>
        {% else %}
          <div class="flex h-10 w-full items-center rounded-lg border border-gray-200 bg-gray-50 px-3 text-sm font-medium text-gray-700">
            {{ pageType | escape }}
          </div>
        {% endif %}
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Operator</span>
        <select name="operator" class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="AND" {% if operator == 'AND' %}selected{% endif %}>AND</option>
          <option value="OR" {% if operator == 'OR' %}selected{% endif %}>OR</option>
          <option value="NOT" {% if operator == 'NOT' %}selected{% endif %}>NOT</option>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Page Size</span>
        <input type="number" name="pagesize" value="{{ pageSize }}" min="1" max="100"
               class="h-10 w-full rounded-lg border border-gray-300 px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Sort</span>
        <select name="sort" class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="updated_at" {% if sort == 'updated_at' %}selected{% endif %}>Updated</option>
          <option value="created_at" {% if sort == 'created_at' %}selected{% endif %}>Created</option>
          <option value="name" {% if sort == 'name' %}selected{% endif %}>Name</option>
          <option value="weight" {% if sort == 'weight' %}selected{% endif %}>Weight</option>
          <option value="id" {% if sort == 'id' %}selected{% endif %}>ID</option>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Order</span>
        <select name="order" class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="DESC" {% if order == 'DESC' %}selected{% endif %}>Desc</option>
          <option value="ASC" {% if order == 'ASC' %}selected{% endif %}>Asc</option>
        </select>
      </label>
    </div>

    <div id="advanced-search-criteria" class="mt-4 grid gap-3">
      {% for criterion in criteria %}
        <div data-criterion-row class="grid gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3 lg:grid-cols-[3rem_minmax(0,1fr)_minmax(12rem,18rem)_minmax(12rem,1fr)_2.5rem] lg:items-start">
          <div data-criterion-number class="flex h-10 items-center text-sm font-semibold text-gray-500">#{{ criterion.index }}</div>
          <label class="block">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Search</span>
            <input type="search" name="search{{ criterion.index }}" value="{{ criterion.term | escape }}" placeholder="name email company"
                   class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
          </label>
          <label class="block">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Path</span>
            <input type="text" name="path{{ criterion.index }}" value="{{ criterion.path | escape }}" placeholder="position[*].company" list="advanced-search-path-options"
                   class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
          </label>
          <div>
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Tags</span>
            <details class="rounded-lg border border-gray-300 bg-white">
              <summary class="flex h-10 cursor-pointer items-center px-3 text-sm font-medium text-gray-700">Select Tags</summary>
              <div class="max-h-56 overflow-y-auto border-t border-gray-200 p-3">
                {% if criterion.tagGroups.size > 0 %}
                  {% for group in criterion.tagGroups %}
                    <div class="mb-3 last:mb-0">
                      <div class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-500">{{ group.name | escape }}</div>
                      <div class="grid gap-1">
                        {% for tag in group.tags %}
                          <label class="flex min-h-7 items-center gap-2 text-sm text-gray-700">
                            <input type="checkbox" name="tags{{ criterion.index }}" value="{{ tag.idString | escape }}"
                                   class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
                                   {% if tag.selected %}checked{% endif %}>
                            <span>{{ tag.name | escape }}</span>
                          </label>
                        {% endfor %}
                      </div>
                    </div>
                  {% endfor %}
                {% else %}
                  <div class="text-sm text-gray-400">No tags</div>
                {% endif %}
              </div>
            </details>
          </div>
          <button type="button" data-remove-criterion title="Remove criterion" aria-label="Remove criterion"
                  class="mt-6 inline-flex h-10 w-10 items-center justify-center rounded-lg text-gray-500 transition-colors hover:bg-gray-100 hover:text-red-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#x"></use></svg>
          </button>
        </div>
      {% endfor %}
    </div>

    <template id="advanced-search-criterion-template">
      <div data-criterion-row class="grid gap-3 rounded-lg border border-gray-200 bg-gray-50 p-3 lg:grid-cols-[3rem_minmax(0,1fr)_minmax(12rem,18rem)_minmax(12rem,1fr)_2.5rem] lg:items-start">
        <div data-criterion-number class="flex h-10 items-center text-sm font-semibold text-gray-500">#__INDEX__</div>
        <label class="block">
          <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Search</span>
          <input type="search" name="search__INDEX__" value="" placeholder="name email company"
                 class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </label>
        <label class="block">
          <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Path</span>
          <input type="text" name="path__INDEX__" value="" placeholder="position[*].company" list="advanced-search-path-options"
                 class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
        </label>
        <div>
          <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Tags</span>
          <details class="rounded-lg border border-gray-300 bg-white">
            <summary class="flex h-10 cursor-pointer items-center px-3 text-sm font-medium text-gray-700">Select Tags</summary>
            <div class="max-h-56 overflow-y-auto border-t border-gray-200 p-3">
              {% if tagGroups.size > 0 %}
                {% for group in tagGroups %}
                  <div class="mb-3 last:mb-0">
                    <div class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-500">{{ group.name | escape }}</div>
                    <div class="grid gap-1">
                      {% for tag in group.tags %}
                        <label class="flex min-h-7 items-center gap-2 text-sm text-gray-700">
                          <input type="checkbox" name="tags__INDEX__" value="{{ tag.idString | escape }}"
                                 class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                          <span>{{ tag.name | escape }}</span>
                        </label>
                      {% endfor %}
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                <div class="text-sm text-gray-400">No tags</div>
              {% endif %}
            </div>
          </details>
        </div>
        <button type="button" data-remove-criterion title="Remove criterion" aria-label="Remove criterion"
                class="mt-6 inline-flex h-10 w-10 items-center justify-center rounded-lg text-gray-500 transition-colors hover:bg-gray-100 hover:text-red-600">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#x"></use></svg>
        </button>
      </div>
    </template>

    <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:justify-between">
      <button type="button" id="advanced-search-add-criterion"
              title="Add Criterion"
              aria-label="Add Criterion"
              class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#plus"></use></svg>
        <span class="hidden lg:inline">Add Criterion</span>
      </button>
      <div class="flex flex-col gap-2 sm:flex-row">
      <a href="{{ resetHref | escape }}"
         class="inline-flex h-10 items-center justify-center rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
        Reset
      </a>
      <button type="submit"
              title="Search"
              aria-label="Search"
              class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-indigo-600 text-white shadow-sm transition-colors hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#search"></use></svg>
      </button>
      </div>
    </div>
  </form>

  <datalist id="advanced-search-path-options">
    {% for pathOption in pathOptions %}
      <option value="{{ pathOption | escape }}"></option>
    {% endfor %}
  </datalist>
  <script type="application/json" id="advanced-search-path-options-data">{{ pathOptionsByPageTypeJson }}</script>

  {% if hasResults %}
    <form id="advanced-search-bulk-form" method="POST" action="{{ bulkAction | escape }}" class="mb-3 hidden rounded-xl border border-gray-200 bg-white p-3 shadow-sm" data-bulk-form aria-hidden="true">
      <input type="hidden" name="return_to" value="{{ currentHref | escape }}">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div class="grid gap-3 sm:grid-cols-[minmax(9rem,12rem)_minmax(12rem,16rem)]">
          <label class="block">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Bulk Action</span>
            <select name="bulk_action" data-bulk-action class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <option value="publish">Publish</option>
              <option value="unpublish">Unpublish</option>
              <option value="delete">Move to Trash</option>
            </select>
          </label>
          <label class="block">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">Apply To</span>
            <select name="scope" data-bulk-scope class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <option value="selected">Selected items</option>
              <option value="all">All {{ count }} results</option>
            </select>
          </label>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
          <div class="text-sm text-gray-500"><span data-selected-count>0</span> selected</div>
          <button type="submit"
                  title="Apply bulk action"
                  aria-label="Apply bulk action"
                  class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-indigo-700">
            Apply
          </button>
        </div>
      </div>
    </form>
  {% endif %}

  <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
    <table class="relative w-full min-w-[840px] text-left">
      <thead class="border-b border-gray-200 bg-gray-50">
        <tr>
          <th class="w-12 px-6 py-3">
            {% if hasResults %}
              <input type="checkbox" data-bulk-select-all title="Select all visible pages" aria-label="Select all visible pages"
                     class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            {% endif %}
          </th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Page</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Type</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Weight</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Status</th>
          <th class="px-6 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasResults %}
          {% for page in pages %}
            <tr class="transition-colors hover:bg-gray-50">
              <td class="px-6 py-4 align-top">
                <input type="checkbox" name="page_ids" value="{{ page.id }}" form="advanced-search-bulk-form"
                       data-bulk-page-checkbox title="Select {{ page.name | escape }}" aria-label="Select {{ page.name | escape }}"
                       class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              </td>
              <td class="px-6 py-4">
                <a href="{{ page.editHref | escape }}" class="flex flex-col gap-1">
                  <div class="font-medium text-gray-900">{{ page.name | escape }}</div>
                  <div class="font-mono text-xs text-gray-500">/{{ page.slug | escape }}</div>
                </a>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">
                {% if page.pageTypeHref %}
                  <a href="{{ page.pageTypeHref | escape }}" class="font-medium text-indigo-600 hover:text-indigo-800 hover:underline">
                    {{ page.pageType | escape }}
                  </a>
                {% else %}
                  {{ page.pageType | escape }}
                {% endif %}
              </td>
              <td class="px-6 py-4">
                <div class="flex min-w-0 items-center gap-2">
                  <span class="text-sm text-gray-700">{{ page.weight }}</span>
                  {% if page.hasLiveWeightDrift %}
                    <span title="Live weight is {{ page.liveWeight }}; publish to sync" class="inline-flex items-center text-amber-600">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#warning"></use></svg>
                    </span>
                  {% endif %}
                </div>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  {% if page.isPublished %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                      <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>Live
                    </span>
                    {% if page.hasLiveLectDrift %}
                      <span title="Live content differs from draft; publish to sync" class="inline-flex items-center text-amber-600">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#warning"></use></svg>
                        <span class="sr-only">Live content differs from draft</span>
                      </span>
                    {% endif %}
                  {% else %}
                    <span class="inline-flex items-center gap-1 rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">
                      <span class="h-1.5 w-1.5 rounded-full bg-yellow-500"></span>Draft
                    </span>
                  {% endif %}
                </div>
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap items-center gap-2">
                  <a href="{{ page.editHref | escape }}" title="Edit" aria-label="Edit {{ page.name | escape }}"
                     class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 transition-colors hover:bg-indigo-50 hover:text-indigo-800">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#pencil-square"></use></svg>
                    <span class="sr-only">Edit</span>
                  </a>
                  {% if page.isPublished %}
                    <form method="POST" action="{{ page.unpublishAction | escape }}" class="inline shrink-0" data-confirm="Unpublish this page?">
                      <button type="submit" title="Unpublish" aria-label="Unpublish {{ page.name | escape }}"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-yellow-600 transition-colors hover:bg-yellow-50 hover:text-yellow-800">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#eye-off"></use></svg>
                        <span class="sr-only">Unpublish</span>
                      </button>
                    </form>
                  {% else %}
                    <form method="POST" action="{{ page.publishAction | escape }}" class="inline shrink-0">
                      <button type="submit" title="Publish" aria-label="Publish {{ page.name | escape }}"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-green-600 transition-colors hover:bg-green-50 hover:text-green-800">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#cloud-upload"></use></svg>
                        <span class="sr-only">Publish</span>
                      </button>
                    </form>
                  {% endif %}
                  <form method="POST" action="{{ page.deleteAction | escape }}" class="inline shrink-0" data-confirm="Move this page to trash?">
                    <button type="submit" title="Trash" aria-label="Move {{ page.name | escape }} to trash"
                            class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-red-500 transition-colors hover:bg-red-50 hover:text-red-700">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#trash-can"></use></svg>
                      <span class="sr-only">Trash</span>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-gray-400">
              {% if hasSearch %}
                No matching pages.
              {% else %}
                Enter search criteria.
              {% endif %}
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>

  {% if showPagination %}
    <div class="mt-4 flex items-center justify-between gap-3 text-sm">
      <div class="text-gray-500">Page {{ currentPage }} of {{ totalPages }}</div>
      <div class="flex gap-2">
        {% if hasPreviousPage %}
          <a href="{{ previousHref | escape }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">Previous</a>
        {% endif %}
        {% if hasNextPage %}
          <a href="{{ nextHref | escape }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">Next</a>
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>

<script nonce="{{ nonce }}">
  (() => {
    const criteria = document.getElementById('advanced-search-criteria');
    const template = document.getElementById('advanced-search-criterion-template');
    const addButton = document.getElementById('advanced-search-add-criterion');
    const pageTypeSelect = document.getElementById('advanced_search_page_type');
    const pathOptionsList = document.getElementById('advanced-search-path-options');
    const pathOptionsData = document.getElementById('advanced-search-path-options-data');
    const bulkForm = document.querySelector('[data-bulk-form]');
    const bulkSelectAll = document.querySelector('[data-bulk-select-all]');
    const bulkCheckboxes = Array.from(document.querySelectorAll('[data-bulk-page-checkbox]'));
    const bulkSelectedCount = document.querySelector('[data-selected-count]');
    const bulkScope = document.querySelector('[data-bulk-scope]');
    const bulkAction = document.querySelector('[data-bulk-action]');
    let nextIndex = {{ nextCriterionIndex }};

    const pathOptionsByPageType = JSON.parse(pathOptionsData?.textContent || '{}');

    const updatePathOptions = (pageType) => {
      if (!pathOptionsList) return;
      const values = pathOptionsByPageType[pageType] || pathOptionsByPageType.all || [];
      pathOptionsList.replaceChildren();
      values.forEach((value) => {
        const option = document.createElement('option');
        option.value = value;
        pathOptionsList.appendChild(option);
      });
    };

    const updateRemoveButtons = () => {
      const rows = criteria.querySelectorAll('[data-criterion-row]');
      rows.forEach((row) => {
        const button = row.querySelector('[data-remove-criterion]');
        if (button) button.disabled = rows.length <= 1;
      });
    };

    const selectedBulkCount = () => bulkCheckboxes.filter((checkbox) => checkbox.checked).length;

    const updateBulkSelection = () => {
      const selected = selectedBulkCount();
      if (bulkSelectedCount) bulkSelectedCount.textContent = String(selected);
      if (bulkForm) {
        bulkForm.classList.toggle('hidden', selected === 0);
        bulkForm.setAttribute('aria-hidden', selected === 0 ? 'true' : 'false');
      }
      if (bulkSelectAll) {
        bulkSelectAll.checked = selected > 0 && selected === bulkCheckboxes.length;
        bulkSelectAll.indeterminate = selected > 0 && selected < bulkCheckboxes.length;
      }
    };

    addButton?.addEventListener('click', () => {
      const html = template.innerHTML.replaceAll('__INDEX__', String(nextIndex++));
      criteria.insertAdjacentHTML('beforeend', html);
      updateRemoveButtons();
    });

    pageTypeSelect?.addEventListener('change', () => {
      updatePathOptions(pageTypeSelect.value);
    });

    criteria?.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target : null;
      const button = target?.closest('[data-remove-criterion]');
      if (!button) return;
      const rows = criteria.querySelectorAll('[data-criterion-row]');
      if (rows.length <= 1) return;
      button.closest('[data-criterion-row]')?.remove();
      updateRemoveButtons();
    });

    bulkSelectAll?.addEventListener('change', () => {
      bulkCheckboxes.forEach((checkbox) => { checkbox.checked = bulkSelectAll.checked; });
      updateBulkSelection();
    });

    bulkCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener('change', updateBulkSelection);
    });

    bulkForm?.addEventListener('submit', (event) => {
      const scope = bulkScope?.value || 'selected';
      const action = bulkAction?.value || 'publish';
      const selected = selectedBulkCount();
      if (scope === 'selected' && selected === 0) {
        event.preventDefault();
        alert('Select at least one page.');
        return;
      }
      const actionLabel = action === 'delete' ? 'move to trash' : action;
      const subject = scope === 'all' ? '{{ count }} matching pages' : selected + ' selected page' + (selected === 1 ? '' : 's');
      if (!confirm('Bulk ' + actionLabel + ' ' + subject + '?')) {
        event.preventDefault();
      }
    });

    updateRemoveButtons();
    updateBulkSelection();
  })();
</script>
