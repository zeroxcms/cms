<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Pages</h2>
      <p class="text-sm text-gray-500 mt-1">{{ pageCountLabel | escape }}</p>
    </div>
    <a href="/admin/pages/new"
       class="inline-flex w-full items-center justify-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
      </svg>
      New Page
    </a>
  </div>

  {% if hasFlash %}
    <div id="flash" class="mb-4 rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-700 flex items-center gap-2">
      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      {{ flash | escape }}
    </div>
  {% endif %}

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[760px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Page</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Weight</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasPages %}
          {% for page in pages %}
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                <a href="{{ page.editHref | escape }}" class="flex flex-col gap-1">
                  <div class="font-medium text-gray-900">{{ page.name | escape }}</div>
                  <div class="text-xs text-gray-500 font-mono">/{{ page.slug | escape }}</div>
                </a>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">{{ page.pageType | escape }}</td>
              <td class="px-6 py-4">
                <form method="POST" action="{{ page.weightAction | escape }}" class="flex min-w-0 flex-wrap items-center gap-2">
                  <input type="hidden" name="return_to" value="{{ returnPath | escape }}">
                  <label for="weight_{{ page.id }}" class="sr-only">Weight for {{ page.name | escape }}</label>
                  <input id="weight_{{ page.id }}" type="number" name="weight" value="{{ page.weight }}" min="0" max="1000"
                         class="min-w-0 w-20 max-w-full px-2 py-1 border border-gray-300 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                  <button type="submit"
                          class="shrink-0 px-2.5 py-1 rounded-lg border border-gray-300 bg-white text-xs font-semibold text-gray-700 hover:bg-gray-50">
                    Save
                  </button>
                  {% if page.hasLiveWeightDrift %}
                    <span title="Live weight is {{ page.liveWeight }}; publish to sync"
                          class="inline-flex items-center text-amber-600">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                      </svg>
                    </span>
                  {% endif %}
                </form>
              </td>
              <td class="px-6 py-4">
                {% if page.isPublished %}
                  <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Live
                  </span>
                {% else %}
                  <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                    <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>Draft
                  </span>
                {% endif %}
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap items-center gap-2">
                  <a href="{{ page.editHref | escape }}"
                     title="Edit"
                     aria-label="Edit {{ page.name | escape }}"
                     class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 hover:bg-indigo-50 hover:text-indigo-800 transition-colors">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19.5 7.125L16.875 4.5M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/>
                    </svg>
                    <span class="sr-only">Edit</span>
                  </a>
                  {% if page.isPublished %}
                    <form method="POST" action="{{ page.unpublishAction | escape }}" class="inline shrink-0"
                          onsubmit="return confirm('Unpublish this page?')">
                      <button type="submit"
                              title="Unpublish"
                              aria-label="Unpublish {{ page.name | escape }}"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-yellow-600 hover:bg-yellow-50 hover:text-yellow-800 transition-colors">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c1.927 0 3.733-.52 5.285-1.428"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.5a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.243 4.243L9.88 9.88"/>
                        </svg>
                        <span class="sr-only">Unpublish</span>
                      </button>
                    </form>
                  {% else %}
                    <form method="POST" action="{{ page.publishAction | escape }}" class="inline shrink-0">
                      <button type="submit"
                              title="Publish"
                              aria-label="Publish {{ page.name | escape }}"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-green-600 hover:bg-green-50 hover:text-green-800 transition-colors">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M12 16.5V9.75m0 0l-3 3m3-3l3 3"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6.75 19.5a4.5 4.5 0 01-.858-8.917 5.25 5.25 0 0110.233-2.33 3.75 3.75 0 013.125 6.816"/>
                        </svg>
                        <span class="sr-only">Publish</span>
                      </button>
                    </form>
                  {% endif %}
                  <form method="POST" action="{{ page.deleteAction | escape }}" class="inline shrink-0"
                        onsubmit="return confirm('Move this page to trash?')">
                    <button type="submit"
                            title="Trash"
                            aria-label="Move {{ page.name | escape }} to trash"
                            class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-red-500 hover:bg-red-50 hover:text-red-700 transition-colors">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166M19.228 5.79L18.16 19.673A2.25 2.25 0 0115.916 21H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .563c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
                      </svg>
                      <span class="sr-only">Trash</span>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M9 13h6m-3-3v6m5 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              No pages yet. <a href="/admin/pages/new" class="text-indigo-600 hover:underline">Create your first page</a>.
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>

<script>
  const flash = document.getElementById('flash');
  if (flash) setTimeout(() => flash.remove(), 4000);
</script>
