<div class="min-w-0 max-w-full overflow-x-hidden px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 xl:flex-row xl:items-center xl:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">{{ pageTitle | escape }}</h2>
      <p class="text-sm text-gray-500 mt-1">{{ pageCountLabel | escape }}</p>
      {% if hasStatusFilters %}
        <div class="mt-3 inline-flex h-9 overflow-hidden rounded-lg border border-gray-300 bg-white text-sm font-semibold shadow-sm">
          {% for filter in statusFilters %}
            <a href="{{ filter.href | escape }}"
               {% if filter.isActive %}aria-current="page"{% endif %}
               class="inline-flex items-center border-r border-gray-300 px-3 last:border-r-0 {% if filter.isActive %}bg-indigo-600 text-white{% else %}text-gray-700 hover:bg-gray-50{% endif %}">
              {{ filter.label | escape }}
            </a>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="flex w-full flex-row gap-2 xl:max-w-3xl xl:justify-end">
      <form method="GET" action="{{ searchAction | escape }}" class="flex min-w-0 flex-1 gap-2">
        <input type="hidden" name="operator" value="AND">
        <input type="hidden" name="pagesize" value="20">
        <input type="hidden" name="sort" value="updated_at">
        <input type="hidden" name="order" value="DESC">
        <input type="hidden" name="path1" value="">
        <label for="dashboard_search" class="sr-only">Search pages</label>
        <input id="dashboard_search" type="search" name="search1" value="{{ searchValue | escape }}" placeholder="{{ searchPlaceholder | escape }}"
               class="h-10 min-w-0 flex-1 rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <button type="submit"
                title="Search"
                aria-label="Search pages"
                class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#search"></use></svg>
        </button>
      </form>
      {% if hasExportHref %}
        <a href="{{ exportHref | escape }}"
           title="Export CSV"
           aria-label="Export CSV"
           class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#download"></use></svg>
          <span class="hidden lg:inline">Export CSV</span>
        </a>
      {% endif %}
      {% if hasImportHref %}
        <a href="{{ importHref | escape }}"
           title="Import CSV"
           aria-label="Import CSV"
           class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#upload"></use></svg>
          <span class="hidden lg:inline">Import CSV</span>
        </a>
      {% endif %}
      <a href="/admin/pages/new"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#plus"></use></svg>
        <span class="hidden lg:inline">New Page</span>
      </a>
    </div>
  </div>

  {% if hasFlash %}
    <div id="flash" class="mb-4 rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-700 flex items-center gap-2">
      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><use href="{{ iconHrefPrefix | escape }}#check-circle"></use></svg>
      {{ flash | escape }}
    </div>
  {% endif %}

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="relative w-full text-left{% if hasPages %} min-w-[760px]{% endif %}"{% if privacyTable %} data-privacy-table{% endif %}>
      {% if hasPages %}
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Page</th>
          {% if showPageTypeColumn %}
            <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
          {% endif %}
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Weight</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      {% endif %}
      <tbody class="divide-y divide-gray-100">
        {% if hasPages %}
          {% for page in pages %}
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4">
                {% if page.isDraftMissing %}
                  <div class="flex flex-col gap-1">
                    <div class="font-medium text-gray-900"{% if privacyTable %} data-private-field="name"{% endif %}>{{ page.name | escape }}</div>
                    <div class="text-xs text-gray-500 font-mono">/{{ page.slug | escape }}</div>
                  </div>
                {% else %}
                  <a href="{{ page.editHref | escape }}" class="flex flex-col gap-1">
                    <div class="font-medium text-gray-900"{% if privacyTable %} data-private-field="name"{% endif %}>{{ page.name | escape }}</div>
                    <div class="text-xs text-gray-500 font-mono">/{{ page.slug | escape }}</div>
                  </a>
                {% endif %}
              </td>
              {% if showPageTypeColumn %}
                <td class="px-6 py-4 text-sm text-gray-500">
                  {% if page.pageTypeHref %}
                    <a href="{{ page.pageTypeHref | escape }}" class="font-medium text-indigo-600 hover:text-indigo-800 hover:underline">
                      {{ page.pageType | escape }}
                    </a>
                  {% else %}
                    {{ page.pageType | escape }}
                  {% endif %}
                </td>
              {% endif %}
              <td class="px-6 py-4">
                {% if page.isDraftMissing %}
                  <span class="text-sm text-gray-700">{{ page.weight }}</span>
                {% else %}
                  <form method="POST" action="{{ page.weightAction | escape }}" class="flex min-w-0 flex-wrap items-center gap-2">
                    <input type="hidden" name="return_to" value="{{ returnPath | escape }}">
                    <label for="weight_{{ page.id }}" class="sr-only">Weight for {{ page.name | escape }}</label>
                    <input id="weight_{{ page.id }}" type="number" name="weight" value="{{ page.weight }}" min="0" max="1000"
                           class="min-w-0 w-20 max-w-full px-2 py-1 border border-gray-300 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    <button type="submit"
                            class="shrink-0 px-2.5 py-1 rounded-lg border border-gray-300 bg-white text-xs font-semibold text-gray-700 hover:bg-gray-50">
                      Save
                    </button>
                    {% if page.hasLiveWeightDrift %}
                      <span title="Live weight is {{ page.liveWeight }}; publish to sync"
                            class="inline-flex items-center text-amber-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#warning"></use></svg>
                      </span>
                    {% endif %}
                  </form>
                {% endif %}
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  {% if page.isPublished %}
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Live
                    </span>
                    {% if page.isDraftMissing %}
                      <span title="Published page is missing from drafts"
                            class="inline-flex items-center text-amber-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#warning"></use></svg>
                        <span class="sr-only">Published page is missing from drafts</span>
                      </span>
                    {% endif %}
                    {% if page.hasLiveLectDrift %}
                      <span title="Live content differs from draft; publish to sync"
                            class="inline-flex items-center text-amber-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#warning"></use></svg>
                        <span class="sr-only">Live content differs from draft</span>
                      </span>
                    {% endif %}
                  {% else %}
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>Draft
                    </span>
                  {% endif %}
                </div>
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap items-center gap-2">
                  {% if page.isDraftMissing %}
                    <form method="POST" action="{{ page.pullAction | escape }}" class="inline shrink-0">
                      <button type="submit"
                              title="Ingest submission"
                              aria-label="Ingest submission {{ page.name | escape }}"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 hover:bg-indigo-50 hover:text-indigo-800 transition-colors">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#download"></use></svg>
                        <span class="sr-only">Ingest submission</span>
                      </button>
                    </form>
                  {% else %}
                    <a href="{{ page.readHref | escape }}"
                       title="View"
                       aria-label="View {{ page.name | escape }}"
                       class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#eye"></use></svg>
                      <span class="sr-only">View</span>
                    </a>
                    <a href="{{ page.editHref | escape }}"
                       title="Edit"
                       aria-label="Edit {{ page.name | escape }}"
                       class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 hover:bg-indigo-50 hover:text-indigo-800 transition-colors">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#pencil-square"></use></svg>
                      <span class="sr-only">Edit</span>
                    </a>
                    {% if page.isPublished %}
                      <form method="POST" action="{{ page.unpublishAction | escape }}" class="inline shrink-0"
                            data-confirm="Unpublish this page?">
                        <button type="submit"
                                title="Unpublish"
                                aria-label="Unpublish {{ page.name | escape }}"
                                class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-yellow-600 hover:bg-yellow-50 hover:text-yellow-800 transition-colors">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#eye-off"></use></svg>
                          <span class="sr-only">Unpublish</span>
                        </button>
                      </form>
                    {% else %}
                      <form method="POST" action="{{ page.publishAction | escape }}" class="inline shrink-0">
                        <button type="submit"
                                title="Publish"
                                aria-label="Publish {{ page.name | escape }}"
                                class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-green-600 hover:bg-green-50 hover:text-green-800 transition-colors">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#cloud-upload"></use></svg>
                          <span class="sr-only">Publish</span>
                        </button>
                      </form>
                    {% endif %}
                    <form method="POST" action="{{ page.deleteAction | escape }}" class="inline shrink-0"
                          data-confirm="Move this page to trash?">
                      <button type="submit"
                              title="Trash"
                              aria-label="Move {{ page.name | escape }} to trash"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-red-500 hover:bg-red-50 hover:text-red-700 transition-colors">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#trash-can"></use></svg>
                        <span class="sr-only">Trash</span>
                      </button>
                    </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="{{ emptyColspan }}" class="px-6 py-12 text-center text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix | escape }}#document-plus"></use></svg>
              No pages yet. <a href="/admin/pages/new" class="text-indigo-600 hover:underline">Create your first page</a>.
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>

  {% if showPagination %}
    <div class="mt-4 flex flex-col gap-3 text-sm sm:flex-row sm:items-center sm:justify-between">
      <div class="text-gray-500">Page {{ currentPage }} of {{ totalPages }}</div>
      <div class="flex flex-wrap gap-2">
        {% if hasFirstPage %}
          <a href="{{ firstHref | escape }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">First</a>
        {% endif %}
        {% if hasPreviousPage %}
          <a href="{{ previousHref | escape }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">Previous</a>
        {% endif %}
        {% if hasNextPage %}
          <a href="{{ nextHref | escape }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">Next</a>
        {% endif %}
        {% if hasLastPage %}
          <a href="{{ lastHref | escape }}" class="inline-flex h-9 items-center rounded-lg border border-gray-300 bg-white px-3 font-semibold text-gray-700 hover:bg-gray-50">Last</a>
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>

<script nonce="{{ nonce }}">
  const flash = document.getElementById('flash');
  if (flash) setTimeout(() => flash.remove(), 4000);
</script>
