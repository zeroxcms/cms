<div class="min-w-0 max-w-full overflow-x-hidden px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 xl:flex-row xl:items-center xl:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">{{ "nav.pages" | t }}{% if pageTypeFilter != '' %}: {{ pageTypeFilter }}{% endif %}</h2>
      <p class="text-sm text-gray-500 mt-1">
        {% if paginatedCount %}{{ "pages.count.showing" | t }} {{ paginationStart }}-{{ paginationEnd }} {{ "pages.count.of" | t }} {% endif %}{{ pageCount }}
        {% if statusFilter == 'live' %}{% if singularCount %}{{ "pages.count.live_page" | t }}{% else %}{{ "pages.count.live_pages" | t }}{% endif %}
        {% elsif statusFilter == 'draft' %}{% if singularCount %}{{ "pages.count.draft_page" | t }}{% else %}{{ "pages.count.draft_pages" | t }}{% endif %}
        {% else %}{% if singularCount %}{{ "pages.count.page" | t }}{% else %}{{ "pages.count.pages" | t }}{% endif %} {{ "pages.count.in_draft" | t }}{% endif %}
      </p>
      {% if hasStatusFilters or hasPageTypeChoices %}
        <div class="mt-3 flex flex-wrap items-center gap-2">
          {% if hasStatusFilters %}
            <div class="inline-flex h-9 overflow-hidden rounded-lg border border-gray-300 bg-white text-sm font-semibold shadow-sm">
              {% for filter in statusFilters %}
                <a href="{{ filter.href }}"
                   {% if filter.isActive %}aria-current="page"{% endif %}
                   class="inline-flex items-center border-r border-gray-300 px-3 last:border-r-0 {% if filter.isActive %}bg-indigo-600 text-white{% else %}text-gray-700 hover:bg-gray-50{% endif %}">
                  {% if filter.translationKey %}{{ filter.translationKey | t }}{% else %}{{ filter.label }}{% endif %}
                </a>
              {% endfor %}
            </div>
          {% endif %}
          {% if hasPageTypeChoices %}
            <label for="page_type_filter" class="sr-only">{{ "view_strings.sections_dashboard.filter_by_type" | t }}</label>
            <select id="page_type_filter"
                    class="h-9 rounded-lg border border-gray-300 bg-white px-3 text-sm font-semibold text-gray-700 shadow-sm focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <option value="{{ allTypesHref }}"{% if allTypesSelected %} selected{% endif %}>{{ "view_strings.sections_dashboard.all_types" | t }}</option>
              {% for opt in pageTypeOptions %}
                <option value="{{ opt.href }}"{% if opt.isSelected %} selected{% endif %}>{{ opt.slug }}</option>
              {% endfor %}
            </select>
          {% endif %}
        </div>
      {% endif %}
    </div>
    <div class="flex w-full flex-row gap-2 xl:max-w-3xl xl:justify-end">
      <form method="GET" action="{{ searchAction }}" class="flex min-w-0 flex-1 gap-2">
        <input type="hidden" name="operator" value="AND">
        <input type="hidden" name="pagesize" value="20">
        <input type="hidden" name="sort" value="updated_at">
        <input type="hidden" name="order" value="DESC">
        <input type="hidden" name="path1" value="">
        <label for="dashboard_search" class="sr-only">{{ "view_strings.sections_dashboard.search_pages" | t }}</label>
        <input id="dashboard_search" type="search" name="search1" value="{{ searchValue }}" placeholder="{% if pageTypeFilter != '' %}{{ "view_strings.sections_dashboard.search" | t }} {{ pageTypeFilter }} {{ "nav.pages" | t }}{% else %}{{ "view_strings.sections_dashboard.search_pages" | t }}{% endif %}"
               class="h-10 min-w-0 flex-1 rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
        <button type="submit"
                title="{{ "view_strings.sections_dashboard.search" | t }}"
                aria-label="{{ "view_strings.sections_dashboard.search_pages" | t }}"
                class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#search"></use></svg>
        </button>
      </form>
      {% if hasExportHref %}
        <a href="{{ exportHref }}"
           title="{{ "view_strings.sections_dashboard.export_csv" | t }}"
           aria-label="{{ "view_strings.sections_dashboard.export_csv" | t }}"
           class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#download"></use></svg>
          <span class="hidden lg:inline">{{ "view_strings.sections_dashboard.export_csv" | t }}</span>
        </a>
      {% endif %}
      {% if hasImportHref %}
        <a href="{{ importHref }}"
           title="{{ "view_strings.sections_dashboard.import_csv" | t }}"
           aria-label="{{ "view_strings.sections_dashboard.import_csv" | t }}"
           class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#upload"></use></svg>
          <span class="hidden lg:inline">{{ "view_strings.sections_dashboard.import_csv" | t }}</span>
        </a>
      {% endif %}
      <a href="/admin/pages/new"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#plus"></use></svg>
        <span class="hidden lg:inline">{{ "view_strings.sections_dashboard.new_page" | t }}</span>
      </a>
    </div>
  </div>

  {% if hasFlash %}
    <div id="flash" class="mb-4 rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-700 flex items-center gap-2">
      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><use href="{{ iconHrefPrefix }}#check-circle"></use></svg>
      {{ flash | t }}
    </div>
  {% endif %}

  {% if hasSelectablePages %}
    <form id="dashboard-bulk-form" method="POST" action="{{ bulkAction }}"
          class="mb-3 hidden rounded-xl border border-gray-200 bg-white p-3 shadow-sm"
          data-dashboard-bulk-form
          data-dashboard-bulk-confirm-template="{{ "view_strings.sections_dashboard.bulk_confirm_template" | t }}"
          data-dashboard-bulk-all-subject="{{ "view_strings.sections_dashboard.bulk_all_matching_pages_subject" | t }}"
          data-dashboard-bulk-page-singular="{{ "view_strings.sections_dashboard.bulk_selected_page" | t }}"
          data-dashboard-bulk-page-plural="{{ "view_strings.sections_dashboard.bulk_selected_pages" | t }}"
          aria-hidden="true">
      <input type="hidden" name="return_to" value="{{ returnPath }}">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div class="grid gap-3 sm:grid-cols-2">
          <label class="block sm:w-56">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_advanced_search.bulk_action" | t }}</span>
            <select name="bulk_action" data-dashboard-bulk-action
                    class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <option value="publish">{{ "view_strings.sections_advanced_search.publish" | t }}</option>
              <option value="unpublish">{{ "view_strings.sections_advanced_search.unpublish" | t }}</option>
              <option value="delete">{{ "view_strings.sections_advanced_search.move_to_trash" | t }}</option>
            </select>
          </label>
          <label class="block sm:w-56">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_advanced_search.apply_to" | t }}</span>
            <select name="scope" data-dashboard-bulk-scope
                    class="h-10 w-full rounded-lg border border-gray-300 bg-white px-3 text-sm text-gray-700 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500">
              <option value="selected">{{ "view_strings.sections_advanced_search.selected_items" | t }}</option>
              <option value="all">{{ "view_strings.sections_dashboard.all_matching_pages" | t }}</option>
            </select>
          </label>
        </div>
        <div class="flex items-center gap-3">
          <div class="text-sm text-gray-500"><span data-dashboard-selected-count>0</span> {{ "view_strings.sections_advanced_search.selected" | t }}</div>
          <button type="submit"
                  title="{{ "view_strings.sections_advanced_search.apply_bulk_action" | t }}"
                  aria-label="{{ "view_strings.sections_advanced_search.apply_bulk_action" | t }}"
                  class="inline-flex h-10 items-center justify-center rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-indigo-700">
            {{ "view_strings.sections_advanced_search.apply" | t }}
          </button>
        </div>
      </div>
    </form>
  {% endif %}

  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="overflow-x-auto">
      <table class="relative w-full text-left{% if hasPages %} min-w-[760px]{% endif %}"{% if privacyTable %} data-privacy-table{% endif %}>
      {% if hasPages %}
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="w-12 px-6 py-3">
            {% if hasSelectablePages %}
              <input type="checkbox" data-dashboard-bulk-select-all
                     title="{{ "view_strings.sections_advanced_search.select_all_visible_pages" | t }}"
                     aria-label="{{ "view_strings.sections_advanced_search.select_all_visible_pages" | t }}"
                     class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
            {% endif %}
          </th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_dashboard.page" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_dashboard.weight" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_dashboard.actions" | t }}</th>
        </tr>
      </thead>
      {% endif %}
      <tbody class="divide-y divide-gray-100">
        {% if hasPages %}
          {% for page in pages %}
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-6 py-4 align-top">
                {% if page.isSelectable %}
                  <input type="checkbox" name="page_ids" value="{{ page.id }}" form="dashboard-bulk-form"
                         data-dashboard-bulk-checkbox title="Select {{ page.name }}" aria-label="Select {{ page.name }}"
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                {% endif %}
              </td>
              <td class="px-6 py-4">
                {% if page.isDraftMissing %}
                  <div class="flex flex-col gap-1">
                    <div class="font-medium text-gray-900"{% if privacyTable %} data-private-field="name"{% endif %}>{{ page.name }}</div>
                    <div class="text-xs text-gray-500 font-mono">/{{ page.slug }}</div>
                  </div>
                {% else %}
                  <a href="{{ page.editHref }}" class="flex flex-col gap-1">
                    <div class="font-medium text-gray-900"{% if privacyTable %} data-private-field="name"{% endif %}>{{ page.name }}</div>
                    <div class="text-xs text-gray-500 font-mono">/{{ page.slug }}</div>
                  </a>
                {% endif %}
                <div class="mt-1.5 flex flex-wrap items-center gap-2">
                  {% if showPageTypeColumn and page.hasPageType %}
                    {% if page.pageTypeHref %}
                      <a href="{{ page.pageTypeHref }}" class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-700 transition-colors hover:bg-indigo-200 hover:text-gray-900">{{ page.pageType }}</a>
                    {% else %}
                      <span class="inline-flex items-center rounded-full bg-indigo-100 px-2.5 py-0.5 text-xs font-medium text-indigo-700">{{ page.pageType }}</span>
                    {% endif %}
                  {% endif %}
                  {% if page.isPublished %}
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                      <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>{{ "view_strings.sections_dashboard.live" | t }}
                    </span>
                    {% if page.isDraftMissing %}
                      <span title="{{ "view_strings.sections_dashboard.published_page_is_missing_from_drafts" | t }}"
                            class="inline-flex items-center text-amber-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#warning"></use></svg>
                        <span class="sr-only">{{ "view_strings.sections_dashboard.published_page_is_missing_from_drafts" | t }}</span>
                      </span>
                    {% endif %}
                    {% if page.hasLiveLectDrift %}
                      <span title="{{ "view_strings.sections_dashboard.live_content_differs_from_draft_publish_to_sync" | t }}"
                            class="inline-flex items-center text-amber-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#warning"></use></svg>
                        <span class="sr-only">{{ "view_strings.sections_dashboard.live_content_differs_from_draft" | t }}</span>
                      </span>
                    {% endif %}
                  {% else %}
                    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                      <span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>{{ "view_strings.sections_dashboard.draft" | t }}
                    </span>
                  {% endif %}
                </div>
              </td>
              <td class="px-6 py-4">
                {% if page.isDraftMissing %}
                  <span class="text-sm text-gray-700">{{ page.weight }}</span>
                {% else %}
                  <form method="POST" action="{{ page.weightAction }}" class="flex min-w-0 flex-nowrap items-center gap-2">
                    <input type="hidden" name="return_to" value="{{ returnPath }}">
                    <label for="weight_{{ page.id }}" class="sr-only">Weight for {{ page.name }}</label>
                    <input id="weight_{{ page.id }}" type="number" name="weight" value="{{ page.weight }}" min="0" max="1000"
                           class="w-20 shrink-0 px-2 py-1 border border-gray-300 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    <button type="submit"
                            title="{{ "view_strings.sections_dashboard.save" | t }}"
                            aria-label="{{ "view_strings.sections_dashboard.save" | t }}"
                            class="inline-flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-lg text-indigo-600 transition-colors hover:bg-indigo-50 hover:text-indigo-800">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#save"></use></svg>
                    </button>
                    {% if page.hasLiveWeightDrift %}
                      <span title="Live weight is {{ page.liveWeight }}; publish to sync"
                            class="inline-flex items-center text-amber-600">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#warning"></use></svg>
                      </span>
                    {% endif %}
                  </form>
                {% endif %}
              </td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap items-center gap-2">
                  {% if page.isDraftMissing %}
                    <form method="POST" action="{{ page.pullAction }}" class="inline shrink-0">
                      <button type="submit"
                              title="{{ "view_strings.sections_dashboard.ingest_submission" | t }}"
                              aria-label="Ingest submission {{ page.name }}"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 hover:bg-indigo-50 hover:text-indigo-800 transition-colors">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#download"></use></svg>
                        <span class="sr-only">{{ "view_strings.sections_dashboard.ingest_submission" | t }}</span>
                      </button>
                    </form>
                  {% else %}
                    <a href="{{ page.readHref }}"
                       title="{{ "view_strings.sections_dashboard.view" | t }}"
                       aria-label="View {{ page.name }}"
                       class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-gray-500 hover:bg-gray-100 hover:text-gray-700 transition-colors">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#eye"></use></svg>
                      <span class="sr-only">{{ "view_strings.sections_dashboard.view" | t }}</span>
                    </a>
                    <a href="{{ page.editHref }}"
                       title="{{ "view_strings.sections_dashboard.edit" | t }}"
                       aria-label="Edit {{ page.name }}"
                       class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 hover:bg-indigo-50 hover:text-indigo-800 transition-colors">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#pencil-square"></use></svg>
                      <span class="sr-only">{{ "view_strings.sections_dashboard.edit" | t }}</span>
                    </a>
                    {% if page.isPublished %}
                      <form method="POST" action="{{ page.unpublishAction }}" class="inline shrink-0"
                            data-confirm="{{ "view_strings.sections_dashboard.unpublish_this_page" | t }}">
                        <button type="submit"
                                title="{{ "view_strings.sections_dashboard.unpublish" | t }}"
                                aria-label="Unpublish {{ page.name }}"
                                class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-yellow-600 hover:bg-yellow-50 hover:text-yellow-800 transition-colors">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#eye-off"></use></svg>
                          <span class="sr-only">{{ "view_strings.sections_dashboard.unpublish" | t }}</span>
                        </button>
                      </form>
                    {% else %}
                      <form method="POST" action="{{ page.publishAction }}" class="inline shrink-0">
                        <button type="submit"
                                title="{{ "view_strings.sections_dashboard.publish" | t }}"
                                aria-label="Publish {{ page.name }}"
                                class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-green-600 hover:bg-green-50 hover:text-green-800 transition-colors">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#cloud-upload"></use></svg>
                          <span class="sr-only">{{ "view_strings.sections_dashboard.publish" | t }}</span>
                        </button>
                      </form>
                    {% endif %}
                    <form method="POST" action="{{ page.deleteAction }}" class="inline shrink-0"
                          data-confirm="{{ "view_strings.sections_dashboard.move_this_page_to_trash" | t }}">
                      <button type="submit"
                              title="{{ "view_strings.sections_dashboard.trash" | t }}"
                              aria-label="Move {{ page.name }} to trash"
                              class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-red-500 hover:bg-red-50 hover:text-red-700 transition-colors">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#trash-can"></use></svg>
                        <span class="sr-only">{{ "view_strings.sections_dashboard.trash" | t }}</span>
                      </button>
                    </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="{{ emptyColspan }}" class="px-6 py-12 text-center text-gray-400">
              <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#document-plus"></use></svg>
              {{ "view_strings.sections_dashboard.no_pages_yet" | t }} <a href="/admin/pages/new" class="text-indigo-600 hover:underline">{{ "view_strings.sections_dashboard.create_your_first_page" | t }}</a>.
            </td>
          </tr>
        {% endif %}
      </tbody>
      </table>
    </div>
  </div>

  {% if showPagination %}
    <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-gray-100 pt-4">
      <p class="text-sm text-gray-500">
        {{ "pages.count.showing" | t }} {{ paginationStart }}-{{ paginationEnd }} {{ "pages.count.of" | t }} {{ pageCount }}
      </p>
      <div class="flex items-center gap-2">
        {% if hasPreviousPage %}
          <a href="{{ previousHref }}"
             class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#arrow-left"></use></svg>
            {{ "common.previous" | t }}
          </a>
        {% else %}
          <span class="inline-flex h-9 cursor-not-allowed items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-50 px-3 text-xs font-semibold text-gray-400">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#arrow-left"></use></svg>
            {{ "common.previous" | t }}
          </span>
        {% endif %}
        <span class="text-xs font-medium text-gray-500">{{ "profile.pagination_page" | t }} {{ currentPage }} {{ "profile.pagination_of" | t }} {{ totalPages }}</span>
        {% if hasNextPage %}
          <a href="{{ nextHref }}"
             class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">
            {{ "common.next" | t }}
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#chevron-right"></use></svg>
          </a>
        {% else %}
          <span class="inline-flex h-9 cursor-not-allowed items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-50 px-3 text-xs font-semibold text-gray-400">
            {{ "common.next" | t }}
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#chevron-right"></use></svg>
          </span>
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>

<script nonce="{{ nonce }}">
  const flash = document.getElementById('flash');
  if (flash) setTimeout(() => flash.remove(), 4000);

  const typeFilter = document.getElementById('page_type_filter');
  if (typeFilter) typeFilter.addEventListener('change', () => {
    if (typeFilter.value) window.location.href = typeFilter.value;
  });

  (() => {
    const bulkForm = document.querySelector('[data-dashboard-bulk-form]');
    if (!bulkForm) return;
    const checkboxes = Array.from(document.querySelectorAll('[data-dashboard-bulk-checkbox]'));
    const selectAll = document.querySelector('[data-dashboard-bulk-select-all]');
    const selectedCount = document.querySelector('[data-dashboard-selected-count]');
    const action = document.querySelector('[data-dashboard-bulk-action]');
    const scope = document.querySelector('[data-dashboard-bulk-scope]');

    const countSelected = () => checkboxes.filter((checkbox) => checkbox.checked).length;
    const syncSelection = () => {
      const selected = countSelected();
      if (selectedCount) selectedCount.textContent = String(selected);
      bulkForm.classList.toggle('hidden', selected === 0);
      bulkForm.setAttribute('aria-hidden', selected === 0 ? 'true' : 'false');
      if (selectAll) {
        selectAll.checked = selected > 0 && selected === checkboxes.length;
        selectAll.indeterminate = selected > 0 && selected < checkboxes.length;
      }
    };

    selectAll?.addEventListener('change', () => {
      checkboxes.forEach((checkbox) => { checkbox.checked = selectAll.checked; });
      syncSelection();
    });
    checkboxes.forEach((checkbox) => checkbox.addEventListener('change', syncSelection));
    bulkForm.addEventListener('submit', (event) => {
      const selected = countSelected();
      if (selected === 0) {
        event.preventDefault();
        return;
      }
      const actionLabel = action?.selectedOptions?.[0]?.textContent?.trim() || action?.value || 'publish';
      const subject = scope?.value === 'all'
        ? bulkForm.dataset.dashboardBulkAllSubject
        : selected + ' ' + (selected === 1
          ? bulkForm.dataset.dashboardBulkPageSingular
          : bulkForm.dataset.dashboardBulkPagePlural);
      const message = (bulkForm.dataset.dashboardBulkConfirmTemplate || 'Confirm {action} for {subject}?')
        .replace('{action}', actionLabel)
        .replace('{subject}', subject || '');
      if (!confirm(message)) {
        event.preventDefault();
      }
    });
    syncSelection();
  })();
</script>
