<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <h2 class="text-2xl font-bold text-gray-900">Tags</h2>
    <div class="grid grid-cols-2 gap-2 sm:flex sm:items-center">
      <a href="/admin/taxonomies" class="px-4 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300">Taxonomies</a>
      <a href="/admin/tags/new" class="px-4 py-2 text-center bg-indigo-600 text-white text-sm font-semibold rounded-lg">New Tag</a>
    </div>
  </div>
  <form method="GET" class="mb-4 flex min-w-0 flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center">
    <label for="filter_taxonomy" class="sr-only">Filter by taxonomy</label>
    <select id="filter_taxonomy" name="filter_taxonomy" class="min-w-0 w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:w-auto">
      <option value="0">All taxonomies</option>
      {% for option in filterOptions %}
        <option value="{{ option.id }}" {% if option.selected %}selected{% endif %}>{{ option.name | escape }}</option>
      {% endfor %}
    </select>
    <button type="submit" class="w-full shrink-0 px-3 py-2 border border-gray-300 rounded-lg text-sm font-semibold sm:w-auto">Filter</button>
  </form>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Slug</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Type</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasTags %}
          {% for tag in tags %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">{{ tag.name | escape }}</td>
              <td class="px-6 py-3 text-sm font-mono text-gray-500">{{ tag.slug | escape }}</td>
              <td class="px-6 py-3 text-sm text-gray-500">{{ tag.taxonomyName | escape }}</td>
              <td class="px-6 py-3 text-right">
                <a href="{{ tag.editHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">Edit</a>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="4" class="px-6 py-10 text-center text-gray-400">No tags yet.</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
