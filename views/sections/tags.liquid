<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <h2 class="text-2xl font-bold text-gray-900">{{ "view_strings.sections_tags.tags" | t }}</h2>
    <div class="flex flex-row gap-2 sm:items-center">
      <a href="/admin/taxonomies"
         title="{{ "view_strings.sections_tags.taxonomies" | t }}"
         aria-label="{{ "view_strings.sections_tags.taxonomies" | t }}"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#tag"></use></svg>
        <span class="hidden lg:inline">{{ "view_strings.sections_tags.taxonomies" | t }}</span>
      </a>
      <a href="/admin/tags/new"
         title="{{ "view_strings.sections_tags.new_tag" | t }}"
         aria-label="{{ "view_strings.sections_tags.new_tag" | t }}"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#plus"></use></svg>
        <span class="hidden lg:inline">{{ "view_strings.sections_tags.new_tag" | t }}</span>
      </a>
    </div>
  </div>
  <form method="GET" class="mb-4 flex min-w-0 flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center">
    <label for="filter_taxonomy" class="sr-only">{{ "view_strings.sections_tags.filter_by_taxonomy" | t }}</label>
    <select id="filter_taxonomy" name="filter_taxonomy" class="min-w-0 w-full px-3 py-2 border border-gray-300 rounded-lg text-sm sm:w-auto">
      <option value="">{{ "view_strings.sections_tags.all_taxonomies" | t }}</option>
      {% for option in filterOptions %}
        <option value="{{ option.id }}" {% if option.selected %}selected{% endif %}>{{ option.name }}</option>
      {% endfor %}
    </select>
    <button type="submit"
            title="{{ "view_strings.sections_tags.filter" | t }}"
            aria-label="{{ "view_strings.sections_tags.filter_tags" | t }}"
            class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-gray-300 bg-white text-gray-700 hover:bg-gray-50">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#list-filter"></use></svg>
    </button>
  </form>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[620px] text-left" data-reorder="/admin/tags/batch-weight" data-reorder-key="updates" data-reorder-handle-only>
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="w-10 px-3 py-3"></th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_tags.name" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_tags.weight" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_tags.type" | t }}</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasTags %}
          {% for tag in tags %}
            <tr class="hover:bg-gray-50" data-id="{{ tag.id }}">
              <td class="px-3 py-3 text-gray-300">
                <span data-reorder-handle title="{{ "view_strings.sections_tags.drag_to_reorder" | t }}" aria-label="{{ "view_strings.sections_tags.drag_to_reorder" | t }}" class="inline-flex h-8 w-8 cursor-grab items-center justify-center rounded-md hover:bg-gray-100 hover:text-gray-500">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#menu"></use></svg>
                </span>
              </td>
              <td class="px-6 py-3 text-sm font-medium text-gray-900">
                <a href="{{ tag.editHref }}" class="block text-sm font-medium text-indigo-600 hover:text-indigo-800">{{ tag.name }}</a>
                <div class="text-xs font-mono text-gray-500">{{ tag.slug }}</div>
              </td>
              <td class="px-6 py-3 text-sm text-gray-500">{{ tag.weight }}</td>
              <td class="px-6 py-3 text-sm text-gray-500">{{ tag.taxonomyName }}</td>
              <td class="px-6 py-3 text-right">
                <a href="{{ tag.editHref }}"
                   title="{{ "view_strings.sections_tags.edit" | t }}"
                   aria-label="{{ "view_strings.sections_tags.edit" | t }} {{ tag.name }}"
                   class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-indigo-600 transition-colors hover:bg-indigo-50 hover:text-indigo-800">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#pencil-square"></use></svg>
                  <span class="sr-only">{{ "view_strings.sections_tags.edit" | t }}</span>
                </a>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="6" class="px-6 py-10 text-center text-gray-400">{{ "view_strings.sections_tags.no_tags_yet" | t }}</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
