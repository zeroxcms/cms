<div class="min-w-0 max-w-3xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">Menu</h2>
    <p class="mt-1 text-sm text-gray-500">Choose which built-in admin links are visible in the sidebar.</p>
  </div>

  {% if hasFlash %}
    <div class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">{{ flash | escape }}</div>
  {% endif %}

  <form id="menu-settings-form" method="POST" action="/admin/settings/menu" class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
    <fieldset class="min-w-0">
      <legend class="text-sm font-semibold uppercase tracking-wider text-gray-500">Sidebar links</legend>
      <div class="mt-4 divide-y divide-gray-200">
        {% for option in options %}
          <label class="flex min-w-0 items-start justify-between gap-4 py-3">
            <span class="min-w-0">
              <span class="block text-sm font-semibold text-gray-900">{{ option.label | escape }}</span>
              <span class="mt-1 block text-sm text-gray-500">{{ option.description | escape }}</span>
            </span>
            <input type="checkbox"
                   name="visible_items"
                   value="{{ option.value | escape }}"
                   {% if option.checked %}checked{% endif %}
                   class="mt-1 h-4 w-4 shrink-0 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
          </label>
        {% endfor %}
      </div>
    </fieldset>
  </form>

  <div class="mt-4 flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button type="submit"
            form="menu-settings-form"
            class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">Save</button>
    <a href="/admin" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">Cancel</a>
  </div>
</div>
