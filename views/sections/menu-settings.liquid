<div class="min-w-0 max-w-3xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">{{ "view_strings.sections_menu_settings.system" | t }}</h2>
    <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_menu_settings.manage_the_admin_app_name_home_page_icon_and_sidebar_menu" | t }}</p>
  </div>

  {% if hasFlash %}
    <div class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">{{ flashKey | t }}</div>
  {% endif %}
  {% if hasError %}
    <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">{{ errorKey | t }}</div>
  {% endif %}

  <form id="menu-settings-form" method="POST" action="/admin/settings/system" class="min-w-0 space-y-6">
    <section class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_menu_settings.app_branding" | t }}</h3>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <label class="block min-w-0">
          <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_menu_settings.app_name" | t }}</span>
          <input type="text"
                 name="app_name"
                 value="{{ appName }}"
                 maxlength="80"
                 class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
        </label>
        <label class="block min-w-0">
          <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_menu_settings.app_icon" | t }}</span>
          <select name="app_icon" class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
            {% for option in iconOptions %}
              <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.labelKey | t }}</option>
            {% endfor %}
          </select>
        </label>
      </div>
    </section>

    <section class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "settings.regional.title" | t }}</h3>
      <label class="mt-4 block min-w-0 max-w-md">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "settings.regional.timezone" | t }}</span>
        <select name="system_timezone"
                required
                class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono">
          {% for option in timezoneOptions %}
            <option value="{{ option.value }}"{% if option.selected %} selected{% endif %}>{{ option.label }}</option>
          {% endfor %}
        </select>
        <span class="mt-1 block text-xs text-gray-500">{{ "settings.regional.timezone_help" | t }}</span>
      </label>
    </section>

    <section class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_menu_settings.admin_home" | t }}</h3>
      <label class="mt-4 block min-w-0">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_menu_settings.admin_redirect_path" | t }}</span>
        <input type="text"
               name="admin_home_path"
               value="{{ adminHomePath }}"
               placeholder="{{ "view_strings.sections_menu_settings.admin_plugins_events_dashboard" | t }}"
               class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
      </label>
    </section>

    <section class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_menu_settings.sidebar_groups" | t }}</h3>
      <label class="mt-4 block max-w-xs">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_menu_settings.settings_group_weight" | t }}</span>
        <input type="number"
               name="settings_group_weight"
               value="{{ settingsGroupWeight }}"
               class="block w-24 rounded-lg border border-gray-300 px-3 py-2 text-sm">
      </label>
    </section>

    {% if hasMainOptions %}
    <fieldset class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <legend class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_menu_settings.main_sidebar_links" | t }}</legend>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left">
          <thead class="text-xs uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.item" | t }}</th>
              <th class="w-24 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.visible" | t }}</th>
              <th class="w-28 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.weight" | t }}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm">
            {% for option in mainOptions %}
              <tr>
                <td class="px-3 py-3">
                  <p class="font-semibold text-gray-900">{{ option.labelKey | t }}</p>
                  <p class="mt-1 text-gray-500">{{ option.descriptionKey | t }}</p>
                </td>
                <td class="px-3 py-3">
                  <input type="checkbox"
                         name="visible_items"
                         value="{{ option.value }}"
                         {% if option.checked %}checked{% endif %}
                         {% if option.locked %}disabled{% endif %}
                         aria-label="{{ "settings.actions.show_item" | t }}"
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                  {% if option.locked %}
                    <input type="hidden" name="visible_items" value="{{ option.value }}">
                  {% endif %}
                </td>
                <td class="px-3 py-3">
                  <input type="number"
                         name="weight_{{ option.value }}"
                         value="{{ option.weight }}"
                         aria-label="{{ "settings.fields.item_weight" | t }}"
                         class="block w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm">
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </fieldset>
    {% endif %}

    {% if hasSettingsOptions %}
    <fieldset class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <legend class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_menu_settings.settings_sidebar_links" | t }}</legend>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left">
          <thead class="text-xs uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.item" | t }}</th>
              <th class="w-24 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.visible" | t }}</th>
              <th class="w-28 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.weight" | t }}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm">
            {% for option in settingsOptions %}
              <tr>
                <td class="px-3 py-3">
                  <p class="font-semibold text-gray-900">{{ option.labelKey | t }}</p>
                  <p class="mt-1 text-gray-500">{{ option.descriptionKey | t }}</p>
                </td>
                <td class="px-3 py-3">
                  <input type="checkbox"
                         name="visible_items"
                         value="{{ option.value }}"
                         {% if option.checked %}checked{% endif %}
                         {% if option.locked %}disabled{% endif %}
                         aria-label="{{ "settings.actions.show_item" | t }}"
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                  {% if option.locked %}
                    <input type="hidden" name="visible_items" value="{{ option.value }}">
                  {% endif %}
                </td>
                <td class="px-3 py-3">
                  <input type="number"
                         name="weight_{{ option.value }}"
                         value="{{ option.weight }}"
                         aria-label="{{ "settings.fields.item_weight" | t }}"
                         class="block w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm">
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </fieldset>
    {% endif %}

    {% if hasPluginOptions %}
    <fieldset class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <legend class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_menu_settings.plugin_links" | t }}</legend>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left">
          <thead class="text-xs uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.item" | t }}</th>
              <th class="w-28 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.group" | t }}</th>
              <th class="w-24 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.visible" | t }}</th>
              <th class="w-28 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.weight" | t }}</th>
              <th class="w-36 px-3 py-2 font-semibold">{{ "view_strings.sections_menu_settings.icon" | t }}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm">
            {% for option in pluginOptions %}
              <tr>
                <td class="px-3 py-3">
                  <p class="font-semibold text-gray-900">{{ option.label }}</p>
                  <p class="mt-1 truncate text-gray-500">{{ option.href }}</p>
                </td>
                <td class="px-3 py-3 text-gray-600">{{ option.groupKey | t }}</td>
                <td class="px-3 py-3">
                  <input type="checkbox"
                         name="plugin_visible_items"
                         value="{{ option.key }}"
                         {% if option.checked %}checked{% endif %}
                         aria-label="{{ "settings.actions.show_item" | t }}"
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                </td>
                <td class="px-3 py-3">
                  <input type="number"
                         name="plugin_weight_{{ option.formKey }}"
                         value="{{ option.weight }}"
                         aria-label="{{ "settings.fields.item_weight" | t }}"
                         class="block w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm">
                </td>
                <td class="px-3 py-3">
                  <select name="plugin_icon_{{ option.formKey }}" aria-label="{{ "settings.fields.item_icon" | t }}"
                          class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                    {% for icon in iconOptions %}
                      <option value="{{ icon.value }}"{% if option.icon == icon.value %} selected{% endif %}>{{ icon.labelKey | t }}</option>
                    {% endfor %}
                  </select>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </fieldset>
    {% endif %}
  </form>

  <div class="mt-4 flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button type="submit"
            form="menu-settings-form"
            class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">{{ "view_strings.sections_menu_settings.save" | t }}</button>
    <a href="/admin" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "view_strings.sections_menu_settings.cancel" | t }}</a>
  </div>
</div>
