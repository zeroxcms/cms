<div class="min-w-0 max-w-3xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">System</h2>
    <p class="mt-1 text-sm text-gray-500">Manage the admin app name, home page, icon, and sidebar menu.</p>
  </div>

  {% if hasFlash %}
    <div class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">{{ flash | escape }}</div>
  {% endif %}

  <form id="menu-settings-form" method="POST" action="/admin/settings/system" class="min-w-0 space-y-6">
    <section class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">App branding</h3>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <label class="block min-w-0">
          <span class="block text-sm font-medium text-gray-700 mb-1">App name</span>
          <input type="text"
                 name="app_name"
                 value="{{ appName | escape }}"
                 maxlength="80"
                 class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
        </label>
        <label class="block min-w-0">
          <span class="block text-sm font-medium text-gray-700 mb-1">App icon</span>
          <select name="app_icon" class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
            {% for option in iconOptions %}
              <option value="{{ option.value | escape }}"{% if option.selected %} selected{% endif %}>{{ option.label | escape }}</option>
            {% endfor %}
          </select>
        </label>
      </div>
    </section>

    <section class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">Admin home</h3>
      <label class="mt-4 block min-w-0">
        <span class="block text-sm font-medium text-gray-700 mb-1">/admin redirect path</span>
        <input type="text"
               name="admin_home_path"
               value="{{ adminHomePath | escape }}"
               placeholder="/admin/plugins/events/dashboard"
               class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
      </label>
    </section>

    <section class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">Sidebar groups</h3>
      <label class="mt-4 block max-w-xs">
        <span class="block text-sm font-medium text-gray-700 mb-1">Settings group weight</span>
        <input type="number"
               name="settings_group_weight"
               value="{{ settingsGroupWeight | escape }}"
               class="block w-24 rounded-lg border border-gray-300 px-3 py-2 text-sm">
      </label>
    </section>

    {% if hasMainOptions %}
    <fieldset class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <legend class="text-sm font-semibold uppercase tracking-wider text-gray-500">Main sidebar links</legend>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left">
          <thead class="text-xs uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-3 py-2 font-semibold">Item</th>
              <th class="w-24 px-3 py-2 font-semibold">Visible</th>
              <th class="w-28 px-3 py-2 font-semibold">Weight</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm">
            {% for option in mainOptions %}
              <tr>
                <td class="px-3 py-3">
                  <p class="font-semibold text-gray-900">{{ option.label | escape }}</p>
                  <p class="mt-1 text-gray-500">{{ option.description | escape }}</p>
                </td>
                <td class="px-3 py-3">
                  <input type="checkbox"
                         name="visible_items"
                         value="{{ option.value | escape }}"
                         {% if option.checked %}checked{% endif %}
                         {% if option.locked %}disabled{% endif %}
                         aria-label="Show {{ option.label | escape }}"
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                  {% if option.locked %}
                    <input type="hidden" name="visible_items" value="{{ option.value | escape }}">
                  {% endif %}
                </td>
                <td class="px-3 py-3">
                  <input type="number"
                         name="weight_{{ option.value | escape }}"
                         value="{{ option.weight | escape }}"
                         aria-label="{{ option.label | escape }} weight"
                         class="block w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm">
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </fieldset>
    {% endif %}

    {% if hasSettingsOptions %}
    <fieldset class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <legend class="text-sm font-semibold uppercase tracking-wider text-gray-500">Settings sidebar links</legend>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left">
          <thead class="text-xs uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-3 py-2 font-semibold">Item</th>
              <th class="w-24 px-3 py-2 font-semibold">Visible</th>
              <th class="w-28 px-3 py-2 font-semibold">Weight</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm">
            {% for option in settingsOptions %}
              <tr>
                <td class="px-3 py-3">
                  <p class="font-semibold text-gray-900">{{ option.label | escape }}</p>
                  <p class="mt-1 text-gray-500">{{ option.description | escape }}</p>
                </td>
                <td class="px-3 py-3">
                  <input type="checkbox"
                         name="visible_items"
                         value="{{ option.value | escape }}"
                         {% if option.checked %}checked{% endif %}
                         {% if option.locked %}disabled{% endif %}
                         aria-label="Show {{ option.label | escape }}"
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                  {% if option.locked %}
                    <input type="hidden" name="visible_items" value="{{ option.value | escape }}">
                  {% endif %}
                </td>
                <td class="px-3 py-3">
                  <input type="number"
                         name="weight_{{ option.value | escape }}"
                         value="{{ option.weight | escape }}"
                         aria-label="{{ option.label | escape }} weight"
                         class="block w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm">
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </fieldset>
    {% endif %}

    {% if hasPluginOptions %}
    <fieldset class="min-w-0 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
      <legend class="text-sm font-semibold uppercase tracking-wider text-gray-500">Plugin links</legend>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left">
          <thead class="text-xs uppercase tracking-wider text-gray-500">
            <tr>
              <th class="px-3 py-2 font-semibold">Item</th>
              <th class="w-28 px-3 py-2 font-semibold">Group</th>
              <th class="w-24 px-3 py-2 font-semibold">Visible</th>
              <th class="w-28 px-3 py-2 font-semibold">Weight</th>
              <th class="w-36 px-3 py-2 font-semibold">Icon</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 text-sm">
            {% for option in pluginOptions %}
              <tr>
                <td class="px-3 py-3">
                  <p class="font-semibold text-gray-900">{{ option.label | escape }}</p>
                  <p class="mt-1 truncate text-gray-500">{{ option.href | escape }}</p>
                </td>
                <td class="px-3 py-3 text-gray-600">{{ option.groupLabel | escape }}</td>
                <td class="px-3 py-3">
                  <input type="checkbox"
                         name="plugin_visible_items"
                         value="{{ option.key | escape }}"
                         {% if option.checked %}checked{% endif %}
                         aria-label="Show {{ option.label | escape }}"
                         class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                </td>
                <td class="px-3 py-3">
                  <input type="number"
                         name="plugin_weight_{{ option.formKey | escape }}"
                         value="{{ option.weight | escape }}"
                         aria-label="{{ option.label | escape }} weight"
                         class="block w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm">
                </td>
                <td class="px-3 py-3">
                  <select name="plugin_icon_{{ option.formKey | escape }}" aria-label="{{ option.label | escape }} icon"
                          class="block w-full rounded-lg border border-gray-300 px-3 py-2 text-sm">
                    {% for icon in iconOptions %}
                      <option value="{{ icon.value | escape }}"{% if option.icon == icon.value %} selected{% endif %}>{{ icon.label | escape }}</option>
                    {% endfor %}
                  </select>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </fieldset>
    {% endif %}
  </form>

  <div class="mt-4 flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    <button type="submit"
            form="menu-settings-form"
            class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">Save</button>
    <a href="/admin" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">Cancel</a>
  </div>
</div>
