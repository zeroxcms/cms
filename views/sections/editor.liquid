<div class="min-w-0 max-w-4xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin" class="shrink-0 text-gray-400 hover:text-gray-600 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <h2 class="min-w-0 break-words text-2xl font-bold text-gray-900">{{ pageTitle | escape }}</h2>
    {% if isEdit %}
      <div id="presence-bar"
           class="ml-auto flex items-center gap-1.5 shrink-0"
           data-page-id="{{ page.id }}"
           data-user-id="{{ currentUserId | escape }}"
           data-user-avatar="{{ userAvatar | escape }}">
        <div id="presence-avatars" class="flex items-center gap-1"></div>
        <div id="sync-indicator"
             title=""
             style="width:8px;height:8px;border-radius:50%;background:#9ca3af;flex-shrink:0;transition:background .4s,opacity .4s;display:none"></div>
      </div>
    {% endif %}
  </div>

  {% if hasErrors %}
    <div class="mb-6 rounded-lg bg-red-50 border border-red-200 p-4">
      <p class="text-sm font-semibold text-red-700 mb-1">Please fix the following errors:</p>
      <ul class="list-disc list-inside text-sm text-red-600">
        {% for error in errors %}
          <li>{{ error | escape }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  {% if hasFlash %}
    <div id="flash" class="mb-6 rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-700 flex items-center gap-2">
      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      {{ flash | escape }}
    </div>
  {% endif %}

  <form method="POST" action="{{ action | escape }}" class="min-w-0 space-y-6">
    {% if isVersionPreview %}
      <button type="submit" name="action" value="{{ selectedVersion.restoreAction | escape }}" class="sr-only" tabindex="-1" aria-hidden="true">Restore Version</button>
    {% else %}
      <button type="submit" class="sr-only" tabindex="-1" aria-hidden="true">{{ saveLabel | escape }}</button>
    {% endif %}
    <div class="min-w-0 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <div class="flex min-w-0 flex-col gap-3 border-b border-gray-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between sm:px-5">
        <div class="flex min-w-0 items-center gap-2">
          <svg class="h-4 w-4 shrink-0 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <h3 class="min-w-0 truncate text-lg font-bold text-gray-900">Page Metadata</h3>
        </div>
        <div class="flex min-w-0 flex-wrap items-center gap-3 text-xs text-gray-600">
          <label for="parent_page_search" class="sr-only">Parent Page</label>
          <div class="relative flex min-w-0 items-center gap-1" data-parent-combobox data-parent-exclude="{{ page.id | escape }}">
            <svg class="h-3.5 w-3.5 shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
            </svg>
            <input type="hidden" id="page_id" name="page_id" value="{{ selectedParent.id | escape }}">
            <input type="text" id="parent_page_search"
                   value="{{ selectedParent.label | escape }}"
                   autocomplete="off"
                   role="combobox"
                   aria-controls="parent_page_results"
                   aria-expanded="false"
                   aria-autocomplete="list"
                   class="w-28 max-w-[10rem] truncate border-0 bg-transparent p-0 text-xs text-gray-700 focus:outline-none focus:ring-0"
                   data-parent-search>
            <button type="button" class="shrink-0 rounded p-0.5 text-gray-400 hover:bg-gray-100 hover:text-gray-700" data-parent-toggle aria-label="Search parent pages">
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div id="parent_page_results"
                 class="absolute right-0 top-6 z-20 hidden w-72 max-w-[calc(100vw-2rem)] overflow-hidden rounded-lg border border-gray-200 bg-white py-1 shadow-lg"
                 data-parent-results>
              <button type="button"
                      class="block w-full px-3 py-2 text-left text-xs text-gray-700 hover:bg-gray-50"
                      data-parent-option
                      data-parent-id=""
                      data-parent-label="/"
                      data-parent-search="/ none top level">
                <span class="block font-medium">/</span>
                <span class="block text-[11px] text-gray-400">No parent</span>
              </button>
              <p class="hidden px-3 py-2 text-xs text-gray-400" data-parent-empty>No matching pages</p>
            </div>
          </div>
          <div class="flex min-w-0 items-center gap-1">
            <svg class="h-3.5 w-3.5 shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.5 20.25a8.25 8.25 0 0115 0"/>
            </svg>
            <span class="max-w-[9rem] truncate">{{ userName | escape }}</span>
          </div>
        </div>
      </div>

      <div class="min-w-0 px-4 py-4 sm:px-5">
        {% if isVersionPreview %}
          <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-amber-700">{{ selectedVersion.date | escape }}</p>
        {% endif %}
        <div class="flex min-w-0 items-start justify-between gap-4">
          <div class="min-w-0 flex-1">
            <div class="flex min-w-0 flex-wrap items-baseline gap-x-1.5 gap-y-1">
              <label for="name" class="sr-only">Page Name</label>
              <input type="text" id="name" name="name" required
                     value="{{ page.name | escape }}"
                     placeholder="My Awesome Page"
                     style="width: max(16rem, {{ page.name | size | plus: 2 }}ch);"
                     class="max-w-full border-b border-transparent bg-transparent p-0 text-lg font-bold text-gray-900 focus:border-indigo-500 focus:outline-none"
                     oninput="autoSlug(this.value)">
              <span class="text-sm text-gray-500">(</span>
              <label for="page_type" class="sr-only">Page Type</label>
              <input type="text" id="page_type" name="page_type" list="page_type_options"
                     value="{{ page.pageType | escape }}"
                     placeholder="default"
                     class="w-32 border-b border-transparent bg-transparent p-0 text-sm text-gray-500 focus:border-indigo-500 focus:outline-none">
              <span class="text-sm text-gray-500">)</span>
              <datalist id="page_type_options">
                {% for option in pageTypeOptions %}
                  <option value="{{ option.value | escape }}"></option>
                {% endfor %}
              </datalist>
            </div>
            <div class="mt-1 flex min-w-0 flex-wrap items-center gap-1 text-sm font-mono text-gray-500">
              <span class="shrink-0">/</span>
              <label for="slug" class="sr-only">Slug</label>
              <input type="text" id="slug" name="slug" required
                     value="{{ page.slug | escape }}"
                     placeholder="my-awesome-page"
                     class="min-w-[10rem] flex-1 border-b border-transparent bg-transparent p-0 focus:border-indigo-500 focus:outline-none">
              <button type="button" onclick="copyToClipboard('#slug')" title="Copy slug"
                      class="shrink-0 rounded p-1 text-gray-400 hover:bg-gray-100 hover:text-indigo-700">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
                <span class="sr-only">Copy slug</span>
              </button>
            </div>
          </div>
          <div class="flex shrink-0 items-center gap-1 text-gray-900">
            <span class="text-sm text-gray-500">#</span>
            <label for="weight" class="sr-only">Sort Weight</label>
            <input type="number" id="weight" name="weight"
                   value="{{ page.weight }}" min="0" max="100"
                   class="w-12 border-b border-transparent bg-transparent p-0 text-right text-lg font-bold focus:border-indigo-500 focus:outline-none">
          </div>
        </div>

        <div class="mt-4 grid min-w-0 grid-cols-1 gap-4 sm:grid-cols-2">
          <label for="start" class="flex min-w-0 items-center gap-2">
            <svg class="h-4 w-4 shrink-0 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M8 7V3m8 4V3M4 11h16M5 5h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V6a1 1 0 011-1z"/>
            </svg>
            <span class="shrink-0 text-xs text-gray-500">From:</span>
            <input type="datetime-local" id="start" name="start"
                   value="{{ page.start | escape }}"
                   class="min-w-0 flex-1 border-b border-transparent bg-transparent p-0 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none">
          </label>
          <label for="end" class="flex min-w-0 items-center gap-2">
            <svg class="h-4 w-4 shrink-0 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M8 7V3m8 4V3M4 11h16M5 5h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V6a1 1 0 011-1z"/>
            </svg>
            <span class="shrink-0 text-xs text-gray-500">Until:</span>
            <input type="datetime-local" id="end" name="end"
                   value="{{ page.end | escape }}"
                   class="min-w-0 flex-1 border-b border-transparent bg-transparent p-0 text-sm text-gray-900 focus:border-indigo-500 focus:outline-none">
          </label>
        </div>
      </div>

      <div class="flex min-w-0 flex-col gap-2 border-t border-gray-200 px-4 py-2.5 sm:flex-row sm:items-center sm:px-5">
        <div class="flex shrink-0 items-center gap-2 text-gray-500">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17 20h5v-2a4 4 0 00-4-4h-1M9 20H4v-2a4 4 0 014-4h1m4 6v-2a4 4 0 00-8 0v2m12-10a4 4 0 10-8 0 4 4 0 008 0z"/>
          </svg>
          <label for="editors" class="sr-only">Editor User IDs</label>
          <span class="sr-only">Editors</span>
        </div>
        <div class="flex min-w-0 flex-1 flex-wrap items-center gap-1.5">
          {% if page.hasEditorChips %}
            {% for editor in page.editorChips %}
              <span class="inline-flex max-w-full items-center rounded bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
                {{ editor | escape }}
              </span>
            {% endfor %}
          {% endif %}
          <input type="text" id="editors" name="editors"
                 value="{{ page.editors | escape }}"
                 placeholder="12,34,56"
                 class="min-w-[9rem] flex-1 border-b border-transparent bg-transparent p-0 text-xs text-gray-600 focus:border-indigo-500 focus:outline-none">
        </div>
      </div>

      <div class="flex min-w-0 gap-2 border-t border-gray-200 px-4 py-3 sm:px-5">
        <svg class="mt-1 h-4 w-4 shrink-0 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M8 9l-3 3 3 3m8-6l3 3-3 3M14 5l-4 14"/>
        </svg>
        <label for="lect_json" class="sr-only">Lect JSON</label>
        <textarea id="lect_json" name="lect_json" rows="4"
                  class="block min-w-0 w-full max-w-full rounded border border-gray-300 bg-gray-50 px-3 py-2 text-xs font-mono text-gray-800 focus:border-transparent focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-y">{{ page.lect | escape }}</textarea>
      </div>
    </div>

    {{ structuredBlock }}

    {% if hasPreservedTagIds %}
      {% for tagId in preservedTagIds %}
        <input type="hidden" name="tag_ids" value="{{ tagId | escape }}">
      {% endfor %}
    {% endif %}

    {% if hasTagGroups %}
      <div class="min-w-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <p class="text-sm font-medium text-gray-700 mb-3">Tags</p>
        <div class="space-y-4">
          {% for group in tagGroups %}
            <div class="min-w-0 space-y-2">
              <p class="min-w-0 break-words text-xs font-semibold uppercase tracking-wide text-gray-400">{{ group.name | escape }}</p>
              {% if group.hasTags %}
                <div class="flex flex-wrap gap-3">
                  {% for tag in group.tags %}
                    <label for="tag_{{ tag.id }}" class="flex min-w-0 items-center gap-2 cursor-pointer">
                      <input id="tag_{{ tag.id }}" type="checkbox" name="tag_ids" value="{{ tag.id }}"
                             {% if tag.checked %}checked{% endif %}
                             class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
                      <span class="min-w-0 break-words text-sm text-gray-700">{{ tag.name | escape }}</span>
                    </label>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if hasVersions %}
      <div class="min-w-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <p class="text-sm font-semibold text-gray-700 mb-3">Versions</p>
        <div class="flex flex-wrap gap-2">
          {% for version in versions %}
            <a href="{{ version.href | escape }}"
               class="min-w-0 break-words px-3 py-1.5 rounded-lg border text-xs {% if version.active %}border-amber-400 bg-amber-50 text-amber-800{% else %}border-gray-300 bg-white text-gray-700 hover:bg-gray-50{% endif %}">
              {{ version.label | escape }}
              {% if version.live %}
                <span class="ml-1 rounded bg-green-100 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-green-700">Live</span>
              {% endif %}
            </a>
            <button type="submit" name="action" value="{{ version.revertAction | escape }}"
                    class="shrink-0 px-3 py-1.5 rounded-lg border border-yellow-300 bg-yellow-50 text-xs text-yellow-800 hover:bg-yellow-100">Revert</button>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="flex min-w-0 flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap sm:items-center">
      {% if isVersionPreview %}
        <button type="submit" name="action" value="{{ selectedVersion.restoreAction | escape }}"
                class="w-full px-6 py-2 bg-amber-600 text-white text-sm font-semibold rounded-lg hover:bg-amber-700 transition-colors shadow-sm sm:w-auto">
          Restore Version
        </button>
        <a href="{{ selectedVersion.currentHref | escape }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">
          Edit Current
        </a>
      {% else %}
        <button type="submit"
                class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">
          {{ saveLabel | escape }}
        </button>
        {% if isEdit %}
          <button type="submit" name="action" value="publish"
                  class="w-full px-6 py-2 bg-green-600 text-white text-sm font-semibold rounded-lg hover:bg-green-700 transition-colors shadow-sm sm:w-auto">Publish</button>
        {% endif %}
      {% endif %}
      <a href="/admin" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">
        Cancel
      </a>
    </div>
  </form>
</div>

<script>
  const flash = document.getElementById('flash');
  if (flash) setTimeout(() => flash.remove(), 4000);

  const parentCombobox = document.querySelector('[data-parent-combobox]');
  if (parentCombobox) {
    const parentInput = parentCombobox.querySelector('[data-parent-search]');
    const parentHidden = parentCombobox.querySelector('#page_id');
    const parentResults = parentCombobox.querySelector('[data-parent-results]');
    const parentEmpty = parentCombobox.querySelector('[data-parent-empty]');
    const parentToggle = parentCombobox.querySelector('[data-parent-toggle]');
    let parentSearchRequest = 0;

    function parentOptions() {
      return Array.from(parentCombobox.querySelectorAll('[data-parent-option]'));
    }

    function bindParentOption(option) {
      option.addEventListener('click', () => selectParentOption(option));
    }

    function updateParentEmpty() {
      let visibleCount = 0;
      parentOptions().forEach((option) => {
        const visible = !option.classList.contains('hidden');
        if (visible) visibleCount++;
      });
      parentEmpty.classList.toggle('hidden', visibleCount > 0);
    }

    function renderParentOptions(pages) {
      parentCombobox.querySelectorAll('[data-parent-dynamic]').forEach((option) => option.remove());
      pages.forEach((page) => {
        const option = document.createElement('button');
        option.type = 'button';
        option.className = 'block w-full px-3 py-2 text-left text-xs text-gray-700 hover:bg-gray-50';
        option.dataset.parentOption = '';
        option.dataset.parentDynamic = '';
        option.dataset.parentId = String(page.id);
        option.dataset.parentLabel = page.label;
        option.innerHTML = `<span class="block truncate font-medium"></span><span class="block truncate text-[11px] text-gray-400"></span>`;
        option.children[0].textContent = page.label;
        option.children[1].textContent = page.name;
        bindParentOption(option);
        parentResults.insertBefore(option, parentEmpty);
      });
      updateParentEmpty();
    }

    async function loadParentOptions() {
      const requestId = ++parentSearchRequest;
      const params = new URLSearchParams();
      const query = parentInput.value.trim();
      const exclude = parentCombobox.dataset.parentExclude || '';
      const noParentOption = parentCombobox.querySelector('[data-parent-id=""]');
      noParentOption.classList.toggle('hidden', !!query && query !== '/');
      if (query && query !== '/') params.set('q', query);
      if (exclude) params.set('exclude', exclude);

      try {
        const response = await fetch(`/admin/api/parent-pages?${params.toString()}`);
        if (!response.ok || requestId !== parentSearchRequest) return;
        renderParentOptions(await response.json());
      } catch (_error) {
        if (requestId === parentSearchRequest) renderParentOptions([]);
      }
    }

    async function openParentResults() {
      parentResults.classList.remove('hidden');
      parentInput.setAttribute('aria-expanded', 'true');
      await loadParentOptions();
    }

    function closeParentResults() {
      parentResults.classList.add('hidden');
      parentInput.setAttribute('aria-expanded', 'false');
    }

    function selectParentOption(option) {
      parentHidden.value = option.dataset.parentId || '';
      parentInput.value = option.dataset.parentLabel || '/';
      closeParentResults();
    }

    parentInput.addEventListener('focus', openParentResults);
    parentInput.addEventListener('input', () => {
      if (!parentInput.value.trim()) parentHidden.value = '';
      openParentResults();
    });
    parentInput.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closeParentResults();
        return;
      }
      if (event.key !== 'Enter') return;
      const firstVisible = parentOptions().find((option) => !option.classList.contains('hidden'));
      if (!firstVisible) return;
      event.preventDefault();
      selectParentOption(firstVisible);
    });
    parentToggle.addEventListener('click', () => {
      if (parentResults.classList.contains('hidden')) {
        parentInput.focus();
        openParentResults();
      } else {
        closeParentResults();
      }
    });
    parentOptions().forEach(bindParentOption);
    document.addEventListener('click', (event) => {
      if (!parentCombobox.contains(event.target)) closeParentResults();
    });
  }

  const editorScrollKey = 'cms-editor-scroll:' + window.location.pathname;
  const savedEditorScroll = window.sessionStorage.getItem(editorScrollKey);
  if (savedEditorScroll !== null) {
    window.sessionStorage.removeItem(editorScrollKey);
    window.requestAnimationFrame(() => {
      window.scrollTo(0, Number(savedEditorScroll) || 0);
    });
  }

  function switchEditorLanguage(language) {
    window.sessionStorage.setItem(editorScrollKey, String(window.scrollY));
    const params = new window.URLSearchParams(window.location.search);
    params.set('language', language);
    window.location.href = window.location.pathname + '?' + params.toString();
  }

  const structuredActions = new Set([
    'block-add',
    'block-delete',
    'item-add',
    'item-delete',
    'block-item-add',
    'block-item-delete',
  ]);
  const editorForm = document.querySelector('form[method="POST"]');
  if (editorForm) {
    editorForm.addEventListener('submit', (event) => {
      const submitter = event.submitter || document.activeElement;
      const action = submitter && submitter.getAttribute ? submitter.getAttribute('value') || '' : '';
      if (structuredActions.has(action.split(':')[0])) {
        window.sessionStorage.setItem(editorScrollKey, String(window.scrollY));
      }
    });
  }

  let slugEdited = {% if isEdit %}true{% else %}false{% endif %};
  document.getElementById('slug').addEventListener('input', () => { slugEdited = true; });

  function autoSlug(name) {
    if (slugEdited) return;
    const slug = name.toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
    document.getElementById('slug').value = slug;
  }

  function copyToClipboard(selector) {
    const input = document.querySelector(selector);
    if (!input) return;
    input.select();
    input.setSelectionRange(0, 99999); // For mobile devices
    document.execCommand('copy');
  }
</script>

<script>
(function () {
  var bar = document.getElementById('presence-bar');
  if (!bar) return;

  var pageId = bar.dataset.pageId;
  var currentUserId = bar.dataset.userId;
  var userAvatar = bar.dataset.userAvatar || '';
  var lastActive = new Date().toISOString();

  ['mousemove', 'keydown', 'click', 'scroll'].forEach(function (evt) {
    document.addEventListener(evt, function () { lastActive = new Date().toISOString(); }, { passive: true });
  });

  function userColor(userId) {
    var palette = ['#6366f1', '#ec4899', '#10b981', '#f59e0b', '#8b5cf6', '#06b6d4', '#f97316'];
    var h = 0;
    for (var i = 0; i < userId.length; i++) h = (h * 31 + userId.charCodeAt(i)) & 0xffffff;
    return palette[Math.abs(h) % palette.length];
  }

  function initials(name) {
    return name.trim().split(/\s+/).map(function (w) { return w[0] || ''; }).join('').slice(0, 2).toUpperCase();
  }

  function renderAvatars(editors) {
    var container = document.getElementById('presence-avatars');
    if (!container) return;
    var now = Date.now();
    var IDLE_MS = 5 * 60 * 1000;
    container.innerHTML = editors.map(function (e) {
      var idle = (now - new Date(e.last_active).getTime()) > IDLE_MS;
      var color = userColor(e.user_id);
      var ring = idle ? '2px solid #9ca3af' : '2px solid ' + color;
      var opacity = idle ? '0.4' : '1';
      var label = e.user_name + (idle ? ' (idle)' : '') + (e.user_id === currentUserId ? ' (you)' : '');
      if (e.user_avatar) {
        return '<img src="' + e.user_avatar + '" title="' + label + '" alt="' + e.user_name +
          '" style="width:32px;height:32px;border-radius:50%;object-fit:cover;outline:' + ring +
          ';opacity:' + opacity + ';transition:opacity .3s">';
      }
      return '<div title="' + label + '" aria-label="' + label +
        '" style="width:32px;height:32px;border-radius:50%;background:' + color +
        ';display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff;outline:' +
        ring + ';opacity:' + opacity + ';transition:opacity .3s">' + initials(e.user_name) + '</div>';
    }).join('');
    // Enable CRDT only while at least one other editor is present.
    if (editors.length > 1) {
      window.__cmsSync && window.__cmsSync.enable();
    } else {
      window.__cmsSync && window.__cmsSync.disable();
    }
  }

  function sendHeartbeat() {
    fetch('/api/presence/' + pageId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ lastActive: lastActive, userAvatar: userAvatar }),
    }).catch(function () {});
  }

  function refreshPresence() {
    fetch('/api/presence/' + pageId)
      .then(function (r) { return r.json(); })
      .then(renderAvatars)
      .catch(function () {});
  }

  sendHeartbeat();
  refreshPresence();
  setInterval(sendHeartbeat, 30000);
  setInterval(refreshPresence, 15000);

  window.addEventListener('beforeunload', function () {
    fetch('/api/presence/' + pageId, { method: 'DELETE', keepalive: true }).catch(function () {});
  });
}());
</script>

<script>
(function () {
  var bar = document.getElementById('presence-bar');
  if (!bar) return;

  var pageId = bar.dataset.pageId;
  var currentUserId = bar.dataset.userId;
  var indicator = document.getElementById('sync-indicator');

  // HLC: "<ms>.<counter>.<userId>" — lexicographic ordering is correct.
  var hlcCounter = 0;
  function nextHlc() {
    return Date.now() + '.' + (++hlcCounter).toString().padStart(6, '0') + '.' + currentUserId;
  }

  // Track locally sent ops so snapshot ops don't overwrite in-progress edits.
  // localOps[path] = hlc of the latest op we sent for that path.
  var localOps = {};

  var ws = null;
  var reconnectTimer = null;
  var crdtEnabled = false;

  function setSyncStatus(status) {
    if (!indicator) return;
    if (status === 'idle') {
      indicator.style.display = 'none';
      indicator.title = '';
    } else if (status === 'connected') {
      indicator.style.display = '';
      indicator.style.background = '#10b981';
      indicator.title = 'Live sync active';
    } else if (status === 'connecting') {
      indicator.style.display = '';
      indicator.style.background = '#f59e0b';
      indicator.title = 'Connecting…';
    } else {
      indicator.style.display = '';
      indicator.style.background = '#9ca3af';
      indicator.title = 'Sync disconnected — changes still save normally';
    }
  }

  function applyOp(op) {
    var path = op.path;
    var value = op.value != null ? String(op.value) : '';

    // Don't clobber a locally edited field whose op is newer.
    var localHlc = localOps[path];
    if (localHlc && localHlc >= (op.hlc || '')) return;

    // Escape backslashes and quotes for the attribute selector.
    var escaped = path.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
    var el = document.querySelector('[name="' + escaped + '"]');
    if (!el) return;

    // Don't interrupt the user mid-edit.
    if (document.activeElement === el) return;

    el.value = value;
  }

  function sendOp(el) {
    if (!crdtEnabled || !ws || ws.readyState !== WebSocket.OPEN) return;
    var hlc = nextHlc();
    localOps[el.name] = hlc;
    ws.send(JSON.stringify({
      type: 'op',
      path: el.name,
      value: el.value,
      hlc: hlc,
      opId: crypto.randomUUID(),
    }));
  }

  // Attach listeners to all lect-encoded form fields.
  // Names follow the lect convention: starts with . @ * or # (digit).
  document.querySelectorAll('input[name], textarea[name], select[name]').forEach(function (el) {
    var name = el.getAttribute('name') || '';
    if (!/^[.@*#\d]/.test(name)) return;
    el.addEventListener('input',  function () { sendOp(el); });
    el.addEventListener('change', function () { sendOp(el); });
  });

  function connect() {
    if (!crdtEnabled) return;
    if (ws && ws.readyState < 2) return; // already CONNECTING or OPEN
    clearTimeout(reconnectTimer);
    setSyncStatus('connecting');

    var proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
    ws = new WebSocket(proto + '//' + location.host + '/admin/api/sync/' + pageId);

    ws.onopen = function () {
      setSyncStatus('connected');
      ws.send(JSON.stringify({ type: 'sync' }));
    };

    ws.onmessage = function (e) {
      var msg;
      try { msg = JSON.parse(e.data); } catch { return; }

      if (msg.type === 'snapshot') {
        // Apply state from other editors; skip ops we own.
        (msg.ops || []).forEach(function (op) {
          if (op.userId === currentUserId) return;
          applyOp(op);
        });
      } else if (msg.type === 'op') {
        // Real-time broadcast — server never echoes back to sender.
        applyOp(msg);
      }
    };

    ws.onclose = ws.onerror = function () {
      if (!crdtEnabled) {
        setSyncStatus('idle');
        return;
      }
      setSyncStatus('disconnected');
      reconnectTimer = setTimeout(connect, 4000);
    };
  }

  function disconnect() {
    crdtEnabled = false;
    clearTimeout(reconnectTimer);
    if (ws) {
      ws.onclose = ws.onerror = null;
      try { ws.close(1000, 'No co-editors'); } catch {}
      ws = null;
    }
    setSyncStatus('idle');
  }

  // Exposed to the presence script so it can drive CRDT activation.
  window.__cmsSync = {
    enable: function () {
      if (crdtEnabled) return; // already active
      crdtEnabled = true;
      connect();
    },
    disable: disconnect,
  };

  window.addEventListener('beforeunload', function () {
    if (ws) try { ws.close(1001, 'Leaving'); } catch {}
  });
}());
</script>
