<div class="min-w-0 max-w-4xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center gap-3 mb-6">
    <a href="/admin" class="shrink-0 text-gray-400 hover:text-gray-600 transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <h2 class="min-w-0 break-words text-2xl font-bold text-gray-900">{{ pageTitle | escape }}</h2>
  </div>

  {% if hasErrors %}
    <div class="mb-6 rounded-lg bg-red-50 border border-red-200 p-4">
      <p class="text-sm font-semibold text-red-700 mb-1">Please fix the following errors:</p>
      <ul class="list-disc list-inside text-sm text-red-600">
        {% for error in errors %}
          <li>{{ error | escape }}</li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}

  {% if hasFlash %}
    <div id="flash" class="mb-6 rounded-lg bg-green-50 border border-green-200 p-3 text-sm text-green-700 flex items-center gap-2">
      <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      {{ flash | escape }}
    </div>
  {% endif %}

  <form method="POST" action="{{ action | escape }}" class="min-w-0 space-y-6">
    {% if isVersionPreview %}
      <button type="submit" name="action" value="{{ selectedVersion.restoreAction | escape }}" class="sr-only" tabindex="-1" aria-hidden="true">Restore Version</button>
    {% else %}
      <button type="submit" class="sr-only" tabindex="-1" aria-hidden="true">{{ saveLabel | escape }}</button>
    {% endif %}
    <div class="min-w-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm space-y-5 sm:p-6">
      <div class="grid min-w-0 grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5">
        <div class="min-w-0 sm:col-span-2">
          {% if isVersionPreview %}
            <p class="mb-1 text-xs font-semibold uppercase tracking-wide text-amber-700">{{ selectedVersion.date | escape }}</p>
          {% endif %}
          <div class="min-w-0">
          <label for="name" class="hidden text-sm font-medium text-gray-700 mb-1">
            Page Name <span class="text-red-500">*</span>
          </label>
          <input type="text" id="name" name="name" required
                 value="{{ page.name | escape }}"
                 placeholder="My Awesome Page"
                 class="block min-w-0 w-full max-w-full border-b border-transparent p-0 text-xl focus:outline-none focus:border-b focus:border-indigo-500"
                 oninput="autoSlug(this.value)">
          </div>
          <div class="min-w-0">
          <label for="slug" class="hidden text-sm font-medium text-gray-700 mb-1">
            Slug <span class="text-red-500">*</span>
          </label>
          <div class="flex min-w-0 flex-wrap items-center gap-1 text-xs font-mono text-gray-500">
            <span class="shrink-0">/</span>
            <input type="text" id="slug" name="slug" required
                   value="{{ page.slug | escape }}"
                   placeholder="my-awesome-page"
                   class="min-w-0 flex-1 border-b border-transparent bg-transparent focus:outline-none focus:border-indigo-500">
            <button type="button" onclick="copyToClipboard('#slug')" class="shrink-0 text-indigo-600 hover:text-indigo-800">copy</button>
          </div>
          </div>
        </div>

        <div class="min-w-0">
          <label for="page_type" class="block text-sm font-medium text-gray-700 mb-1">Page Type</label>
          <input type="text" id="page_type" name="page_type" list="page_type_options"
                 value="{{ page.pageType | escape }}"
                 placeholder="e.g. blog, product, landing"
                 class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
          <datalist id="page_type_options">
            {% for option in pageTypeOptions %}
              <option value="{{ option.value | escape }}"></option>
            {% endfor %}
          </datalist>
        </div>

        <div class="min-w-0">
          <label for="weight" class="block text-sm font-medium text-gray-700 mb-1">Sort Weight</label>
          <input type="number" id="weight" name="weight"
                 value="{{ page.weight }}" min="0" max="100"
                 class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div class="min-w-0">
          <label for="start" class="block text-sm font-medium text-gray-700 mb-1">Publish From</label>
          <input type="datetime-local" id="start" name="start"
                 value="{{ page.start | escape }}"
                 class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div class="min-w-0">
          <label for="end" class="block text-sm font-medium text-gray-700 mb-1">Publish Until</label>
          <input type="datetime-local" id="end" name="end"
                 value="{{ page.end | escape }}"
                 class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div class="min-w-0 sm:col-span-2">
          <label for="page_id" class="block text-sm font-medium text-gray-700 mb-1">Parent Page</label>
          <select id="page_id" name="page_id"
                  class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            <option value="">- None (top-level page) -</option>
            {% for option in parentOptions %}
              <option value="{{ option.id }}" {% if option.selected %}selected{% endif %}>{{ option.name | escape }}</option>
            {% endfor %}
          </select>
        </div>

        {% if page.creator %}
          <div class="min-w-0">
            <label for="creator" class="block text-sm font-medium text-gray-700 mb-1">Creator User ID</label>
            <input type="text" id="creator"
                   value="{{ page.creator | escape }}" readonly
                   class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-200 bg-gray-50 rounded-lg text-sm text-gray-500">
          </div>
        {% endif %}

        <div class="min-w-0 {% unless page.creator %}sm:col-span-2{% endunless %}">
          <label for="editors" class="block text-sm font-medium text-gray-700 mb-1">Editor User IDs</label>
          <input type="text" id="editors" name="editors"
                 value="{{ page.editors | escape }}"
                 placeholder="12,34,56"
                 class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div class="min-w-0 sm:col-span-2">
          <label for="lect_json" class="block text-sm font-medium text-gray-700 mb-1">Lect JSON</label>
          <textarea id="lect_json" name="lect_json" rows="4"
                    class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-xs font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-y">{{ page.lect | escape }}</textarea>
        </div>
      </div>
    </div>

    {{ structuredBlock }}

    {% if hasPreservedTagIds %}
      {% for tagId in preservedTagIds %}
        <input type="hidden" name="tag_ids" value="{{ tagId | escape }}">
      {% endfor %}
    {% endif %}

    {% if hasTagGroups %}
      <div class="min-w-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <p class="text-sm font-medium text-gray-700 mb-3">Tags</p>
        <div class="space-y-4">
          {% for group in tagGroups %}
            <div class="min-w-0 space-y-2">
              <p class="min-w-0 break-words text-xs font-semibold uppercase tracking-wide text-gray-400">{{ group.name | escape }}</p>
              {% if group.hasTags %}
                <div class="flex flex-wrap gap-3">
                  {% for tag in group.tags %}
                    <label for="tag_{{ tag.id }}" class="flex min-w-0 items-center gap-2 cursor-pointer">
                      <input id="tag_{{ tag.id }}" type="checkbox" name="tag_ids" value="{{ tag.id }}"
                             {% if tag.checked %}checked{% endif %}
                             class="w-4 h-4 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500">
                      <span class="min-w-0 break-words text-sm text-gray-700">{{ tag.name | escape }}</span>
                    </label>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if hasVersions %}
      <div class="min-w-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
        <p class="text-sm font-semibold text-gray-700 mb-3">Versions</p>
        <div class="flex flex-wrap gap-2">
          {% for version in versions %}
            <a href="{{ version.href | escape }}"
               class="min-w-0 break-words px-3 py-1.5 rounded-lg border text-xs {% if version.active %}border-amber-400 bg-amber-50 text-amber-800{% else %}border-gray-300 bg-white text-gray-700 hover:bg-gray-50{% endif %}">
              {{ version.label | escape }}
              {% if version.live %}
                <span class="ml-1 rounded bg-green-100 px-1.5 py-0.5 text-[10px] font-semibold uppercase text-green-700">Live</span>
              {% endif %}
            </a>
            <button type="submit" name="action" value="{{ version.revertAction | escape }}"
                    class="shrink-0 px-3 py-1.5 rounded-lg border border-yellow-300 bg-yellow-50 text-xs text-yellow-800 hover:bg-yellow-100">Revert</button>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    <div class="flex min-w-0 flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap sm:items-center">
      {% if isVersionPreview %}
        <button type="submit" name="action" value="{{ selectedVersion.restoreAction | escape }}"
                class="w-full px-6 py-2 bg-amber-600 text-white text-sm font-semibold rounded-lg hover:bg-amber-700 transition-colors shadow-sm sm:w-auto">
          Restore Version
        </button>
        <a href="{{ selectedVersion.currentHref | escape }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">
          Edit Current
        </a>
      {% else %}
        <button type="submit"
                class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">
          {{ saveLabel | escape }}
        </button>
        {% if isEdit %}
          <button type="submit" name="action" value="publish"
                  class="w-full px-6 py-2 bg-green-600 text-white text-sm font-semibold rounded-lg hover:bg-green-700 transition-colors shadow-sm sm:w-auto">Publish</button>
        {% endif %}
      {% endif %}
      <a href="/admin" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">
        Cancel
      </a>
    </div>
  </form>
</div>

<script>
  const flash = document.getElementById('flash');
  if (flash) setTimeout(() => flash.remove(), 4000);

  const editorScrollKey = 'cms-editor-scroll:' + window.location.pathname;
  const savedEditorScroll = window.sessionStorage.getItem(editorScrollKey);
  if (savedEditorScroll !== null) {
    window.sessionStorage.removeItem(editorScrollKey);
    window.requestAnimationFrame(() => {
      window.scrollTo(0, Number(savedEditorScroll) || 0);
    });
  }

  function switchEditorLanguage(language) {
    window.sessionStorage.setItem(editorScrollKey, String(window.scrollY));
    const params = new window.URLSearchParams(window.location.search);
    params.set('language', language);
    window.location.href = window.location.pathname + '?' + params.toString();
  }

  const structuredActions = new Set([
    'block-add',
    'block-delete',
    'item-add',
    'item-delete',
    'block-item-add',
    'block-item-delete',
  ]);
  const editorForm = document.querySelector('form[method="POST"]');
  if (editorForm) {
    editorForm.addEventListener('submit', (event) => {
      const submitter = event.submitter || document.activeElement;
      const action = submitter && submitter.getAttribute ? submitter.getAttribute('value') || '' : '';
      if (structuredActions.has(action.split(':')[0])) {
        window.sessionStorage.setItem(editorScrollKey, String(window.scrollY));
      }
    });
  }

  let slugEdited = {% if isEdit %}true{% else %}false{% endif %};
  document.getElementById('slug').addEventListener('input', () => { slugEdited = true; });

  function autoSlug(name) {
    if (slugEdited) return;
    const slug = name.toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
    document.getElementById('slug').value = slug;
  }

  function copyToClipboard(selector) {
    const input = document.querySelector(selector);
    if (!input) return;
    input.select();
    input.setSelectionRange(0, 99999); // For mobile devices
    document.execCommand('copy');
  }
</script>
