<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">{{ "view_strings.sections_plugins_manage.plugins" | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugins_manage.registered_over_https_added_here_without_a_cms_redeploy" | t }}</p>
    </div>
    <a href="/admin/plugins-manage/new"
       title="{{ "view_strings.sections_plugins_manage.register_plugin" | t }}"
       aria-label="{{ "view_strings.sections_plugins_manage.register_plugin" | t }}"
       class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#plus"></use></svg>
      <span class="hidden lg:inline">{{ "view_strings.sections_plugins_manage.register_plugin" | t }}</span>
    </a>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left text-sm mb-8">
      <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
        <tr>
          <th class="px-4 py-2">{{ "view_strings.sections_plugins_manage.plugin" | t }}</th>
          <th class="px-4 py-2">{{ "plugins.fields.url" | t }}</th>
          <th class="px-4 py-2">{{ "view_strings.sections_plugins_manage.status" | t }}</th>
          <th class="px-4 py-2 text-right">{{ "view_strings.sections_plugins_manage.actions" | t }}</th>
        </tr>
      </thead>
      <tbody>
        {% if hasPlugins %}
          {% for plugin in plugins %}
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{{ plugin.title }}</div>
                <div class="text-xs text-gray-500">{{ plugin.subtitle }}</div>
              </td>
              <td class="px-4 py-3 text-xs text-gray-500 break-all max-w-xs">{{ plugin.url }}</td>
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ plugin.statusClass }}">{{ plugin.statusKey | t }}</span>
              </td>
              <td class="px-4 py-3 text-right align-top">
                <div class="flex flex-wrap justify-end gap-1.5">
                  {% if plugin.hasAssets or plugin.hasPageTypes or plugin.hasLimits or plugin.hasCredits %}
                    <details class="group inline-block text-left relative">
                      <summary class="inline-flex h-8 cursor-pointer list-none items-center justify-center gap-1.5 rounded-md border border-gray-300 bg-white px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50 [&::-webkit-details-marker]:hidden">
                        {{ "view_strings.sections_plugins_manage.configuration" | t }}
                        <svg class="h-3.5 w-3.5 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#chevron-right"></use></svg>
                      </summary>
                      <div class="mt-2 rounded-lg bg-white shadow-sm absolute z-10">
                        <div class="flex flex-nowrap gap-1.5 shadow-md pb-2 pe-2">
                          {% if plugin.hasAssets %}<a href="{{ plugin.assetsHref }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_plugins_manage.assets" | t }}</a>{% endif %}
                          {% if plugin.hasPageTypes %}<a href="{{ plugin.pageTypesHref }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50 whitespace-nowrap">{{ "view_strings.sections_plugins_manage.page_types" | t }}</a>{% endif %}
                          {% if plugin.hasLimits %}<a href="{{ plugin.limitsHref }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_plugins_manage.limits" | t }}</a>{% endif %}
                          {% if plugin.hasCredits %}<a href="{{ plugin.creditsHref }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_plugins_manage.credits" | t }}</a>{% endif %}
                        </div>
                      </div>
                    </details>
                  {% endif %}

                  <form method="post" action="{{ plugin.toggleAction }}" class="inline">
                    <button type="submit" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">{% if plugin.enabled %}{{ "plugins.actions.disable" | t }}{% else %}{{ "plugins.actions.enable" | t }}{% endif %}</button>
                  </form>
                  <a href="{{ plugin.editHref }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">{{ "view_strings.sections_plugins_manage.edit" | t }}</a>
                  <form method="post" action="{{ plugin.deleteAction }}" class="inline" data-confirm="{{ "view_strings.sections_plugins_manage.remove_this_plugin" | t }}">
                    <button type="submit" class="inline-flex h-8 items-center justify-center rounded-md border border-red-300 px-3 text-xs font-semibold text-red-700 hover:bg-red-50">{{ "view_strings.sections_plugins_manage.delete" | t }}</button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="4" class="px-4 py-8 text-center text-sm text-gray-500">
              {{ "view_strings.sections_plugins_manage.no_plugins_registered_yet" | t }} <a class="text-indigo-600 font-medium" href="/admin/plugins-manage/new">{{ "view_strings.sections_plugins_manage.register_one" | t }}</a>.
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
