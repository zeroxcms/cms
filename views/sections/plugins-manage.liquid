<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Plugins</h2>
      <p class="mt-1 text-sm text-gray-500">Registered over HTTPS - added here without a CMS redeploy.</p>
    </div>
    <a href="/admin/plugins-manage/new" class="w-full px-4 py-2 text-center rounded-lg bg-indigo-600 text-white text-sm font-semibold sm:w-auto">Register plugin</a>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left text-sm">
      <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
        <tr>
          <th class="px-4 py-2">Plugin</th>
          <th class="px-4 py-2">URL</th>
          <th class="px-4 py-2">Status</th>
          <th class="px-4 py-2"></th>
        </tr>
      </thead>
      <tbody>
        {% if hasPlugins %}
          {% for plugin in plugins %}
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{{ plugin.title | escape }}</div>
                <div class="text-xs text-gray-500">{{ plugin.subtitle | escape }}</div>
              </td>
              <td class="px-4 py-3 text-xs text-gray-500 break-all max-w-xs">{{ plugin.url | escape }}</td>
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ plugin.statusClass | escape }}">{{ plugin.status | escape }}</span>
              </td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <form method="post" action="{{ plugin.toggleAction | escape }}" class="inline">
                  <button type="submit" class="px-3 py-1 rounded-lg border border-gray-300 text-xs font-semibold text-gray-700">{{ plugin.toggleLabel | escape }}</button>
                </form>
                <a href="{{ plugin.editHref | escape }}" class="ml-1 px-3 py-1 rounded-lg border border-gray-300 text-xs font-semibold text-gray-700">Edit</a>
                <form method="post" action="{{ plugin.deleteAction | escape }}" class="inline" data-confirm="Remove this plugin?">
                  <button type="submit" class="ml-1 px-3 py-1 rounded-lg border border-red-300 text-xs font-semibold text-red-700">Delete</button>
                </form>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="4" class="px-4 py-8 text-center text-sm text-gray-500">
              No plugins registered yet. <a class="text-indigo-600 font-medium" href="/admin/plugins-manage/new">Register one</a>.
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
