<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Plugins</h2>
      <p class="mt-1 text-sm text-gray-500">Registered over HTTPS - added here without a CMS redeploy.</p>
    </div>
    <a href="/admin/plugins-manage/new"
       title="Register plugin"
       aria-label="Register plugin"
       class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#plus"></use></svg>
      <span class="hidden lg:inline">Register plugin</span>
    </a>
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left text-sm">
      <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
        <tr>
          <th class="px-4 py-2">Plugin</th>
          <th class="px-4 py-2">URL</th>
          <th class="px-4 py-2">Status</th>
          <th class="px-4 py-2 text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        {% if hasPlugins %}
          {% for plugin in plugins %}
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{{ plugin.title | escape }}</div>
                <div class="text-xs text-gray-500">{{ plugin.subtitle | escape }}</div>
              </td>
              <td class="px-4 py-3 text-xs text-gray-500 break-all max-w-xs">{{ plugin.url | escape }}</td>
              <td class="px-4 py-3">
                <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ plugin.statusClass | escape }}">{{ plugin.status | escape }}</span>
              </td>
              <td class="px-4 py-3 text-right align-top">
                <details class="group ml-auto inline-block text-left">
                  <summary class="inline-flex h-9 cursor-pointer list-none items-center justify-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50 [&::-webkit-details-marker]:hidden">
                    Actions
                    <svg class="h-3.5 w-3.5 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix | escape }}#chevron-right"></use></svg>
                  </summary>
                  <div class="mt-2 w-72 rounded-lg border border-gray-200 bg-white p-2 shadow-sm">
                    <div class="text-[0.65rem] font-semibold uppercase tracking-wider text-gray-400">Manage</div>
                    <div class="mt-1 flex flex-wrap gap-1.5">
                      <form method="post" action="{{ plugin.toggleAction | escape }}" class="inline">
                        <button type="submit" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">{{ plugin.toggleLabel | escape }}</button>
                      </form>
                      <a href="{{ plugin.editHref | escape }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">Edit</a>
                    </div>

                    {% if plugin.hasAssets or plugin.hasPageTypes or plugin.hasLimits or plugin.hasCredits %}
                      <div class="mt-3 border-t border-gray-100 pt-2">
                        <div class="text-[0.65rem] font-semibold uppercase tracking-wider text-gray-400">Configuration</div>
                        <div class="mt-1 flex flex-wrap gap-1.5">
                          {% if plugin.hasAssets %}<a href="{{ plugin.assetsHref | escape }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">Assets</a>{% endif %}
                          {% if plugin.hasPageTypes %}<a href="{{ plugin.pageTypesHref | escape }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">Page types</a>{% endif %}
                          {% if plugin.hasLimits %}<a href="{{ plugin.limitsHref | escape }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">Limits</a>{% endif %}
                          {% if plugin.hasCredits %}<a href="{{ plugin.creditsHref | escape }}" class="inline-flex h-8 items-center justify-center rounded-md border border-gray-300 px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">Credits</a>{% endif %}
                        </div>
                      </div>
                    {% endif %}

                    <div class="mt-3 border-t border-gray-100 pt-2">
                      <div class="text-[0.65rem] font-semibold uppercase tracking-wider text-gray-400">Danger</div>
                      <form method="post" action="{{ plugin.deleteAction | escape }}" class="mt-1" data-confirm="Remove this plugin?">
                        <button type="submit" class="inline-flex h-8 items-center justify-center rounded-md border border-red-300 px-3 text-xs font-semibold text-red-700 hover:bg-red-50">Delete</button>
                      </form>
                    </div>
                  </div>
                </details>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="4" class="px-4 py-8 text-center text-sm text-gray-500">
              No plugins registered yet. <a class="text-indigo-600 font-medium" href="/admin/plugins-manage/new">Register one</a>.
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
