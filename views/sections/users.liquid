<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">{{ "view_strings.sections_users.users" | t }}</h2>
    <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_users.users_are_created_on_first_sign_in_assign_their_roles_here" | t }}</p>
  </div>
  {% if hasFlash %}
    <div data-users-alert class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">{{ flash | t }}</div>
  {% endif %}
  {% if hasError %}
    <div data-users-alert class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">{{ error }}</div>
  {% endif %}

  <div class="bg-white rounded-xl shadow-sm border border-gray-200">
    <div class="overflow-x-auto">
      <table class="w-full min-w-[680px] text-left" data-privacy-table>
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_users.name" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_users.email" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_users.identity" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_users.roles" | t }}</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasUsers %}
          {% for user in users %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900"><span data-private-field="name">{{ user.name }}</span></td>
              <td class="px-6 py-3 text-sm text-gray-500"><span data-private-field="email">{{ user.email }}</span></td>
              <td class="px-6 py-3">
                <div class="flex flex-wrap gap-1.5">
                  {% for provider in user.identityProviders %}
                    <span class="rounded-full border border-gray-200 bg-gray-50 px-2 py-0.5 text-xs font-medium text-gray-700">{{ provider.label }}</span>
                  {% endfor %}
                </div>
              </td>
              <td class="px-6 py-3 text-sm text-gray-700">
                {% for role in user.roles %}{% if role.labelKey %}{{ role.labelKey | t }}{% else %}{{ role.label }}{% endif %}{% unless forloop.last %}, {% endunless %}{% endfor %}
              </td>
              <td class="px-6 py-3 text-right">
                <div class="flex items-center justify-end gap-3">
                  <a href="{{ user.editHref }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{{ "view_strings.sections_users.roles_and_credits" | t }}</a>
                  {% if user.canDelete %}
                    <form method="POST" action="{{ user.deleteAction }}" data-confirm="{{ "view_strings.sections_users.remove_this_user_and_all_linked_sign_in_identities" | t }}">
                      <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-700">{{ "view_strings.sections_users.delete" | t }}</button>
                    </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="5" class="px-6 py-10 text-center text-gray-400">{{ "view_strings.sections_users.no_users_yet" | t }}</td></tr>
        {% endif %}
      </tbody>
      </table>
    </div>
  </div>

  <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
    <div class="mb-4">
      <h3 class="text-lg font-semibold text-gray-900">{{ "view_strings.sections_users.shared_credits" | t }}</h3>
      <p class="mt-1 text-sm text-gray-500">{{ "users.shared_pool_description" | t }}</p>
    </div>
    <p class="text-2xl font-bold text-gray-900">{{ sharedCreditBalance }}</p>

    <form method="POST" action="{{ sharedCreditAction }}"
          data-confirm="{{ "view_strings.sections_users.apply_this_shared_pool_adjustment" | t }}"
          class="mt-5 max-w-md space-y-3 border-t border-gray-100 pt-5">
      <h4 class="text-sm font-semibold text-gray-900">{{ "view_strings.sections_users.adjust_pool" | t }}</h4>
      <p class="text-xs text-gray-500">{{ "view_strings.sections_users.positive_grants_negative_deducts_the_pool_can_never_go_below_zero" | t }}</p>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_users.amount" | t }}</span>
        <input name="amount" type="number" step="1" required placeholder="e.g. 500 or -100"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_users.note" | t }}</span>
        <input name="note" type="text" maxlength="300" required placeholder="{{ "view_strings.sections_users.why_the_pool_is_changing" | t }}"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white hover:bg-indigo-700">{{ "view_strings.sections_users.adjust_pool" | t }}</button>
    </form>

    {% if hasSharedCreditLedger %}
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">{{ "view_strings.sections_users.when" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_users.action" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_users.change" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_users.balance" | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for entry in sharedCreditLedger %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3 text-xs text-gray-500">{{ entry.createdAt | l10n_date }}</td>
                <td class="px-4 py-3">
                  <span class="font-mono text-xs">{{ entry.action }}</span>
                  {% if entry.note != '' %}<div class="text-xs text-gray-500 mt-0.5">{{ entry.note }}</div>{% endif %}
                </td>
                <td class="px-4 py-3 text-sm {% if entry.isSpend %}text-red-700{% else %}text-green-700{% endif %}">{{ entry.delta }}</td>
                <td class="px-4 py-3 text-sm text-gray-700">{{ entry.balanceAfter }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    {% else %}
      <p class="mt-3 text-sm text-gray-500">{{ "view_strings.sections_users.no_shared_credit_activity_yet" | t }}</p>
    {% endif %}
  </div>
</div>

<script>
  document.querySelectorAll('[data-users-alert]').forEach((alert) => {
    setTimeout(() => alert.remove(), 4000);
  });
</script>
