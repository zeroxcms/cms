<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">Users</h2>
    <p class="mt-1 text-sm text-gray-500">Users are created on first sign-in. Assign their roles here.</p>
  </div>
  {% if hasFlash %}
    <div data-users-alert class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">{{ flash | escape }}</div>
  {% endif %}
  {% if hasError %}
    <div data-users-alert class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">{{ error | escape }}</div>
  {% endif %}
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[680px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Identity</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Roles</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasUsers %}
          {% for user in users %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">{{ user.name | escape }}</td>
              <td class="px-6 py-3 text-sm text-gray-500">{{ user.email | escape }}</td>
              <td class="px-6 py-3">
                <div class="flex flex-wrap gap-1.5">
                  {% for provider in user.identityProviders %}
                    <span class="rounded-full border border-gray-200 bg-gray-50 px-2 py-0.5 text-xs font-medium text-gray-700">{{ provider.label | escape }}</span>
                  {% endfor %}
                </div>
              </td>
              <td class="px-6 py-3 text-sm text-gray-700">{{ user.rolesLabel | escape }}</td>
              <td class="px-6 py-3 text-right">
                <div class="flex items-center justify-end gap-3">
                  <a href="{{ user.editHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">Edit roles</a>
                  {% if user.canDelete %}
                    <form method="POST" action="{{ user.deleteAction | escape }}" data-confirm="Remove this user and all linked sign-in identities?">
                      <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-700">Delete</button>
                    </form>
                  {% endif %}
                </div>
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="5" class="px-6 py-10 text-center text-gray-400">No users yet.</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>

<script>
  document.querySelectorAll('[data-users-alert]').forEach((alert) => {
    setTimeout(() => alert.remove(), 4000);
  });
</script>
