<div class="min-w-0 max-w-4xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">Profile</h2>
    <p class="mt-1 text-sm text-gray-500">Manage your CMS account and connected sign-in methods.</p>
  </div>

  {% if hasFlash %}
    <div data-profile-alert class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">{{ flash | escape }}</div>
  {% endif %}
  {% if hasError %}
    <div data-profile-alert class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">{{ error | escape }}</div>
  {% endif %}

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
      <div class="flex min-w-0 items-center gap-4">
        {% if hasAvatar %}
          <img src="{{ avatarUrl | escape }}"
               class="h-16 w-16 shrink-0 rounded-full object-cover"
               alt="avatar"
               data-avatar-img>
        {% else %}
          <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-indigo-500 text-2xl font-bold text-white">{{ initial | escape }}</div>
        {% endif %}
        <div class="min-w-0">
          <h3 class="truncate text-xl font-semibold text-gray-900">{{ name | escape }}</h3>
          <p class="truncate text-sm text-gray-500">{{ email | escape }}</p>
          <p class="mt-1 text-xs font-semibold uppercase tracking-wider text-gray-500">{{ roleLabel | escape }}</p>
        </div>
      </div>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">Connected identities</h3>
      <div class="mt-4 space-y-2">
        {% if hasIdentities %}
          {% for identity in identities %}
            <div class="flex min-w-0 items-center justify-between gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2">
              <div class="min-w-0">
                <p class="text-sm font-medium text-gray-900">{{ identity.label | escape }}</p>
                <p class="truncate text-xs text-gray-500">{{ identity.providerUserId | escape }}</p>
              </div>
              <div class="flex shrink-0 items-center gap-2">
                <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-800">Connected</span>
                {% if identity.canDisconnect %}
                  <form method="post"
                        action="{{ identity.disconnectHref | escape }}"
                        data-confirm="Disconnect this sign-in method?">
                    <button type="submit"
                            class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-red-200 bg-white text-red-600 hover:bg-red-50"
                            aria-label="Disconnect {{ identity.label | escape }}">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#trash"></use></svg>
                    </button>
                  </form>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          <p class="text-sm text-gray-500">No linked sign-in identities found.</p>
        {% endif %}
      </div>
    </section>
  </div>

  <section class="mt-4 bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
    <div class="mb-4">
      <h3 class="text-lg font-semibold text-gray-900">Sign-in methods</h3>
      <p class="mt-1 text-sm text-gray-500">Start a provider flow while signed in to attach it to this account.</p>
    </div>
    {% if hasProviders %}
      <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {% for provider in providers %}
          {% if provider.connected %}
            <div class="flex h-10 items-center justify-between rounded-lg border border-gray-200 bg-gray-50 px-3 text-sm">
              <span class="font-medium text-gray-900">{{ provider.label | escape }}</span>
              <span class="text-xs font-semibold text-green-700">Connected</span>
            </div>
          {% else %}
            <a href="{{ provider.connectHref | escape }}"
               class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-3 text-sm font-semibold text-gray-700 hover:bg-gray-50">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
              Connect {{ provider.label | escape }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <p class="text-sm text-gray-500">No OAuth providers are enabled.</p>
    {% endif %}
  </section>
</div>

<script>
  document.querySelectorAll('[data-profile-alert]').forEach((alert) => {
    setTimeout(() => alert.remove(), 4000);
  });
</script>
