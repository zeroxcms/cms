<div class="min-w-0 max-w-4xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="mb-6">
    <h2 class="text-2xl font-bold text-gray-900">{{ "profile.title" | t }}</h2>
    <p class="mt-1 text-sm text-gray-500">{{ "profile.description" | t }}</p>
  </div>

  <section class="mb-4 rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6">
    <form method="post" action="{{ uiLocaleAction }}" class="flex flex-col gap-3 sm:flex-row sm:items-end">
      <label class="flex-1 text-sm font-medium text-gray-700">{{ "profile.interface_language" | t }}
        <select name="locale" class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2">
          {% for option in uiLocaleOptions %}<option value="{{ option.code }}" {% if option.selected %}selected{% endif %}>{{ option.label }}</option>{% endfor %}
        </select>
      </label>
      <button class="h-10 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white">{{ "profile.save_language" | t }}</button>
    </form>
  </section>

  {% if hasFlash %}
    <div data-profile-alert class="mb-4 rounded-lg border border-green-200 bg-green-50 p-3 text-sm text-green-700">{{ flash | t }}</div>
  {% endif %}
  {% if hasError %}
    <div data-profile-alert class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">{{ error | t }}</div>
  {% endif %}

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
      <div class="flex min-w-0 items-center gap-4">
        {% if hasAvatar %}
          <img src="{{ avatarUrl }}"
               class="h-16 w-16 shrink-0 rounded-full object-cover"
               alt="{{ "profile.avatar" | t }}"
               data-avatar-img>
        {% else %}
          <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-indigo-500 text-2xl font-bold text-white">{{ initial }}</div>
        {% endif %}
        <div class="min-w-0">
          <h3 class="truncate text-xl font-semibold text-gray-900">{{ name }}</h3>
          <p class="truncate text-sm text-gray-500">{{ email }}</p>
          <p class="mt-1 text-xs font-semibold uppercase tracking-wider text-gray-500">{{ roleLabel }}</p>
        </div>
      </div>
    </section>

    <section class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">{{ "profile.connected_identities" | t }}</h3>
      <div class="mt-4 space-y-2">
        {% if hasIdentities %}
          {% for identity in identities %}
            <div class="flex min-w-0 items-center justify-between gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2">
              <div class="min-w-0">
                <p class="text-sm font-medium text-gray-900">{{ identity.label }}</p>
                <p class="truncate text-xs text-gray-500">{{ identity.providerUserId }}</p>
              </div>
              <div class="flex shrink-0 items-center gap-2">
                <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-800">{{ "common.connected" | t }}</span>
                {% if identity.canDisconnect %}
                  <form method="post"
                        action="{{ identity.disconnectHref }}"
                        data-confirm="{{ "profile.disconnect_confirm" | t }}">
                    <button type="submit"
                            class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-red-200 bg-white text-red-600 hover:bg-red-50"
                            aria-label="{{ "profile.disconnect" | t }} {{ identity.label }}">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#trash"></use></svg>
                    </button>
                  </form>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          <p class="text-sm text-gray-500">{{ "profile.no_identities" | t }}</p>
        {% endif %}
      </div>
    </section>
  </div>

  <section class="mt-4 bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
    <div class="mb-4">
      <h3 class="text-lg font-semibold text-gray-900">{{ "profile.sign_in_methods" | t }}</h3>
      <p class="mt-1 text-sm text-gray-500">{{ "profile.sign_in_description" | t }}</p>
    </div>
    {% if hasProviders %}
      <div class="grid grid-cols-1 gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {% for provider in providers %}
          {% if provider.connected %}
            <div class="flex h-10 items-center justify-between rounded-lg border border-gray-200 bg-gray-50 px-3 text-sm">
              <span class="font-medium text-gray-900">{{ provider.label }}</span>
              <span class="text-xs font-semibold text-green-700">{{ "common.connected" | t }}</span>
            </div>
          {% else %}
            <a href="{{ provider.connectHref }}"
               class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-3 text-sm font-semibold text-gray-700 hover:bg-gray-50">
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#plus"></use></svg>
              {{ "profile.connect" | t }} {{ provider.label }}
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <p class="text-sm text-gray-500">{{ "profile.no_oauth_providers" | t }}</p>
    {% endif %}
  </section>

  <section class="mt-4 bg-white rounded-xl shadow-sm border border-gray-200 p-5 sm:p-6">
    <div class="mb-4">
      <h3 class="text-lg font-semibold text-gray-900">{{ "profile.credits" | t }}</h3>
      <p class="mt-1 text-sm text-gray-500">{{ "profile.credits_description" | t }}</p>
    </div>
    <p class="text-2xl font-bold text-gray-900">{{ creditBalance }}</p>

    <form method="POST" action="{{ creditTransferAction }}"
          data-confirm="{{ "profile.send_confirm" | t }}"
          class="mt-5 max-w-md space-y-3 border-t border-gray-100 pt-5">
      <h4 class="text-sm font-semibold text-gray-900">{{ "profile.send_credits" | t }}</h4>
      <p class="text-xs text-gray-500">{{ "profile.transfer_description" | t }}</p>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "profile.recipient_email" | t }}</span>
        <input name="recipient" type="email" required autocomplete="off" placeholder="user@example.com"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "common.amount" | t }}</span>
        <input name="amount" type="number" step="1" min="1" required placeholder="e.g. 100"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "common.note" | t }} <span class="text-gray-400">({{ "common.optional" | t }})</span></span>
        <input name="note" type="text" maxlength="300" placeholder="{{ "profile.transfer_note_placeholder" | t }}"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white hover:bg-indigo-700">{{ "profile.send_credits" | t }}</button>
    </form>

    <form method="POST" action="{{ sharedDonateAction }}"
          data-confirm="{{ "profile.donate_confirm" | t }}"
          class="mt-5 max-w-md space-y-3 border-t border-gray-100 pt-5">
      <h4 class="text-sm font-semibold text-gray-900">{{ "profile.donate_title" | t }}</h4>
      <p class="text-xs text-gray-500">
        {{ "profile.shared_pool_balance" | t }}: <span class="font-semibold text-gray-900">{{ sharedCreditBalance }}</span>.
        {{ "profile.shared_pool_description" | t }}
      </p>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "common.amount" | t }}</span>
        <input name="amount" type="number" step="1" min="1" required placeholder="e.g. 100"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <label class="block">
        <span class="block text-sm font-medium text-gray-700 mb-1">{{ "common.note" | t }} <span class="text-gray-400">({{ "common.optional" | t }})</span></span>
        <input name="note" type="text" maxlength="300" placeholder="{{ "profile.donation_note_placeholder" | t }}"
               class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      </label>
      <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white hover:bg-indigo-700">{{ "profile.donate_to_pool" | t }}</button>
    </form>

    {% if hasCreditLedger %}
      <div class="mt-4 overflow-x-auto">
        <table class="w-full min-w-[560px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">{{ "common.when" | t }}</th>
              <th class="px-4 py-2">{{ "common.action" | t }}</th>
              <th class="px-4 py-2">{{ "common.change" | t }}</th>
              <th class="px-4 py-2">{{ "common.balance" | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for entry in creditLedger %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3 text-xs text-gray-500">{{ entry.createdAt | l10n_date }}</td>
                <td class="px-4 py-3">
                  <span class="font-mono text-xs">{{ entry.action }}</span>
                  {% if entry.note != '' %}<div class="text-xs text-gray-500 mt-0.5">{{ entry.note }}</div>{% endif %}
                </td>
                <td class="px-4 py-3 text-sm {% if entry.isSpend %}text-red-700{% else %}text-green-700{% endif %}">{{ entry.delta }}</td>
                <td class="px-4 py-3 text-sm text-gray-700">{{ entry.balanceAfter }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      {% if showCreditLedgerPagination %}
        <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-gray-100 pt-4">
          <p class="text-sm text-gray-500">
            {{ "profile.showing" | t }} {{ creditLedgerPagination.from }}-{{ creditLedgerPagination.to }} {{ "profile.showing_of" | t }} {{ creditLedgerPagination.total }}
          </p>
          <div class="flex items-center gap-2">
            {% if creditLedgerPagination.hasPrevious %}
              <a href="{{ creditLedgerPagination.previousHref }}"
                 class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#arrow-left"></use></svg>
                {{ "common.previous" | t }}
              </a>
            {% else %}
              <span class="inline-flex h-9 cursor-not-allowed items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-50 px-3 text-xs font-semibold text-gray-400">
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#arrow-left"></use></svg>
                {{ "common.previous" | t }}
              </span>
            {% endif %}
            <span class="text-xs font-medium text-gray-500">{{ "profile.pagination_page" | t }} {{ creditLedgerPagination.page }} {{ "profile.pagination_of" | t }} {{ creditLedgerPagination.pageCount }}</span>
            {% if creditLedgerPagination.hasNext %}
              <a href="{{ creditLedgerPagination.nextHref }}"
                 class="inline-flex h-9 items-center justify-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3 text-xs font-semibold text-gray-700 hover:bg-gray-50">
                {{ "common.next" | t }}
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#chevron-right"></use></svg>
              </a>
            {% else %}
              <span class="inline-flex h-9 cursor-not-allowed items-center justify-center gap-1.5 rounded-lg border border-gray-200 bg-gray-50 px-3 text-xs font-semibold text-gray-400">
                {{ "common.next" | t }}
                <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#chevron-right"></use></svg>
              </span>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% else %}
      <p class="mt-3 text-sm text-gray-500">{{ "profile.no_credit_activity" | t }}</p>
    {% endif %}
  </section>
</div>

<script>
  document.querySelectorAll('[data-profile-alert]').forEach((alert) => {
    setTimeout(() => alert.remove(), 4000);
  });
</script>
