<div class="min-w-0 max-w-xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-6">{{ heading | escape }}</h2>
  {% if readOnly %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-600">You don't have permission to edit taxonomies.</div>
  {% endif %}
  <form id="taxonomy-form" method="POST" action="{{ action | escape }}" class="min-w-0 space-y-4">
    <label for="taxonomy_name" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Name</span>
      <input id="taxonomy_name" name="name" required value="{{ name | escape }}"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm{% if readOnly %} bg-gray-50 text-gray-600{% endif %}">
    </label>
    <label for="taxonomy_slug" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Slug</span>
      <input id="taxonomy_slug" name="slug" value="{{ slug | escape }}"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm{% if readOnly %} bg-gray-50 text-gray-600{% endif %}">
    </label>
  </form>
  {% if isEdit %}{% unless readOnly %}
    <form id="taxonomy-delete-form" method="POST" action="{{ deleteAction | escape }}" data-confirm="Delete this taxonomy? Its tags are kept but no longer grouped under it."></form>
  {% endunless %}{% endif %}
  <div class="mt-4 flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
    {% unless readOnly %}<button form="taxonomy-form" type="submit" class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">Save</button>{% endunless %}
    <a href="/admin/taxonomies" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{% if readOnly %}Back{% else %}Cancel{% endif %}</a>
    {% if isEdit %}{% unless readOnly %}
      <button form="taxonomy-delete-form" type="submit" class="w-full px-6 py-2 bg-red-600 text-white text-sm font-semibold rounded-lg hover:bg-red-700 transition-colors shadow-sm sm:ml-auto sm:w-auto">Delete</button>
    {% endunless %}{% endif %}
  </div>
</div>
