<div class="min-w-0 max-w-xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <h2 class="text-2xl font-bold text-gray-900 mb-6">{{ heading | escape }}</h2>
  {% if readOnly %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-600">You don't have permission to edit taxonomies.</div>
  {% endif %}
  <form method="POST" action="{{ action | escape }}" class="min-w-0 space-y-4">
    <label for="taxonomy_name" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Name</span>
      <input id="taxonomy_name" name="name" required value="{{ name | escape }}"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm{% if readOnly %} bg-gray-50 text-gray-600{% endif %}">
    </label>
    <label for="taxonomy_slug" class="block min-w-0">
      <span class="block text-sm font-medium text-gray-700 mb-1">Slug</span>
      <input id="taxonomy_slug" name="slug" value="{{ slug | escape }}"{% if readOnly %} readonly{% endif %} class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm{% if readOnly %} bg-gray-50 text-gray-600{% endif %}">
    </label>
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      {% unless readOnly %}<button type="submit" class="w-full shrink-0 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg sm:w-auto">Save</button>{% endunless %}
      <a href="/admin/taxonomies" class="w-full shrink-0 px-4 py-2 text-center bg-white border border-gray-300 rounded-lg text-sm font-semibold sm:w-auto">{% if readOnly %}Back{% else %}Cancel{% endif %}</a>
    </div>
  </form>
  {% if isEdit %}{% unless readOnly %}
    <form method="POST" action="{{ deleteAction | escape }}">
      <button type="submit" class="w-full px-4 py-2 text-sm font-semibold text-red-600 sm:w-auto">Delete</button>
    </form>
  {% endunless %}{% endif %}
</div>
