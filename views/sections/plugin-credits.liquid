<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">← Plugins</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel }} · Credits</h2>
      <p class="mt-1 text-sm text-gray-500">Chargeable actions this plugin declares. Prices set here are deducted from the acting user's credit balance and logged in the credit ledger. Leave a value blank to use the plugin default; enter 0 to make an action free.</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessage }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      This plugin is not reachable right now, so its declared credit costs can't be listed.
    </div>
  {% else %}
    <form method="post" action="{{ saveAction }}">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
        <table class="w-full min-w-[680px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">Action</th>
              <th class="px-4 py-2">Charged</th>
              <th class="px-4 py-2">Effective price</th>
              <th class="px-4 py-2">Configure</th>
            </tr>
          </thead>
          <tbody>
            {% if hasCredits %}
              {% for credit in credits %}
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900">{{ credit.label }}</div>
                    <div class="text-xs text-gray-400 mt-0.5 font-mono">{{ credit.key }}</div>
                    {% if credit.description != '' %}<div class="text-xs text-gray-500 mt-0.5">{{ credit.description }}</div>{% endif %}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">{{ credit.chargeLabel }}</td>
                  <td class="px-4 py-3">
                    <div class="text-sm text-gray-700">{{ credit.effectiveLabel }}</div>
                    <div class="text-xs text-gray-400 mt-0.5">Default: {{ credit.defaultLabel }}</div>
                  </td>
                  <td class="px-4 py-3">
                    <input name="value_{{ credit.key }}" type="number" min="0" step="1" value="{{ credit.value }}" placeholder="Default"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                  </td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="4" class="px-4 py-8 text-center text-sm text-gray-500">This plugin declares no chargeable actions.</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
      {% if hasCredits %}
        <div class="mt-4">
          <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Save prices</button>
        </div>
      {% endif %}
    </form>
  {% endif %}
</div>
