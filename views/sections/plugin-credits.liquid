<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "view_strings.sections_plugin_credits.plugins" | t }}</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel }} · {{ "view_strings.sections_plugin_credits.credits" | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugin_credits.chargeable_actions_this_plugin_declares_prices_set_here_are_deducted_fro" | t }}</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessageKey | t }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      {{ "view_strings.sections_plugin_credits.this_plugin_is_not_reachable_right_now_so_its_declared_credit_costs_can_" | t }}
    </div>
  {% else %}
    <form method="post" action="{{ saveAction }}">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
        <table class="w-full min-w-[680px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_credits.action" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_credits.charged" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_credits.effective_price" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_credits.configure" | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% if hasCredits %}
              {% for credit in credits %}
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900">{{ credit.label }}</div>
                    <div class="text-xs text-gray-400 mt-0.5 font-mono">{{ credit.key }}</div>
                    {% if credit.description != '' %}<div class="text-xs text-gray-500 mt-0.5">{{ credit.description }}</div>{% endif %}
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">{{ credit.chargeKey | t }} {{ credit.chargeDetail }}</td>
                  <td class="px-4 py-3">
                    <div class="text-sm text-gray-700">{% if credit.effectiveKey != '' %}{{ credit.effectiveKey | t }}{% else %}{{ credit.effectiveLabel }}{% endif %}{% if credit.usesDefault %} ({{ "view_strings.sections_plugin_credits.default" | t }}){% endif %}</div>
                    <div class="text-xs text-gray-400 mt-0.5">{{ "view_strings.sections_plugin_credits.default" | t }}: {% if credit.defaultKey != '' %}{{ credit.defaultKey | t }}{% else %}{{ credit.defaultLabel }}{% endif %}</div>
                  </td>
                  <td class="px-4 py-3">
                    <input name="value_{{ credit.key }}" type="number" min="0" step="1" value="{{ credit.value }}" placeholder="{{ "view_strings.sections_plugin_credits.default" | t }}"
                           class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
                  </td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="4" class="px-4 py-8 text-center text-sm text-gray-500">{{ "view_strings.sections_plugin_credits.this_plugin_declares_no_chargeable_actions" | t }}</td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
      {% if hasCredits %}
        <div class="mt-4">
          <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">{{ "view_strings.sections_plugin_credits.save_prices" | t }}</button>
        </div>
      {% endif %}
    </form>
  {% endif %}
</div>
