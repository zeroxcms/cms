<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Page Types</h2>
      <p class="mt-1 text-sm text-gray-500">Database page types are editable here; config-file and plugin page types are read-only.</p>
    </div>
    {% if canWrite %}
      <a href="/admin/page_types/new"
         title="New Page Type"
         aria-label="New Page Type"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#plus"></use></svg>
        <span class="hidden lg:inline">New Page Type</span>
      </a>
    {% endif %}
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Slug</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Source</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasPageTypes %}
          {% for pageType in pageTypes %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">{{ pageType.name | escape }}</td>
              <td class="px-6 py-3 text-sm font-mono text-gray-500">{{ pageType.slug | escape }}</td>
              <td class="px-6 py-3 text-sm">
                {% if pageType.source == 'db' %}
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-700">db</span>
                {% elsif pageType.source == 'plugin' %}
                  <span data-page-type-plugin="{{ pageType.slug | escape }}" class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 text-emerald-700">plugin{% if pageType.pluginName %} ({{ pageType.pluginName | escape }}){% endif %}</span>
                {% else %}
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">config</span>
                {% endif %}
              </td>
              <td class="px-6 py-3 text-right">
                {% if pageType.isDb %}
                  <a href="{{ pageType.editHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{% if canWrite %}Edit{% else %}View{% endif %}</a>
                {% else %}
                  <a href="{{ pageType.viewHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">View</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="4" class="px-6 py-10 text-center text-gray-400">No page types yet.</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
