<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref | escape }}">← Plugins</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel | escape }} · Page types</h2>
      <p class="mt-1 text-sm text-gray-500">Delegated page-type access this plugin requests through readTypes and writeTypes. Approving a scope lets the plugin use it through the CMS API.</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessage | escape }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      This plugin is not reachable right now, so its requested page-type access can't be listed.
    </div>
  {% else %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
      <table class="w-full min-w-[680px] text-left text-sm">
        <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
          <tr>
            <th class="px-4 py-2">Page type</th>
            <th class="px-4 py-2">Read</th>
            <th class="px-4 py-2">Write</th>
          </tr>
        </thead>
        <tbody>
          {% if hasPageTypes %}
            {% for pageType in pageTypes %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900{% unless pageType.pageType == '*' %} font-mono{% endunless %}">{{ pageType.pageTypeLabel | escape }}</div>
                  {% if pageType.pageType == '*' %}
                    <div class="text-xs text-gray-400 mt-0.5">Wildcard scope</div>
                  {% endif %}
                </td>
                <td class="px-4 py-3">
                  {% if pageType.readDeclared %}
                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ pageType.readStatusClass | escape }}">{{ pageType.readStatusLabel | escape }}</span>
                    {% if pageType.readApproved %}
                      <div class="text-xs text-gray-400 mt-0.5">Approved by {{ pageType.readApprovedBy | escape }}</div>
                      <form method="post" action="{{ pageType.revokeReadAction | escape }}" class="mt-2 inline" data-confirm="Revoke read access to {{ pageType.pageTypeLabel | escape }}?">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType | escape }}">
                        <input type="hidden" name="access" value="read">
                        <button type="submit" class="px-3 py-1 rounded-lg border border-red-300 text-xs font-semibold text-red-700">Revoke</button>
                      </form>
                    {% else %}
                      <form method="post" action="{{ pageType.approveReadAction | escape }}" class="mt-2 inline">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType | escape }}">
                        <input type="hidden" name="access" value="read">
                        <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Approve</button>
                      </form>
                    {% endif %}
                  {% else %}
                    <span class="text-xs text-gray-400">Not requested</span>
                  {% endif %}
                </td>
                <td class="px-4 py-3">
                  {% if pageType.writeDeclared %}
                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ pageType.writeStatusClass | escape }}">{{ pageType.writeStatusLabel | escape }}</span>
                    {% if pageType.writeApproved %}
                      <div class="text-xs text-gray-400 mt-0.5">Approved by {{ pageType.writeApprovedBy | escape }}</div>
                      <form method="post" action="{{ pageType.revokeWriteAction | escape }}" class="mt-2 inline" data-confirm="Revoke write access to {{ pageType.pageTypeLabel | escape }}?">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType | escape }}">
                        <input type="hidden" name="access" value="write">
                        <button type="submit" class="px-3 py-1 rounded-lg border border-red-300 text-xs font-semibold text-red-700">Revoke</button>
                      </form>
                    {% else %}
                      <form method="post" action="{{ pageType.approveWriteAction | escape }}" class="mt-2 inline">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType | escape }}">
                        <input type="hidden" name="access" value="write">
                        <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">Approve</button>
                      </form>
                    {% endif %}
                  {% else %}
                    <span class="text-xs text-gray-400">Not requested</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="3" class="px-4 py-8 text-center text-sm text-gray-500">This plugin declares no delegated page-type access.</td>
            </tr>
          {% endif %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
