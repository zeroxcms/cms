<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">{{ "view_strings.sections_plugin_page_types.plugins" | t }}</a>
      <h2 class="text-2xl font-bold text-gray-900">{{ pluginLabel }} · {{ "view_strings.sections_plugin_page_types.page_types" | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugin_page_types.page_types_and_taxonomies_this_plugin_defines_plus_delegated_page_type_a" | t }}</p>
    </div>
  </div>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessageKey | t }}</div>
  {% endif %}

  {% if unreachable %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 text-sm text-gray-500">
      {{ "view_strings.sections_plugin_page_types.this_plugin_is_not_reachable_right_now_so_its_page_types_and_taxonomies_" | t }}
    </div>
  {% else %}
    {% if hasDefinedPageTypes %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200">
      <div class="flex items-center justify-between gap-4" style="padding:1rem 1rem 0;margin-bottom:.75rem">
        <div>
          <h3 class="text-lg font-bold text-gray-900">{{ "view_strings.sections_plugin_page_types.defined_page_types" | t }}</h3>
          <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugin_page_types.page_types_contributed_by_this_plugin_through_contenttypes_blueprint" | t }}</p>
        </div>
      </div>
      <div class="overflow-x-auto w-full">
        <table class="w-full min-w-[560px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_page_types.page_type" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_page_types.fields" | t }}</th>
              <th class="px-4 py-2"></th>
            </tr>
          </thead>
          <tbody>
            {% for pageType in definedPageTypes %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3 font-medium text-gray-900 font-mono">{{ pageType.slug }}</td>
                <td class="px-4 py-3 text-gray-500">{{ pageType.fieldCount }}</td>
                <td class="px-4 py-3 text-right">
                  <a href="{{ pageType.viewHref }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{{ "view_strings.sections_plugin_page_types.view" | t }}</a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endif %}

    {% if hasDefinedTaxonomies %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 mt-4">
      <div class="flex items-center justify-between gap-4" style="padding:1rem 1rem 0;margin-bottom:.75rem">
        <div>
          <h3 class="text-lg font-bold text-gray-900">{{ "view_strings.sections_plugin_page_types.defined_taxonomies" | t }}</h3>
          <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugin_page_types.taxonomies_contributed_by_this_plugin_through_contenttypes_taxonomies" | t }}</p>
        </div>
      </div>
      <div class="overflow-x-auto w-full">
        <table class="w-full min-w-[560px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_page_types.name" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_page_types.slug" | t }}</th>
              <th class="px-4 py-2"></th>
            </tr>
          </thead>
          <tbody>
            {% for taxonomy in definedTaxonomies %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3 font-medium text-gray-900">{{ taxonomy.name }}</td>
                <td class="px-4 py-3 text-gray-500 font-mono">{{ taxonomy.slug }}</td>
                <td class="px-4 py-3 text-right">
                  <a href="{{ taxonomy.viewHref }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{{ "view_strings.sections_plugin_page_types.view" | t }}</a>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endif %}

    {% if hasPageTypes %}
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 mt-4">
      <div class="flex items-center justify-between gap-4" style="padding:1rem 1rem 0;margin-bottom:.75rem">
        <div>
          <h3 class="text-lg font-bold text-gray-900">{{ "view_strings.sections_plugin_page_types.delegated_access" | t }}</h3>
          <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_plugin_page_types.access_requested_through_readtypes_and_writetypes_approving_a_scope_lets" | t }}</p>
        </div>
      </div>
      <div class="overflow-x-auto w-full">
        <table class="w-full min-w-[680px] text-left text-sm">
          <thead class="bg-gray-50 text-left text-xs uppercase text-gray-500">
            <tr>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_page_types.page_type" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_page_types.read" | t }}</th>
              <th class="px-4 py-2">{{ "view_strings.sections_plugin_page_types.write" | t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for pageType in pageTypes %}
              <tr class="border-t border-gray-100">
                <td class="px-4 py-3">
                  <div class="font-medium text-gray-900{% unless pageType.pageType == '*' %} font-mono{% endunless %}">{% if pageType.pageTypeLabelKey != '' %}{{ pageType.pageTypeLabelKey | t }}{% else %}{{ pageType.pageTypeLabel }}{% endif %}</div>
                  {% if pageType.pageType == '*' %}
                    <div class="text-xs text-gray-400 mt-0.5">{{ "view_strings.sections_plugin_page_types.wildcard_scope" | t }}</div>
                  {% endif %}
                </td>
                <td class="px-4 py-3">
                  {% if pageType.readDeclared %}
                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ pageType.readStatusClass }}">{{ pageType.readStatusKey | t }}</span>
                    {% if pageType.readApproved %}
                      <div class="text-xs text-gray-400 mt-0.5">{{ "view_strings.sections_plugin_page_types.approved_by" | t }} {{ pageType.readApprovedBy }}</div>
                      <form method="post" action="{{ pageType.revokeReadAction }}" class="mt-2 inline" data-confirm="{{ "view_strings.sections_plugin_page_types.revoke_read_confirmation" | t }}">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType }}">
                        <input type="hidden" name="access" value="read">
                        <button type="submit" class="px-3 py-1 rounded-lg border border-red-300 text-xs font-semibold text-red-700">{{ "view_strings.sections_plugin_page_types.revoke" | t }}</button>
                      </form>
                    {% else %}
                      <form method="post" action="{{ pageType.approveReadAction }}" class="mt-2 inline">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType }}">
                        <input type="hidden" name="access" value="read">
                        <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">{{ "view_strings.sections_plugin_page_types.approve" | t }}</button>
                      </form>
                    {% endif %}
                  {% else %}
                    <span class="text-xs text-gray-400">{{ "view_strings.sections_plugin_page_types.not_requested" | t }}</span>
                  {% endif %}
                </td>
                <td class="px-4 py-3">
                  {% if pageType.writeDeclared %}
                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold {{ pageType.writeStatusClass }}">{{ pageType.writeStatusKey | t }}</span>
                    {% if pageType.writeApproved %}
                      <div class="text-xs text-gray-400 mt-0.5">{{ "view_strings.sections_plugin_page_types.approved_by" | t }} {{ pageType.writeApprovedBy }}</div>
                      <form method="post" action="{{ pageType.revokeWriteAction }}" class="mt-2 inline" data-confirm="{{ "view_strings.sections_plugin_page_types.revoke_write_confirmation" | t }}">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType }}">
                        <input type="hidden" name="access" value="write">
                        <button type="submit" class="px-3 py-1 rounded-lg border border-red-300 text-xs font-semibold text-red-700">{{ "view_strings.sections_plugin_page_types.revoke" | t }}</button>
                      </form>
                    {% else %}
                      <form method="post" action="{{ pageType.approveWriteAction }}" class="mt-2 inline">
                        <input type="hidden" name="page_type" value="{{ pageType.pageType }}">
                        <input type="hidden" name="access" value="write">
                        <button type="submit" class="px-3 py-1 rounded-lg bg-indigo-600 text-xs font-semibold text-white">{{ "view_strings.sections_plugin_page_types.approve" | t }}</button>
                      </form>
                    {% endif %}
                  {% else %}
                    <span class="text-xs text-gray-400">{{ "view_strings.sections_plugin_page_types.not_requested" | t }}</span>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
    {% endif %}
  {% endif %}
</div>
