<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-4 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Block Types</h2>
      <p class="mt-1 text-sm text-gray-500">Reusable block definitions. Database blocks are editable here; config-file and plugin blocks are read-only.</p>
    </div>
    {% if canWrite %}<a href="/admin/block_types/new" class="w-full px-4 py-2 text-center bg-indigo-600 text-white text-sm font-semibold rounded-lg sm:w-auto">New Block Type</a>{% endif %}
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Slug</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Source</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasBlockTypes %}
          {% for blockType in blockTypes %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">{{ blockType.name | escape }}</td>
              <td class="px-6 py-3 text-sm font-mono text-gray-500">{{ blockType.slug | escape }}</td>
              <td class="px-6 py-3 text-sm">
                {% if blockType.source == 'db' %}
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-700">db</span>
                {% elsif blockType.source == 'plugin' %}
                  <span data-block-type-plugin="{{ blockType.slug | escape }}" class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 text-emerald-700">plugin{% if blockType.pluginName %} ({{ blockType.pluginName | escape }}){% endif %}</span>
                {% else %}
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">config</span>
                {% endif %}
              </td>
              <td class="px-6 py-3 text-right">
                {% if blockType.isDb %}
                  <a href="{{ blockType.editHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{% if canWrite %}Edit{% else %}View{% endif %}</a>
                {% else %}
                  <a href="{{ blockType.viewHref | escape }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">View</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="4" class="px-6 py-10 text-center text-gray-400">No block types yet.</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
