<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">{{ "view_strings.sections_credit_summary.credit_summary" | t }}</h1>
      <p class="mt-1 text-sm text-gray-500">{{ "view_strings.sections_credit_summary.all_chargeable_actions_declared_by_enabled_plugins_and_the_prices_curren" | t }}</p>
    </div>
    {% if canConfigure %}
    <a href="/admin/plugins-manage"
       title="{{ "view_strings.sections_credit_summary.manage_plugins" | t }}"
       aria-label="{{ "view_strings.sections_credit_summary.manage_plugins" | t }}"
       class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#beaker"></use></svg>
      <span class="hidden lg:inline">{{ "view_strings.sections_credit_summary.manage_plugins" | t }}</span>
    </a>
    {% endif %}
  </div>

  <div class="mb-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_credit_summary.plugins_with_charges" | t }}</p>
      <p class="mt-2 text-2xl font-bold text-gray-900">{{ pluginCount }}</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_credit_summary.chargeable_actions" | t }}</p>
      <p class="mt-2 text-2xl font-bold text-gray-900">{{ chargeCount }}</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{{ "view_strings.sections_credit_summary.paid_actions" | t }}</p>
      <p class="mt-2 text-2xl font-bold text-gray-900">{{ paidCount }}</p>
    </div>
  </div>

  <h2 class="mb-3 text-lg font-semibold text-gray-900">{{ "view_strings.sections_credit_summary.chargeable_actions" | t }}</h2>
  <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-x-auto">
    <table class="w-full min-w-[720px] text-left text-sm">
      <thead class="border-b border-gray-200 bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
        <tr>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.plugin" | t }}</th>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.action" | t }}</th>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.charged" | t }}</th>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.effective_price" | t }}</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasRows %}
          {% for row in rows %}
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{{ row.pluginLabel }}</div>
                <div class="mt-0.5 text-xs font-mono text-gray-400">{{ row.pluginId }}</div>
              </td>
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{{ row.label }}</div>
                <div class="mt-0.5 text-xs font-mono text-gray-400">{{ row.key }}</div>
                {% if row.description != '' %}<div class="mt-0.5 text-xs text-gray-500">{{ row.description }}</div>{% endif %}
              </td>
              <td class="px-4 py-3 text-gray-700">{{ row.chargeKey | t }} {{ row.chargeValue }}</td>
              <td class="px-4 py-3 font-medium text-gray-900">{% if row.effectiveFree %}{{ "credits.summary.free" | t }}{% else %}{{ row.effectiveValue }} {{ "credits.summary.credits" | t }}{% endif %}</td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                {% if canConfigure %}
                <a href="{{ row.manageHref }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{{ "view_strings.sections_credit_summary.configure" | t }}</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="5" class="px-4 py-10 text-center text-sm text-gray-500">{{ "view_strings.sections_credit_summary.no_enabled_plugin_declares_chargeable_actions" | t }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>

  <h2 class="mb-3 mt-8 text-lg font-semibold text-gray-900">{{ "view_strings.sections_credit_summary.usage_limits" | t }}</h2>
  <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-x-auto">
    <table class="w-full min-w-[720px] text-left text-sm">
      <thead class="border-b border-gray-200 bg-gray-50 text-xs uppercase tracking-wider text-gray-500">
        <tr>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.plugin" | t }}</th>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.limit" | t }}</th>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.scope" | t }}</th>
          <th class="px-4 py-3 font-semibold">{{ "view_strings.sections_credit_summary.effective_limit" | t }}</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasLimitRows %}
          {% for row in limitRows %}
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{{ row.pluginLabel }}</div>
                <div class="mt-0.5 text-xs font-mono text-gray-400">{{ row.pluginId }}</div>
              </td>
              <td class="px-4 py-3">
                <div class="font-medium text-gray-900">{{ row.label }}</div>
                <div class="mt-0.5 text-xs font-mono text-gray-400">{{ row.key }}</div>
                {% if row.description != '' %}<div class="mt-0.5 text-xs text-gray-500">{{ row.description }}</div>{% endif %}
              </td>
              <td class="px-4 py-3 text-gray-700">{{ row.scopeKey | t }}{% if row.scopeValue != '' %} {{ row.scopeValue }}{% endif %}</td>
              <td class="px-4 py-3 font-medium text-gray-900">{% if row.effectiveUnlimited %}{{ "credits.summary.unlimited" | t }}{% else %}{{ row.effectiveValue }}{% endif %}</td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                {% if canConfigure %}
                <a href="{{ row.manageHref }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{{ "view_strings.sections_credit_summary.configure" | t }}</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="5" class="px-4 py-10 text-center text-sm text-gray-500">{{ "view_strings.sections_credit_summary.no_enabled_plugin_declares_usage_limits" | t }}</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
