<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-50 to-blue-100 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-600 shadow-lg mb-4">
        <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#document"></use></svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">{{ siteTitle | escape }}</h1>
      <p class="mt-2 text-gray-500">Sign in to manage your content</p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl p-6 sm:p-8">
      {% if error %}
        <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-700">
          {% if isForbidden %}
            You do not have permission to access the admin panel.
          {% else %}
            Authentication error: {{ error | escape }}
          {% endif %}
        </div>
      {% endif %}

      <div class="flex flex-col gap-3">
        {% for provider in providers %}
          <a href="{{ provider.href | escape }}"
             class="flex items-center justify-center gap-3 w-full px-4 py-3 rounded-xl border-2 {{ provider.buttonClass }} font-semibold transition-all duration-150 group">
            <span class="{{ provider.iconClass }} transition-colors">{{ provider.icon }}</span>
            Continue with {{ provider.label | escape }}
          </a>
        {% endfor %}
      </div>

      <p class="mt-6 text-center text-xs text-gray-400">
        Only users with <strong>admin</strong>, <strong>editor</strong>, or
        <strong>moderator</strong> roles can access the CMS.
      </p>
    </div>
  </div>
</div>
