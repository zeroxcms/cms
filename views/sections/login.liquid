<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-50 to-blue-100 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-600 shadow-lg mb-4">
        <svg class="w-9 h-9 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix | escape }}#document"></use></svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 sm:text-3xl">{{ siteTitle | escape }}</h1>
      <p class="mt-2 text-gray-500">Sign in to manage your content</p>
    </div>

    <div class="bg-white rounded-2xl shadow-xl p-6 sm:p-8">
      {% if error %}
        <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-3 text-sm text-red-700">
          {% if isForbidden %}
            You do not have permission to access the admin panel.
          {% else %}
            Authentication error: {{ error | escape }}
          {% endif %}
        </div>
      {% endif %}

      <div class="flex flex-col gap-3">
        {% for provider in providers %}
          <a href="{{ provider.href | escape }}"
             data-auth-provider
             data-provider-label="{{ provider.label | escape }}"
             class="flex items-center justify-center gap-3 w-full px-4 py-3 rounded-xl border-2 {{ provider.buttonClass }} font-semibold transition-all duration-150 group">
            <span class="{{ provider.iconClass }} transition-colors">{{ provider.icon }}</span>
            <span data-auth-provider-text>Continue with {{ provider.label | escape }}</span>
          </a>
        {% endfor %}
      </div>

      <div class="mt-4 hidden items-center justify-center gap-2 rounded-lg bg-indigo-50 px-3 py-2 text-sm font-medium text-indigo-700"
           role="status"
           aria-live="polite"
           data-auth-loading-message>
        <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v4a4 4 0 0 0-4 4H4z"></path>
        </svg>
        <span data-auth-loading-text>Connecting...</span>
      </div>

      <p class="mt-6 text-center text-xs text-gray-400">
        Only users with <strong>admin</strong>, <strong>editor</strong>, or
        <strong>moderator</strong> roles can access the CMS.
      </p>
    </div>
  </div>
</div>

<script nonce="{{ nonce }}">
  (function() {
    function bindAuthLoading() {
      var links = Array.from(document.querySelectorAll('[data-auth-provider]'));
      var message = document.querySelector('[data-auth-loading-message]');
      var messageText = document.querySelector('[data-auth-loading-text]');
      if (!links.length || !(message instanceof HTMLElement)) return;
      if (message.dataset.authLoadingBound === '1') return;
      message.dataset.authLoadingBound = '1';

      links.forEach(function(link) {
        if (!(link instanceof HTMLAnchorElement)) return;
        link.addEventListener('click', function(event) {
          if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
          if (link.getAttribute('aria-disabled') === 'true') {
            event.preventDefault();
            return;
          }

          var label = link.dataset.providerLabel || 'your sign-in provider';
          var text = link.querySelector('[data-auth-provider-text]');
          if (text) text.textContent = 'Connecting to ' + label + '...';
          if (messageText) messageText.textContent = 'Redirecting to ' + label + ' for sign in...';
          message.classList.remove('hidden');
          message.classList.add('flex');

          links.forEach(function(otherLink) {
            if (!(otherLink instanceof HTMLAnchorElement)) return;
            otherLink.setAttribute('aria-disabled', 'true');
            otherLink.tabIndex = -1;
            otherLink.classList.add('pointer-events-none');
            if (otherLink !== link) {
              otherLink.setAttribute('aria-hidden', 'true');
              otherLink.classList.add('hidden');
            }
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bindAuthLoading);
    } else {
      bindAuthLoading();
    }
  })();
</script>
