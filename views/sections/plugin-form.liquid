<div class="max-w-2xl mx-auto px-4 py-6">
  <h1 class="text-2xl font-bold text-gray-900 mb-4">{{ headingKey | t }}</h1>

  {% if hasFlash %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-amber-50 text-amber-800 text-sm">{{ flashMessageKey | t }}</div>
  {% endif %}

  {% if hasError %}
    <div class="mb-4 px-4 py-2 rounded-lg bg-red-50 text-red-700 text-sm">{{ error }}</div>
  {% endif %}

  <form method="post" action="{{ action }}" class="bg-white rounded-xl shadow p-6 space-y-4">
    <label class="block">
      <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_plugin_form.base_url" | t }}</span>
      <input name="url" type="url" required value="{{ url }}" placeholder="{{ "view_strings.sections_plugin_form.https_cms_plugin_contacts_example_workers_dev" | t }}"
             class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
      <span class="block text-xs text-gray-500 mt-1">{{ "view_strings.sections_plugin_form.the_cms_calls" | t }} <code>{url}/__plugin/...</code>{{ "view_strings.sections_plugin_form.must_be_https_or_http_localhost_for_dev" | t }}</span>
    </label>

    <label class="block">
      <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_plugin_form.label" | t }} <span class="text-gray-400">{{ "view_strings.sections_plugin_form.optional" | t }}</span></span>
      <input name="label" type="text" value="{{ label }}" placeholder="{{ "view_strings.sections_plugin_form.shown_until_the_manifest_loads" | t }}"
             class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
    </label>

    <div class="flex gap-4">
      <label class="flex items-center gap-2 text-sm text-gray-700">
        <input name="enabled" type="checkbox" value="1"{% if enabled %} checked{% endif %}> {{ "view_strings.sections_plugin_form.enabled" | t }}
      </label>
      <label class="flex items-center gap-2 text-sm text-gray-700">
        {{ "view_strings.sections_plugin_form.sort_order" | t }}
        <input name="sort_order" type="number" value="{{ sortOrder }}" class="w-20 px-2 py-1 border border-gray-300 rounded-lg">
      </label>
    </div>

    <label class="block">
      <span class="block text-sm font-medium text-gray-700 mb-1">{{ "view_strings.sections_plugin_form.config_json" | t }} <span class="text-gray-400">{{ "view_strings.sections_plugin_form.optional" | t }}</span></span>
      <textarea name="config" rows="3" placeholder="{}"
                class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono">{{ config }}</textarea>
    </label>

    <div class="flex min-w-0 flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap sm:items-center">
      <button type="submit" class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">{{ submitLabelKey | t }}</button>
      <a href="/admin/plugins-manage" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">{{ "view_strings.sections_plugin_form.cancel" | t }}</a>
    </div>
  </form>

  {% if showSecret %}
    <div class="bg-white rounded-xl shadow p-6 mt-6">
      <h2 class="text-sm font-semibold text-gray-700 mb-1">{{ "view_strings.sections_plugin_form.shared_secret" | t }}</h2>
      <p class="text-xs text-gray-500 mb-3">
        {{ "view_strings.sections_plugin_form.set_this_exact_value_on_the_plugin_worker" | t }} <code>{{ "view_strings.sections_plugin_form.wrangler_secret_put_plugin_secret" | t }}</code>.
        {% if usesSharedSecret %}
          {{ "plugins.form.no_dedicated_secret" | t }} <code>PLUGIN_SECRET</code> {{ "plugins.form.rotate_to_assign" | t }}
        {% endif %}
      </p>
      <input type="text" readonly value="{{ secret }}"
             class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono bg-gray-50 mb-3"
             placeholder="{{ "view_strings.sections_plugin_form.using_shared_plugin_secret_fallback" | t }}">
      <form method="post" action="{{ rotateSecretAction }}"
            data-confirm="{{ "view_strings.sections_plugin_form.rotate_this_plugin_s_secret_the_plugin_worker_must_be_updated_to_the_new" | t }}">
        <button type="submit" class="px-3 py-1.5 rounded-lg border border-amber-300 text-xs font-semibold text-amber-800">{{ "view_strings.sections_plugin_form.rotate_secret" | t }}</button>
      </form>
    </div>
  {% endif %}
</div>
