<div class="px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex items-center justify-between gap-4 mb-4">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">{{ titleKey | t }}</h2>
      <p class="mt-1 text-sm text-gray-500">{{ descriptionKey | t }}</p>
    </div>
    {% if canWrite %}
      <a href="{{ newHref }}"
         title="{{ newLabelKey | t }}"
         aria-label="{{ newLabelKey | t }}"
         class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#plus"></use></svg>
        <span class="hidden lg:inline">{{ newLabelKey | t }}</span>
      </a>
    {% endif %}
  </div>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
    <table class="w-full min-w-[560px] text-left">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_type_list.name" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_type_list.slug" | t }}</th>
          <th class="px-6 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">{{ "view_strings.sections_type_list.source" | t }}</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        {% if hasTypes %}
          {% for type in types %}
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-3 text-sm font-medium text-gray-900">{{ type.name }}</td>
              <td class="px-6 py-3 text-sm font-mono text-gray-500">{{ type.slug }}</td>
              <td class="px-6 py-3 text-sm">
                {% if type.source == 'db' %}
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-700">{{ "types.source.database" | t }}</span>
                {% elsif type.source == 'plugin' %}
                  <span data-type-plugin="{{ type.slug }}" class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-emerald-100 text-emerald-700">{{ "types.source.plugin" | t }}{% if type.pluginName %} ({{ type.pluginName }}){% endif %}</span>
                {% else %}
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">{{ "types.source.config" | t }}</span>
                {% endif %}
              </td>
              <td class="px-6 py-3 text-right">
                {% if type.isDb %}
                  <a href="{{ type.editHref }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{% if canWrite %}{{ "common.edit" | t }}{% else %}{{ "common.view" | t }}{% endif %}</a>
                {% else %}
                  <a href="{{ type.viewHref }}" class="text-sm font-medium text-indigo-600 hover:text-indigo-800">{{ "view_strings.sections_type_list.view" | t }}</a>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="4" class="px-6 py-10 text-center text-gray-400">{{ "view_strings.sections_type_list.nothing_here_yet" | t }}</td></tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>
