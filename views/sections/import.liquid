<div class="min-w-0 max-w-3xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-3 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <h2 class="text-2xl font-bold text-gray-900">Import {{ pageType | escape }}</h2>
    <a href="{{ backHref | escape }}" class="text-sm text-indigo-600 hover:underline">Back</a>
  </div>
  <form method="POST" class="min-w-0 space-y-4">
    <label for="items" class="sr-only">Items JSON</label>
    <textarea id="items" name="items" rows="18"
              placeholder='[{"name":"Example","slug":"example","values":{"en":{"name":"Example"}}}]'
              class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono"></textarea>
    <button type="submit" class="w-full shrink-0 px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg sm:w-auto">Import</button>
  </form>
</div>
