<div class="min-w-0 max-w-5xl px-4 py-5 sm:px-6 sm:py-8 lg:px-8">
  <div class="flex flex-col gap-3 mb-6 sm:flex-row sm:items-center sm:justify-between">
    <h2 class="text-2xl font-bold text-gray-900">
      {% if isConfirmImport %}Confirm Import{% else %}Import{% endif %}
      {{ pageType | escape }}
    </h2>
    <a href="{{ backHref | escape }}" class="text-sm text-indigo-600 hover:underline">Back</a>
  </div>

  {% if isConfirmImport %}
    <div class="mb-5 grid gap-3 sm:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white px-4 py-3">
        <div class="text-xs font-semibold uppercase tracking-wider text-gray-500">New Pages</div>
        <div class="mt-1 text-2xl font-semibold text-gray-900">{{ newCount }}</div>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white px-4 py-3">
        <div class="text-xs font-semibold uppercase tracking-wider text-gray-500">Existing Pages</div>
        <div class="mt-1 text-2xl font-semibold text-gray-900">{{ existingCount }}</div>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white px-4 py-3">
        <div class="text-xs font-semibold uppercase tracking-wider text-gray-500">Rows</div>
        <div class="mt-1 text-2xl font-semibold text-gray-900">{{ previewCount }}</div>
      </div>
    </div>

    {% if skippedCount > 0 %}
      <div class="mb-5 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
        {{ skippedCount }} empty row{% if skippedCount != 1 %}s{% endif %} skipped.
      </div>
    {% endif %}

    <form method="POST" action="{{ action | escape }}" class="min-w-0">
      <textarea name="csv" class="hidden">{{ csvText | escape }}</textarea>

      {% if hasImportModeOptions %}
        <fieldset class="mb-6 min-w-0">
          <legend class="mb-2 text-sm font-semibold uppercase tracking-wider text-gray-500">Import Action</legend>
          <div class="grid gap-2 lg:grid-cols-2">
            {% for option in importModeOptions %}
              <label class="flex min-w-0 cursor-pointer gap-3 rounded-lg border border-gray-200 bg-white p-3 hover:bg-gray-50">
                <input type="radio" name="action" value="{{ option.value | escape }}"
                       {% if option.checked %}checked{% endif %}
                       class="mt-1 h-4 w-4 shrink-0 border-gray-300 text-indigo-600 focus:ring-indigo-500">
                <span class="min-w-0">
                  <span class="flex flex-wrap items-center gap-2 text-sm font-semibold text-gray-900">
                    {{ option.label | escape }}
                    {% if option.destructive %}
                      <span class="rounded bg-red-50 px-1.5 py-0.5 text-xs font-semibold text-red-700">Destructive</span>
                    {% endif %}
                  </span>
                  <span class="mt-1 block text-sm text-gray-500">{{ option.description | escape }}</span>
                </span>
              </label>
            {% endfor %}
          </div>
        </fieldset>
      {% endif %}

      <div class="space-y-6">
        <section class="min-w-0">
          <div class="mb-2 flex items-center justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">New Pages</h3>
            <span class="text-sm text-gray-500">{{ newCount }}</span>
          </div>
          {% if hasNewRows %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
              <table class="w-full min-w-[560px] text-left">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">CSV Row</th>
                    <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Page</th>
                    <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Slug</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {% for row in newRows %}
                    <tr>
                      <td class="px-4 py-3 text-sm text-gray-500">{{ row.rowNumber }}</td>
                      <td class="px-4 py-3 text-sm font-medium text-gray-900">{{ row.name | escape }}</td>
                      <td class="px-4 py-3 text-sm font-mono text-gray-500">/{{ row.slug | escape }}</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-500">No new pages.</div>
          {% endif %}
        </section>

        <section class="min-w-0">
          <div class="mb-2 flex items-center justify-between">
            <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-500">Existing Pages</h3>
            <span class="text-sm text-gray-500">{{ existingCount }}</span>
          </div>
          {% if hasExistingRows %}
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
              <table class="w-full min-w-[560px] text-left">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">CSV Row</th>
                    <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Imported Page</th>
                    <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-gray-500">Existing Draft</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {% for row in existingRows %}
                    <tr>
                      <td class="px-4 py-3 text-sm text-gray-500">{{ row.rowNumber }}</td>
                      <td class="px-4 py-3 text-sm">
                        <div class="font-medium text-gray-900">{{ row.name | escape }}</div>
                        <div class="font-mono text-xs text-gray-500">/{{ row.slug | escape }}</div>
                      </td>
                      <td class="px-4 py-3 text-sm">
                        <div class="font-medium text-gray-900">#{{ row.existingId }} {{ row.existingName | escape }}</div>
                        <div class="font-mono text-xs text-gray-500">/{{ row.existingSlug | escape }}</div>
                      </td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-500">No existing pages will be updated.</div>
          {% endif %}
        </section>
      </div>

      <div class="mt-6 flex flex-col gap-2 sm:flex-row sm:justify-end">
        <a href="{{ backHref | escape }}"
           class="inline-flex h-10 items-center justify-center rounded-lg border border-gray-300 bg-white px-4 text-sm font-semibold text-gray-700 hover:bg-gray-50">
          Cancel
        </a>
        <button type="submit"
                {% unless hasPreviewRows %}disabled{% endunless %}
                title="Confirm Import"
                aria-label="Confirm Import"
                class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700 {% unless hasPreviewRows %}cursor-not-allowed opacity-50{% endunless %}">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg>
          <span class="hidden lg:inline">Confirm Import</span>
        </button>
      </div>
    </form>
  {% else %}
    <form method="POST" action="{{ action | escape }}" enctype="multipart/form-data" class="min-w-0 max-w-3xl space-y-4">
      {% if isCsvImport %}
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
          <div class="mb-1 text-xs font-semibold uppercase tracking-wider text-gray-500">CSV Header</div>
          <code class="block whitespace-pre-wrap break-words text-xs text-gray-600">{{ sampleCsvHeader | escape }}</code>
        </div>
        <label class="block">
          <span class="mb-1 block text-sm font-medium text-gray-700">CSV File</span>
          <input type="file" name="file" accept=".csv,text/csv"
                 class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700">
        </label>
        <label for="csv" class="block">
          <span class="mb-1 block text-sm font-medium text-gray-700">Or Paste CSV</span>
          <textarea id="csv" name="csv" rows="14"
                    class="block min-w-0 w-full max-w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-sm"></textarea>
        </label>
      {% else %}
        <label for="items" class="sr-only">Items JSON</label>
        <textarea id="items" name="items" rows="18"
                  placeholder='[{"name":"Example","slug":"example","values":{"en":{"name":"Example"}}}]'
                  class="block min-w-0 w-full max-w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono"></textarea>
      {% endif %}
      <button type="submit"
              title="{% if isCsvImport %}Review Import{% else %}Import{% endif %}"
              aria-label="{% if isCsvImport %}Review Import{% else %}Import{% endif %}"
              class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 text-sm font-semibold text-white hover:bg-indigo-700">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="/assets/icons.svg#upload"></use></svg>
        <span class="hidden lg:inline">{% if isCsvImport %}Review Import{% else %}Import{% endif %}</span>
      </button>
    </form>
  {% endif %}
</div>
