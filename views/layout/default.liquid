<!DOCTYPE html>
<html lang="{{ uiLocale | default: 'en' }}" dir="{{ uiDirection | default: 'ltr' }}" class="h-full overflow-x-hidden bg-gray-50">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {{ siteTitle }}</title>
  <script nonce="{{ nonce }}">
    (function() {
      var key = 'worker-cms-theme';
      var root = document.documentElement;

      function storedTheme() {
        try {
          var value = window.localStorage.getItem(key);
          return value === 'light' || value === 'dark' ? value : 'dark';
        } catch (error) {
          return 'dark';
        }
      }

      function persistTheme(theme) {
        try {
          window.localStorage.setItem(key, theme);
        } catch (error) {
          /* ignore */
        }
      }

      function renderToggle(theme) {
        var isLight = theme === 'light';
        document.querySelectorAll('[data-theme-toggle]').forEach(function(toggle) {
          if (!(toggle instanceof HTMLButtonElement)) return;
          toggle.setAttribute('aria-pressed', isLight ? 'true' : 'false');
          toggle.setAttribute('aria-label', isLight ? 'Switch to dark theme' : 'Switch to light theme');
          toggle.querySelectorAll('[data-theme-icon]').forEach(function(icon) {
            icon.classList.toggle('hidden', icon.getAttribute('data-theme-icon') !== theme);
          });
          var label = toggle.querySelector('[data-theme-toggle-label]');
          if (label) label.textContent = isLight ? 'Light' : 'Dark';
        });
      }

      function applyTheme(theme) {
        root.setAttribute('data-theme', theme);
        renderToggle(theme);
      }

      applyTheme(storedTheme());

      function bindThemeToggle() {
        renderToggle(root.getAttribute('data-theme') || 'dark');
        document.querySelectorAll('[data-theme-toggle]').forEach(function(toggle) {
          if (!(toggle instanceof HTMLButtonElement)) return;
          if (toggle.dataset.themeBound === '1') return;
          toggle.dataset.themeBound = '1';
          toggle.addEventListener('click', function() {
            var next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
            applyTheme(next);
            persistTheme(next);
          });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bindThemeToggle);
      } else {
        bindThemeToggle();
      }
    })();

    {% if admin %}
    (function() {
      if (window.__cmsSessionKeepaliveBound) return;
      window.__cmsSessionKeepaliveBound = true;
      var INTERVAL = 10 * 60 * 1000;
      var inFlight = false;

      async function refresh() {
        if (inFlight) return;
        inFlight = true;
        try {
          var res = await fetch('/auth/refresh', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { Accept: 'application/json' }
          });
          if (res.status === 401) window.location.href = '/auth/login';
        } catch (error) {
          /* retry on the next tick */
        } finally {
          inFlight = false;
        }
      }

      window.setInterval(refresh, INTERVAL);
      document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'visible') refresh();
      });
    })();
    {% endif %}

    // Confirmation prompts for forms marked with data-confirm (CSP-safe
    // replacement for inline onsubmit handlers).
    document.addEventListener('submit', function(event) {
      const message = event.target instanceof Element ? event.target.getAttribute('data-confirm') : null;
      if (message && !confirm(message)) {
        event.preventDefault();
        event.stopImmediatePropagation();
      }
    }, true);

    // Double-submit guard: once a form's submit is actually going through,
    // block repeat submits and disable its buttons until the next page loads.
    // Delegated on document so it also covers client-rendered plugin fragments.
    // The disable is deferred one tick because the browser builds the POST body
    // AFTER the submit event — disabling the clicked submitter synchronously
    // drops its name/value from the submission — and so forms whose scripts
    // preventDefault + fetch (e.g. the check-in kiosk) are left alone.
    // Opt out per form with data-allow-resubmit.
    (function() {
      // Server-side single-use token (_cms_once): the host verifies and claims
      // the stamped value on POST, so a re-POST of the same body (browser
      // resubmit dialog, network retry) is rejected even after this page's
      // in-memory guard is gone. cmsOnce is host-minted and base64url-safe.
      var oncePageToken = '{{ cmsOnce }}';

      function stampOnceToken(form) {
        if (!oncePageToken) return;
        if (form.method !== 'post') return;
        if (form.querySelector('input[name="_cms_once"]')) return;
        var bytes = new Uint8Array(8);
        crypto.getRandomValues(bytes);
        var suffix = Array.prototype.map.call(bytes, function(byte) {
          return byte.toString(16).padStart(2, '0');
        }).join('');
        var input = document.createElement('input');
        input.type = 'hidden';
        input.name = '_cms_once';
        input.value = oncePageToken + ':' + suffix;
        input.setAttribute('data-cms-once-stamped', '1');
        form.appendChild(input);
      }

      document.addEventListener('submit', function(event) {
        var form = event.target;
        if (!(form instanceof HTMLFormElement)) return;
        if (form.hasAttribute('data-allow-resubmit')) return;
        if (form.getAttribute('data-submit-guard') === '1') {
          // Repeat submit while the first is in flight (e.g. Enter key).
          event.preventDefault();
          return;
        }
        // Stamp synchronously — the entry list is built after this event, so
        // (unlike disabling, above) an input added here IS submitted. Skip
        // forms already intercepted (preventDefault + fetch, e.g. the kiosk):
        // their repeat submits are legitimate and must not share one token.
        if (!event.defaultPrevented) stampOnceToken(form);
        setTimeout(function() {
          if (event.defaultPrevented) return;
          form.setAttribute('data-submit-guard', '1');
          form.setAttribute('aria-busy', 'true');
          Array.prototype.forEach.call(form.elements, function(control) {
            var isButton = control instanceof HTMLButtonElement
              || (control instanceof HTMLInputElement && /^(submit|button|reset|image)$/.test(control.type));
            if (!isButton || control.disabled) return;
            // Escape hatches on progress pages must stay usable.
            if (control.hasAttribute('data-stop-continue')) return;
            control.disabled = true;
            control.setAttribute('data-submit-guard-disabled', '1');
            control.style.cursor = 'wait';
            control.style.opacity = '0.65';
          });
        }, 0);
      });

      // Back/forward-cache restores bring the page back with the guard still
      // engaged; release it so the form is usable again.
      window.addEventListener('pageshow', function(event) {
        if (!event.persisted) return;
        document.querySelectorAll('form[data-submit-guard="1"]').forEach(function(form) {
          form.removeAttribute('data-submit-guard');
          form.removeAttribute('aria-busy');
        });
        document.querySelectorAll('[data-submit-guard-disabled]').forEach(function(control) {
          control.disabled = false;
          control.removeAttribute('data-submit-guard-disabled');
          control.style.cursor = '';
          control.style.opacity = '';
        });
        // Drop stamped tokens too: coming back to edit and resubmit is a
        // deliberate new submission and gets a fresh dedupe key.
        document.querySelectorAll('input[data-cms-once-stamped]').forEach(function(input) {
          input.remove();
        });
      });
    })();

    // Avatar fallback (CSP-safe replacement for the inline onerror handler).
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-avatar-img]').forEach(function(avatar) {
        function showAvatarFallback() {
          avatar.classList.add('hidden');
          avatar.parentElement?.querySelector('[data-avatar-fallback]')?.classList.remove('hidden');
        }

        avatar.addEventListener('error', showAvatarFallback);
        if (avatar.complete && avatar.naturalWidth === 0) {
          showAvatarFallback();
        }
      });
    });

    // Auto-submit a control's form when it changes, for elements marked
    // [data-autosubmit] (e.g. an editor language selector that should reload the
    // page on change). CSP-safe replacement for an inline onchange handler — the
    // form attribute association resolves the target form for fields outside it.
    document.addEventListener('change', function(event) {
      const el = event.target;
      if (!(el instanceof Element) || !el.hasAttribute('data-autosubmit')) return;
      const formId = el.getAttribute('form');
      const form = (el instanceof HTMLSelectElement && el.form)
        || (formId && document.getElementById(formId))
        || el.closest('form');
      if (form instanceof HTMLFormElement) form.submit();
    });

    (function() {
      function revealActiveSidebarItem() {
        var activeItem = document.querySelector('[data-admin-sidebar] [aria-current="page"]');
        if (!(activeItem instanceof HTMLElement)) return;
        activeItem.scrollIntoView({ block: 'nearest' });
      }

      function bindMobileMenu() {
        var menu = document.querySelector('[data-admin-sidebar]');
        var openButton = document.querySelector('[data-mobile-menu-open]');
        var closeButtons = document.querySelectorAll('[data-mobile-menu-close]');
        if (!(menu instanceof HTMLElement) || !(openButton instanceof HTMLButtonElement)) return;
        if (openButton.dataset.mobileMenuBound === '1') return;
        openButton.dataset.mobileMenuBound = '1';

        function setOpen(open) {
          var isDesktop = window.matchMedia && window.matchMedia('(min-width: 768px)').matches;
          if (isDesktop) {
            menu.setAttribute('aria-hidden', 'false');
            openButton.setAttribute('aria-expanded', 'false');
            document.body.classList.remove('overflow-hidden');
            revealActiveSidebarItem();
            return;
          }
          menu.classList.toggle('hidden', !open);
          menu.classList.toggle('flex', open);
          menu.setAttribute('aria-hidden', open ? 'false' : 'true');
          openButton.setAttribute('aria-expanded', open ? 'true' : 'false');
          document.body.classList.toggle('overflow-hidden', open);
          if (open) window.requestAnimationFrame(revealActiveSidebarItem);
        }

        openButton.addEventListener('click', function() {
          setOpen(true);
        });
        closeButtons.forEach(function(button) {
          button.addEventListener('click', function() {
            setOpen(false);
          });
        });
        menu.addEventListener('click', function(event) {
          var target = event.target;
          if (target instanceof HTMLAnchorElement) setOpen(false);
        });
        document.addEventListener('keydown', function(event) {
          if (event.key === 'Escape') setOpen(false);
        });
        window.addEventListener('resize', function() {
          setOpen(false);
        });
        setOpen(false);
      }

      function bindMobileHeaderAutoHide() {
        var bar = document.querySelector('[data-admin-mobile-bar]');
        var openButton = document.querySelector('[data-mobile-menu-open]');
        if (!(bar instanceof HTMLElement)) return;
        if (bar.dataset.mobileHeaderScrollBound === '1') return;
        bar.dataset.mobileHeaderScrollBound = '1';

        var lastY = window.scrollY || window.pageYOffset || 0;
        var downDistance = 0;
        var ticking = false;

        function isDesktop() {
          return window.matchMedia && window.matchMedia('(min-width: 768px)').matches;
        }

        function setHidden(hidden) {
          bar.classList.toggle('is-hidden', hidden);
          bar.setAttribute('aria-hidden', hidden ? 'true' : 'false');
          if (openButton instanceof HTMLButtonElement) {
            openButton.tabIndex = hidden ? -1 : 0;
          }
        }

        function update() {
          ticking = false;
          if (isDesktop()) {
            downDistance = 0;
            lastY = window.scrollY || window.pageYOffset || 0;
            setHidden(false);
            return;
          }

          var currentY = Math.max(window.scrollY || window.pageYOffset || 0, 0);
          var delta = currentY - lastY;
          var threshold = Math.max(window.innerHeight / 5, 1);

          if (currentY <= 0) {
            downDistance = 0;
            setHidden(false);
          } else if (delta > 0) {
            downDistance += delta;
            if (downDistance >= threshold) setHidden(true);
          } else if (delta < 0) {
            downDistance = 0;
            setHidden(false);
          }

          lastY = currentY;
        }

        function requestUpdate() {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(update);
        }

        window.addEventListener('scroll', requestUpdate, { passive: true });
        window.addEventListener('resize', requestUpdate);
        setHidden(false);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          bindMobileMenu();
          bindMobileHeaderAutoHide();
        });
      } else {
        bindMobileMenu();
        bindMobileHeaderAutoHide();
      }
    })();
  </script>
  <link rel="stylesheet" href="/assets/admin.css{{ assetRevisionQuery }}">
  <script src="/assets/table-filter.js{{ assetRevisionQuery }}" nonce="{{ nonce }}" defer></script>
  <script src="/assets/privacy-table.js{{ assetRevisionQuery }}" nonce="{{ nonce }}" defer></script>
  <script src="/assets/color-tag.js{{ assetRevisionQuery }}" nonce="{{ nonce }}" defer></script>
  <script src="/assets/picture-field.js{{ assetRevisionQuery }}" nonce="{{ nonce }}" defer></script>
  <script src="/assets/page-ref.js{{ assetRevisionQuery }}" nonce="{{ nonce }}" defer></script>
  {% if editorSync %}<script src="/assets/editor-sync.js{{ assetRevisionQuery }}" nonce="{{ nonce }}" defer></script>{% endif %}
</head>
<body class="h-full overflow-x-hidden">
  {% if admin %}
    <header class="sticky top-0 z-40 flex items-center justify-between gap-3 border-b border-gray-700 bg-gray-900 px-4 py-3 text-white shadow-xl md:hidden" data-admin-mobile-bar>
      <a href="/admin" aria-label="Go to admin dashboard" class="flex min-w-0 items-center gap-3">
        <svg class="h-7 w-7 shrink-0 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#{{ appIcon }}"></use></svg>
        <span class="min-w-0 truncate text-lg font-bold tracking-tight">{{ siteTitle }}</span>
      </a>
      <button type="button"
              class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-gray-700 text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
              data-mobile-menu-open
              aria-controls="admin-mobile-menu"
              aria-expanded="false"
              aria-label="Open menu">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#menu"></use></svg>
      </button>
    </header>

    <aside id="admin-mobile-menu"
           class="fixed inset-0 z-50 hidden max-h-screen min-h-screen flex-col overflow-hidden bg-gray-900 text-white shadow-xl md:fixed md:inset-y-0 md:left-0 md:flex md:min-h-0 md:w-64"
           data-admin-sidebar>
      <div class="flex items-center justify-between gap-3 border-b border-gray-700 px-4 py-3 md:px-6 md:py-5">
        <a href="/admin" aria-label="Go to admin dashboard" class="flex min-w-0 items-center gap-3">
          <svg class="h-7 w-7 shrink-0 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#{{ appIcon }}"></use></svg>
          <span class="min-w-0 truncate text-lg font-bold tracking-tight">{{ siteTitle }}</span>
        </a>
        <button type="button"
                class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-gray-700 text-gray-300 transition-colors hover:bg-gray-700 hover:text-white md:hidden"
                data-mobile-menu-close
                aria-label="Close menu">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#x"></use></svg>
        </button>
      </div>
      <nav class="min-h-0 flex-1 space-y-1 overflow-y-auto px-4 py-4 md:px-4 md:py-6" data-scroll-frame>
        {% for item in sidebarNav %}
          {% if item.isSettingsGroup %}
            <details class="group overflow-hidden"{% if item.isActive %} open{% endif %}>
              <summary class="flex cursor-pointer list-none items-center gap-3 rounded-lg px-3 py-2 transition-colors hover:bg-gray-700 hover:text-white [&::-webkit-details-marker]:hidden {% if item.isActive %}font-semibold text-white{% else %}text-gray-300{% endif %}">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#{{ item.icon }}"></use></svg>
                <span>{{ item.label }}</span>
                <svg class="ml-auto h-4 w-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#chevron-right"></use></svg>
              </summary>
              <div class="mt-1 ml-3 space-y-1 border-l border-gray-700 pl-3">
                {% for settingItem in sidebarSettingsNav %}
                  <a href="{{ settingItem.href }}"
                     {% if settingItem.isActive %}aria-current="page"{% endif %}
                     class="flex items-center gap-3 rounded-lg px-3 py-2 transition-colors {% if settingItem.isActive %}bg-indigo-600 font-semibold text-white shadow-sm hover:bg-indigo-700{% else %}text-gray-300 hover:bg-gray-700 hover:text-white{% endif %}">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#{{ settingItem.icon }}"></use></svg>
                    {{ settingItem.label }}
                  </a>
                {% endfor %}
              </div>
            </details>
          {% else %}
            <a href="{{ item.href }}"
               {% if item.isActive %}aria-current="page"{% endif %}
               class="flex items-center gap-3 rounded-lg px-3 py-2 transition-colors {% if item.isActive %}bg-indigo-600 font-semibold text-white shadow-sm hover:bg-indigo-700{% else %}text-gray-300 hover:bg-gray-700 hover:text-white{% endif %}">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#{{ item.icon }}"></use></svg>
              {{ item.label }}
            </a>
          {% endif %}
        {% endfor %}
      </nav>
      <div class="border-t border-gray-700 px-4 py-3 md:py-4" data-admin-sidebar-footer>
        <a href="/admin/profile" class="mb-3 flex min-w-0 items-center gap-3 rounded-lg px-2 py-2 transition-colors hover:bg-gray-700" data-mobile-menu-close>
          {% if hasUserAvatar %}
            <div class="relative w-8 h-8 shrink-0">
              <img src="{{ userAvatar }}"
                   class="w-8 h-8 rounded-full object-cover"
                   alt="avatar"
                   data-avatar-img>
              <div class="hidden w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-sm font-bold"
                   data-avatar-fallback>{{ userInitial }}</div>
            </div>
          {% else %}
            <div class="w-8 h-8 shrink-0 rounded-full bg-indigo-500 flex items-center justify-center text-sm font-bold"
                 data-avatar-fallback>{{ userInitial }}</div>
          {% endif %}
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-white truncate">{{ userName }}</p>
            <p class="text-xs text-gray-400 capitalize">{{ userRoleLabel }}</p>
            <p class="mt-1 flex items-center gap-1 text-xs font-medium text-amber-400">
              <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="8" stroke-width="2"></circle>
                <path stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M12 8.5v7M10 10.5h2.5a1.5 1.5 0 010 3H10m0 0h3"></path>
              </svg>
              <span>{{ userCredits }} credit{% unless userCredits == 1 %}s{% endunless %}</span>
            </p>
            <p class="mt-0.5 flex items-center gap-1 text-xs font-medium text-sky-400">
              <svg class="h-3.5 w-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="9" cy="12" r="6.5" stroke-width="2"></circle>
                <path stroke-width="2" stroke-linecap="round" d="M14.5 5.7a6.5 6.5 0 010 12.6"></path>
              </svg>
              <span>{{ sharedCredits }} shared</span>
            </p>
          </div>
          <svg class="h-4 w-4 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><use href="{{ iconHrefPrefix }}#chevron-right"></use></svg>
        </a>
        <div class="flex shrink-0 items-center gap-3 md:flex-col md:items-start">
          <button type="button"
                  class="inline-flex shrink-0 items-center gap-2 rounded-lg border border-gray-700 px-2.5 py-1.5 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                  data-theme-toggle
                  aria-pressed="false"
                  aria-label="Switch to light theme">
            <svg class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-theme-icon="light"><use href="{{ iconHrefPrefix }}#sun"></use></svg>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-theme-icon="dark"><use href="{{ iconHrefPrefix }}#moon"></use></svg>
            <span data-theme-toggle-label>Dark</span>
          </button>
          <form method="POST" action="/auth/logout" class="inline">
            <button type="submit"
                    class="flex shrink-0 items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="{{ iconHrefPrefix }}#logout"></use></svg>
              Sign out
            </button>
          </form>
        </div>
      </div>
    </aside>
  {% endif %}
  <div class="{{ contentClass }} min-h-full min-w-0">
    {{ body | raw }}
  </div>
  <script nonce="{{ nonce }}">
  // Drag-and-drop reorder for tables with [data-reorder].
  // Rows carry data-id (weight mode) or data-index (order mode).
  // [data-reorder-handle-only]: drag may only start from [data-reorder-handle] cells.
  (function() {
    var dragSrc = null, dragTable = null, mdTarget = null;
    var markQueued = false;
    // Invisible 1×1 element used as the drag image so no ghost floats around.
    var ghost = document.createElement('span');
    ghost.style.cssText = 'position:fixed;pointer-events:none;opacity:0;width:1px;height:1px';
    document.body.appendChild(ghost);
    function markDraggableRows(scope) {
      Array.from((scope || document).querySelectorAll('table[data-reorder] tbody tr[data-id], table[data-reorder] tbody tr[data-index]')).forEach(function(tr) {
        tr.setAttribute('draggable', 'true');
      });
    }
    function queueMarkDraggableRows() {
      if (markQueued) return;
      markQueued = true;
      requestAnimationFrame(function() {
        markQueued = false;
        markDraggableRows(document);
      });
    }
    // Track mousedown so handle-only tables know whether the drag started on a handle.
    document.addEventListener('mousedown', function(e) {
      mdTarget = e.target;
      var table = e.target.closest && e.target.closest('table[data-reorder]');
      if (table) markDraggableRows(table);
    });
    // Make every eligible row draggable.
    markDraggableRows(document);
    new MutationObserver(queueMarkDraggableRows).observe(document.body, { childList: true, subtree: true });
    document.addEventListener('dragstart', function(e) {
      var tr = e.target.closest && e.target.closest('tr[data-id],tr[data-index]');
      if (!tr) return;
      var table = tr.closest('table[data-reorder]');
      if (!table) return;
      if (table.getAttribute('data-table-filter-active') === '1') {
        e.preventDefault(); return;
      }
      if (table.hasAttribute('data-reorder-handle-only') && (!mdTarget || !mdTarget.closest('[data-reorder-handle]'))) {
        e.preventDefault(); return;
      }
      dragSrc = tr; dragTable = table;
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setDragImage(ghost, 0, 0);
      setTimeout(function() { if (dragSrc) dragSrc.style.opacity = '0.4'; }, 0);
    });
    document.addEventListener('dragover', function(e) {
      if (!dragSrc) return;
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      var tr = e.target.closest && e.target.closest('tr[data-id],tr[data-index]');
      if (!tr || tr === dragSrc || tr.closest('table[data-reorder]') !== dragTable) return;
      var rect = tr.getBoundingClientRect();
      var ref = e.clientY > rect.top + rect.height / 2 ? tr.nextSibling : tr;
      if (ref !== dragSrc && ref !== dragSrc.nextSibling) tr.parentNode.insertBefore(dragSrc, ref);
    });
    document.addEventListener('drop', function(e) {
      e.preventDefault();
      if (dragSrc) dragSrc.style.opacity = '';
    });
    document.addEventListener('dragend', function() {
      if (!dragSrc) return;
      dragSrc.style.opacity = '';
      save(dragTable);
      dragSrc = null; dragTable = null; mdTarget = null;
    });
    function save(table) {
      var url = table.getAttribute('data-reorder');
      var key = table.getAttribute('data-reorder-key') || 'reorder';
      var mode = table.getAttribute('data-reorder-mode');
      var rows = Array.from(table.querySelectorAll('tbody tr[data-id],tbody tr[data-index]'));
      var body = {};
      if (mode === 'order') {
        body[key] = rows.map(function(r) { return parseInt(r.getAttribute('data-index'), 10); });
      } else {
        body[key] = rows.map(function(r, i) { return { id: Number(r.getAttribute('data-id')), weight: i * 10 }; });
      }
      fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).catch(function() {});
    }
  })();
  </script>
</body>
</html>
