<!DOCTYPE html>
<html lang="en" class="h-full overflow-x-hidden bg-gray-50">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | escape }} - {{ siteTitle | escape }}</title>
  <script nonce="{{ nonce }}">
    (function() {
      var key = 'worker-cms-theme';
      var root = document.documentElement;

      function storedTheme() {
        try {
          var value = window.localStorage.getItem(key);
          return value === 'light' || value === 'dark' ? value : 'dark';
        } catch (error) {
          return 'dark';
        }
      }

      function persistTheme(theme) {
        try {
          window.localStorage.setItem(key, theme);
        } catch (error) {
          /* ignore */
        }
      }

      function renderToggle(theme) {
        var toggle = document.querySelector('[data-theme-toggle]');
        if (!(toggle instanceof HTMLButtonElement)) return;
        var isLight = theme === 'light';
        toggle.setAttribute('aria-pressed', isLight ? 'true' : 'false');
        toggle.setAttribute('aria-label', isLight ? 'Switch to dark theme' : 'Switch to light theme');
        toggle.querySelectorAll('[data-theme-icon]').forEach(function(icon) {
          icon.classList.toggle('hidden', icon.getAttribute('data-theme-icon') !== theme);
        });
        var label = toggle.querySelector('[data-theme-toggle-label]');
        if (label) label.textContent = isLight ? 'Light' : 'Dark';
      }

      function applyTheme(theme) {
        root.setAttribute('data-theme', theme);
        renderToggle(theme);
      }

      applyTheme(storedTheme());

      function bindThemeToggle() {
        var toggle = document.querySelector('[data-theme-toggle]');
        renderToggle(root.getAttribute('data-theme') || 'dark');
        if (!(toggle instanceof HTMLButtonElement)) return;
        if (toggle.dataset.themeBound === '1') return;
        toggle.dataset.themeBound = '1';
        toggle.addEventListener('click', function() {
          var next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
          applyTheme(next);
          persistTheme(next);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bindThemeToggle);
      } else {
        bindThemeToggle();
      }
    })();

    (function() {
      const INTERVAL = 14 * 60 * 1000;
      async function refresh() {
        try {
          const res = await fetch('/auth/refresh', { method: 'POST' });
          if (!res.ok) { window.location.href = '/auth/login'; }
        } catch(e) { /* ignore */ }
      }
      setInterval(refresh, INTERVAL);
    })();

    // Confirmation prompts for forms marked with data-confirm (CSP-safe
    // replacement for inline onsubmit handlers).
    document.addEventListener('submit', function(event) {
      const message = event.target instanceof Element ? event.target.getAttribute('data-confirm') : null;
      if (message && !confirm(message)) {
        event.preventDefault();
        event.stopImmediatePropagation();
      }
    }, true);

    // Avatar fallback (CSP-safe replacement for the inline onerror handler).
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('[data-avatar-img]').forEach(function(avatar) {
        function showAvatarFallback() {
          avatar.classList.add('hidden');
          avatar.parentElement?.querySelector('[data-avatar-fallback]')?.classList.remove('hidden');
        }

        avatar.addEventListener('error', showAvatarFallback);
        if (avatar.complete && avatar.naturalWidth === 0) {
          showAvatarFallback();
        }
      });
    });

    // Auto-submit a control's form when it changes, for elements marked
    // [data-autosubmit] (e.g. an editor language selector that should reload the
    // page on change). CSP-safe replacement for an inline onchange handler — the
    // form attribute association resolves the target form for fields outside it.
    document.addEventListener('change', function(event) {
      const el = event.target;
      if (!(el instanceof Element) || !el.hasAttribute('data-autosubmit')) return;
      const formId = el.getAttribute('form');
      const form = (el instanceof HTMLSelectElement && el.form)
        || (formId && document.getElementById(formId))
        || el.closest('form');
      if (form instanceof HTMLFormElement) form.submit();
    });
  </script>
  <link rel="stylesheet" href="/assets/admin.css">
</head>
<body class="h-full overflow-x-hidden">
  {% if admin %}
    <aside class="sticky top-0 z-40 bg-gray-900 text-white shadow-xl md:fixed md:inset-y-0 md:left-0 md:w-64 md:flex md:flex-col" data-admin-sidebar>
      <div class="flex items-center gap-3 px-4 py-3 border-b border-gray-700 md:px-6 md:py-5">
        <svg class="w-7 h-7 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#document"></use></svg>
        <span class="min-w-0 truncate font-bold text-lg tracking-tight">{{ siteTitle | escape }}</span>
      </div>
      <nav class="flex gap-1 overflow-x-auto px-3 py-2 md:block md:flex-1 md:px-4 md:py-6 md:space-y-1" data-scroll-frame>
        <a href="/admin"
           class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#menu"></use></svg>
          Pages
        </a>
        <a href="/admin/tags"
           class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#tag"></use></svg>
          Tags
        </a>
        <details class="group shrink-0 overflow-hidden md:block md:overflow-visible">
          <summary class="flex cursor-pointer list-none items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3 [&::-webkit-details-marker]:hidden">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#settings"></use></svg>
            <span>Settings</span>
            <svg class="ml-auto hidden h-4 w-4 transition-transform group-open:rotate-90 md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#chevron-right"></use></svg>
          </summary>
          <div class="flex max-w-[calc(100vw-2rem)] gap-1 overflow-x-auto md:mt-1 md:ml-3 md:block md:max-w-none md:space-y-1 md:overflow-visible md:border-l md:border-gray-700 md:pl-3" data-scroll-frame>
            <a href="/admin/taxonomies"
               class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#list-filter"></use></svg>
              Taxonomies
            </a>
            <a href="/admin/page_types"
               class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#list"></use></svg>
              Page Types
            </a>
            <a href="/admin/block_types"
               class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#blocks"></use></svg>
              Block Types
            </a>
            {% if canManageUsers %}
            <a href="/admin/users"
               class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#users"></use></svg>
              Users
            </a>
            {% endif %}
            {% if canManageRoles %}
            <a href="/admin/roles"
               class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#shield-check"></use></svg>
              Roles
            </a>
            {% endif %}
            {% if canManagePlugins %}
            <a href="/admin/plugins-manage"
               class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#beaker"></use></svg>
              Plugins
            </a>
            {% endif %}
            {% for item in pluginSettingsNav %}
            <a href="{{ item.href | escape }}"
               class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#beaker"></use></svg>
              {{ item.label | escape }}
            </a>
            {% endfor %}
          </div>
        </details>
        <a href="/admin/trash"
           class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#trash"></use></svg>
          Trash
        </a>
        {% for item in pluginNav %}
        <a href="{{ item.href | escape }}"
           class="flex shrink-0 items-center gap-2 px-3 py-2 rounded-lg text-gray-300 hover:bg-gray-700 hover:text-white transition-colors md:gap-3">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#beaker"></use></svg>
          {{ item.label | escape }}
        </a>
        {% endfor %}
      </nav>
      <div class="flex items-center justify-between gap-3 px-4 py-3 border-t border-gray-700 md:block md:py-4">
        <div class="hidden min-w-0 items-center gap-3 sm:flex md:mb-3">
          {% if hasUserAvatar %}
            <div class="relative w-8 h-8 shrink-0">
              <img src="{{ userAvatar | escape }}"
                   class="w-8 h-8 rounded-full object-cover"
                   alt="avatar"
                   data-avatar-img>
              <div class="hidden w-8 h-8 rounded-full bg-indigo-500 flex items-center justify-center text-sm font-bold"
                   data-avatar-fallback>{{ userInitial | escape }}</div>
            </div>
          {% else %}
            <div class="w-8 h-8 shrink-0 rounded-full bg-indigo-500 flex items-center justify-center text-sm font-bold"
                 data-avatar-fallback>{{ userInitial | escape }}</div>
          {% endif %}
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-white truncate">{{ userName | escape }}</p>
            <p class="text-xs text-gray-400 capitalize">{{ userRoleLabel | escape }}</p>
          </div>
        </div>
        <div class="flex shrink-0 items-center gap-3 md:flex-col md:items-start">
          <button type="button"
                  class="inline-flex shrink-0 items-center gap-2 rounded-lg border border-gray-700 px-2.5 py-1.5 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white"
                  data-theme-toggle
                  aria-pressed="false"
                  aria-label="Switch to light theme">
            <svg class="h-4 w-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-theme-icon="light"><use href="/assets/icons.svg#sun"></use></svg>
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" data-theme-icon="dark"><use href="/assets/icons.svg#moon"></use></svg>
            <span data-theme-toggle-label>Dark</span>
          </button>
          <form method="POST" action="/auth/logout" class="inline">
            <button type="submit"
                    class="flex shrink-0 items-center gap-2 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="/assets/icons.svg#logout"></use></svg>
              Sign out
            </button>
          </form>
        </div>
      </div>
    </aside>
  {% endif %}
  <div class="{{ contentClass }} min-h-full min-w-0">
    {{ body }}
  </div>
  <script nonce="{{ nonce }}">
  // Drag-and-drop reorder for tables with [data-reorder].
  // Rows carry data-id (weight mode) or data-index (order mode).
  // [data-reorder-handle-only]: drag may only start from [data-reorder-handle] cells.
  (function() {
    var dragSrc = null, dragTable = null, mdTarget = null;
    // Invisible 1×1 element used as the drag image so no ghost floats around.
    var ghost = document.createElement('span');
    ghost.style.cssText = 'position:fixed;pointer-events:none;opacity:0;width:1px;height:1px';
    document.body.appendChild(ghost);
    // Track mousedown so handle-only tables know whether the drag started on a handle.
    document.addEventListener('mousedown', function(e) { mdTarget = e.target; });
    // Make every eligible row draggable.
    Array.from(document.querySelectorAll('table[data-reorder] tbody tr[data-id], table[data-reorder] tbody tr[data-index]')).forEach(function(tr) {
      tr.setAttribute('draggable', 'true');
    });
    document.addEventListener('dragstart', function(e) {
      var tr = e.target.closest && e.target.closest('tr[data-id],tr[data-index]');
      if (!tr) return;
      var table = tr.closest('table[data-reorder]');
      if (!table) return;
      if (table.hasAttribute('data-reorder-handle-only') && (!mdTarget || !mdTarget.closest('[data-reorder-handle]'))) {
        e.preventDefault(); return;
      }
      dragSrc = tr; dragTable = table;
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setDragImage(ghost, 0, 0);
      setTimeout(function() { if (dragSrc) dragSrc.style.opacity = '0.4'; }, 0);
    });
    document.addEventListener('dragover', function(e) {
      if (!dragSrc) return;
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
      var tr = e.target.closest && e.target.closest('tr[data-id],tr[data-index]');
      if (!tr || tr === dragSrc || tr.closest('table[data-reorder]') !== dragTable) return;
      var rect = tr.getBoundingClientRect();
      var ref = e.clientY > rect.top + rect.height / 2 ? tr.nextSibling : tr;
      if (ref !== dragSrc && ref !== dragSrc.nextSibling) tr.parentNode.insertBefore(dragSrc, ref);
    });
    document.addEventListener('drop', function(e) {
      e.preventDefault();
      if (dragSrc) dragSrc.style.opacity = '';
    });
    document.addEventListener('dragend', function() {
      if (!dragSrc) return;
      dragSrc.style.opacity = '';
      save(dragTable);
      dragSrc = null; dragTable = null; mdTarget = null;
    });
    function save(table) {
      var url = table.getAttribute('data-reorder');
      var key = table.getAttribute('data-reorder-key') || 'reorder';
      var mode = table.getAttribute('data-reorder-mode');
      var rows = Array.from(table.querySelectorAll('tbody tr[data-id],tbody tr[data-index]'));
      var body = {};
      if (mode === 'order') {
        body[key] = rows.map(function(r) { return parseInt(r.getAttribute('data-index'), 10); });
      } else {
        body[key] = rows.map(function(r, i) { return { id: Number(r.getAttribute('data-id')), weight: i * 10 }; });
      }
      fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) }).catch(function() {});
    }
  })();
  </script>
</body>
</html>
