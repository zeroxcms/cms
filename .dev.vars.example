# Local development secrets – copy this to .dev.vars and fill in real values
# .dev.vars is gitignored and never committed

JWT_SECRET=replace-with-a-random-32-byte-hex-string
CANONICAL_ORIGIN=http://localhost:8787
OAUTH_REDIRECT_URI=http://localhost:8787/auth/callback
# Add a line per provider you enable:
EVENTUAI_CLIENT_SECRET=your-eventuai-client-secret
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GOOGLE_CLIENT_SECRET=your-google-client-secret
